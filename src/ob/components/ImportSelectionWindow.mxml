<mg:TitleWindow xmlns:fx="http://ns.adobe.com/mxml/2009"
    xmlns:s="library://ns.adobe.com/flex/spark"
    xmlns:mx="library://ns.adobe.com/flex/mx"
    xmlns:mg="library://ns.mignari.com/mg"
    width="500"
    height="400"
    fontSize="11"
    title="Import Selection">

    <fx:Metadata>
        [ResourceBundle("strings")]
    </fx:Metadata>

    <fx:Script>
        <![CDATA[
            import com.mignari.utils.DialogDetail;

            import flash.filesystem.File;
            import flash.net.FileFilter;

            import mx.collections.ArrayCollection;

            import otlib.loaders.PathHelper;

            // --------------------------------------------------------------------------
            // PROPERTIES
            // --------------------------------------------------------------------------

            private var _detail:uint = DialogDetail.CANCEL;
            private var _selectedFiles:Vector.<PathHelper>;
            private var _folder:File;

            [Bindable]
            private var _fileList:ArrayCollection = new ArrayCollection();

            [Bindable]
            private var _recursive:Boolean = false;

            // --------------------------------------------------------------------------
            // GETTERS
            // --------------------------------------------------------------------------

            public function get detail():uint
            {
                return _detail;
            }

            public function get selectedFiles():Vector.<PathHelper>
            {
                return _selectedFiles;
            }

            // --------------------------------------------------------------------------
            // METHODS
            // --------------------------------------------------------------------------

            protected function importFilesButtonClickHandler(event:MouseEvent):void
            {
                var filter:FileFilter = new FileFilter("OBD Files (*.obd)", "*.obd");
                var file:File = File.documentsDirectory;
                file.addEventListener("selectMultiple", filesSelectMultipleHandler);
                file.addEventListener(Event.CANCEL, filesCancelHandler);
                file.browseForOpenMultiple("Select OBD Files", [filter]);
            }

            private function filesSelectMultipleHandler(event:Event):void
            {
                var file:File = File(event.target);
                file.removeEventListener("selectMultiple", filesSelectMultipleHandler);
                file.removeEventListener(Event.CANCEL, filesCancelHandler);

                var fileList:Array = event.target["files"] as Array;
                if (fileList && fileList.length > 0)
                {
                    _selectedFiles = new Vector.<PathHelper>();
                    var idx:uint = 0;
                    for each (var f:File in fileList)
                    {
                        if (f.extension && f.extension.toLowerCase() == "obd")
                        {
                            _selectedFiles.push(new PathHelper(f.nativePath, idx));
                            idx++;
                        }
                    }
                    if (_selectedFiles.length > 0)
                    {
                        _detail = DialogDetail.OK;
                        close();
                    }
                }
            }

            private function filesCancelHandler(event:Event):void
            {
                var file:File = File(event.target);
                file.removeEventListener("selectMultiple", filesSelectMultipleHandler);
                file.removeEventListener(Event.CANCEL, filesCancelHandler);
            }

            protected function importFolderButtonClickHandler(event:MouseEvent):void
            {
                var dir:File = File.documentsDirectory;
                dir.addEventListener(Event.SELECT, folderSelectHandler);
                dir.addEventListener(Event.CANCEL, folderCancelHandler);
                dir.browseForDirectory("Select folder with OBD files");
            }

            private function folderSelectHandler(event:Event):void
            {
                var dir:File = File(event.target);
                dir.removeEventListener(Event.SELECT, folderSelectHandler);
                dir.removeEventListener(Event.CANCEL, folderCancelHandler);
                _folder = dir;
                scanFolder(dir);
            }

            private function folderCancelHandler(event:Event):void
            {
                var dir:File = File(event.target);
                dir.removeEventListener(Event.SELECT, folderSelectHandler);
                dir.removeEventListener(Event.CANCEL, folderCancelHandler);
            }

            private function scanFolder(folder:File):void
            {
                _fileList.removeAll();
                var files:Array = folder.getDirectoryListing();
                var obdFiles:Vector.<File> = new Vector.<File>();

                collectFiles(folder, obdFiles);

                for each (var f:File in obdFiles)
                {
                    _fileList.addItem({name: f.name, path: f.nativePath});
                }

                confirmButton.enabled = (_fileList.length > 0);
            }

            private function collectFiles(folder:File, result:Vector.<File>):void
            {
                var files:Array = folder.getDirectoryListing();
                for each (var f:File in files)
                {
                    if (f.isDirectory && _recursive)
                    {
                        collectFiles(f, result);
                    }
                    else if (f.extension && f.extension.toLowerCase() == "obd")
                    {
                        result.push(f);
                    }
                }
            }

            protected function confirmButtonClickHandler(event:MouseEvent):void
            {
                _selectedFiles = new Vector.<PathHelper>();
                for (var i:int = 0; i < _fileList.length; i++)
                {
                    var item:Object = _fileList.getItemAt(i);
                    _selectedFiles.push(new PathHelper(item.path, uint(i)));
                }
                _detail = DialogDetail.OK;
                close();
            }

            protected function recursiveChangeHandler(event:Event):void
            {
                _recursive = CheckBox(event.target).selected;
                if (_folder)
                    scanFolder(_folder);
            }
        ]]>
    </fx:Script>

    <mg:layout>
        <s:VerticalLayout/>
    </mg:layout>

    <s:VGroup width="100%" height="100%" gap="10" padding="10">
        <s:HGroup width="100%" gap="10">
            <s:Button label="Import Files..."
                width="50%" height="28"
                click="importFilesButtonClickHandler(event)"/>
            <s:Button label="Import Folder..."
                width="50%" height="28"
                click="importFolderButtonClickHandler(event)"/>
        </s:HGroup>

        <s:CheckBox label="Scan subfolders recursively"
            selected="{_recursive}"
            change="recursiveChangeHandler(event)"/>

        <s:Label text="Files found: {_fileList.length}" fontWeight="bold"/>

        <s:List id="fileListDisplay"
            width="100%" height="100%"
            dataProvider="{_fileList}"
            labelField="name"
            borderAlpha="0"
            contentBackgroundColor="0x494949"/>
    </s:VGroup>

    <s:BorderContainer width="100%" skinClass="com.mignari.skins.PixeledBorderContainerSkin">
        <s:layout>
            <s:HorizontalLayout gap="10" padding="10" verticalAlign="middle" horizontalAlign="right"/>
        </s:layout>

        <s:Button id="confirmButton"
            label="@Resource(key='confirm', bundle='strings')"
            minWidth="70"
            enabled="false"
            click="confirmButtonClickHandler(event)"/>

        <s:Button id="cancelButton"
            label="@Resource(key='cancel', bundle='strings')"
            minWidth="70"
            click="close()"/>
    </s:BorderContainer>
</mg:TitleWindow>
