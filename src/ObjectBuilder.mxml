            private function requestThingWithDebounce(thingId:uint, category:String):void
            {
                // Store pending request
                _pendingThingId = thingId;
                _pendingThingCategory = category;
            
                // Cancel previous timer
                if (_thingSelectionDebounceTimer)
                {
                    _thingSelectionDebounceTimer.stop();
                    _thingSelectionDebounceTimer.removeEventListener(TimerEvent.TIMER, onThingSelectionDebounce);
                }
            
                // Start new debounce timer (150ms delay)
                _thingSelectionDebounceTimer = new Timer(150, 1);
                _thingSelectionDebounceTimer.addEventListener(TimerEvent.TIMER, onThingSelectionDebounce);
                _thingSelectionDebounceTimer.start();
            }
            
            private function onThingSelectionDebounce(event:TimerEvent):void
            {
                _thingSelectionDebounceTimer.removeEventListener(TimerEvent.TIMER, onThingSelectionDebounce);
                _thingSelectionDebounceTimer = null;
            
                if (_pendingThingId != 0 && _pendingThingCategory)
                {
                    sendCommand(new GetThingCommand(_pendingThingId, _pendingThingCategory));
                }
            }
