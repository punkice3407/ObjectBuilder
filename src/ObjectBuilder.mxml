            protected function uncaughtErrorHandler(event:UncaughtErrorEvent):void
            {
                event.preventDefault();

                var message:String;
                var stackTrace:String = "";

                if (event.error is Error)
                {
                    var error:Error = event.error as Error;
                    message = error.message;
                    stackTrace = error.getStackTrace();
                }
                else if (event.error is ErrorEvent)
                {
                    var errorEvent:ErrorEvent = event.error as ErrorEvent;
                    message = errorEvent.text;
                }
                else
                {
                    message = String(event.error);
                }

                var fullMessage:String = "Uncaught error: " + message;
                if (stackTrace)
                    fullMessage += "\n\n" + stackTrace;

                Log.error(fullMessage);

                var errorWindow:ErrorWindow = new ErrorWindow();
                errorWindow.message = fullMessage;
                errorWindow.open();
                WindowUtil.centralizeWindowOnScreen(errorWindow);

                if (_locked)
                    _locked = false;
            }

