            protected function thingEditorDragDropHandler(event:NativeDragEvent):void
            {
                if (!clientLoaded)
                    return;
            
                var clipboard:Clipboard = event.clipboard;
                if (clipboard.hasFormat(ClipboardFormats.FILE_LIST_FORMAT))
                {
                    var fileList:Array = clipboard.getData(ClipboardFormats.FILE_LIST_FORMAT) as Array;
                    if (!fileList || fileList.length == 0)
                        return;
            
                    var file:File = fileList[0];
                    if (FileUtil.hasBitmapFormat(file))
                    {
                        // Capture current framegroup BEFORE async load
                        var savedGroupType:uint = thingTypeEditor.frameGroupSlider.value;
                        var loader:BitmapLoader = new BitmapLoader();
                        loader.addEventListener(Event.COMPLETE, loadCompleteHandler);
                        loader.load(file);
                    }
                }
            
                function loadCompleteHandler(event:Event):void
                {
                    var bitmap:BitmapData = event.target.bitmap;
                    var thing:ThingType = thingTypeEditor.getThingTypeResult();
                    var groupType:uint = savedGroupType;
            
                    var frameGroup:FrameGroup = thing.getFrameGroup(groupType);
                    var size:Size = frameGroup.getSpriteSheetSize();
            
                    // Check if this is a single frame group spritesheet
                    if (bitmap.width == size.width && size.height == bitmap.height)
                    {
                        // Copy sprites from ALL frame groups (preserve other groups)
                        var sprites:Dictionary = new Dictionary();
                        var existingData:ThingData = thingTypeEditor.thingData;
            
                        for (var g:uint = FrameGroupType.DEFAULT; g <= FrameGroupType.WALKING; g++)
                        {
                            var fg:FrameGroup = thing.getFrameGroup(g);
                            if (!fg)
                                continue;
            
                            var len:uint = fg.spriteIndex.length;
                            sprites[g] = new Vector.<SpriteData>(len, true);
            
                            if (g == groupType)
                            {
                                // For the target group, create new sprite data (will be filled by setSpriteSheet)
                                for (var i:uint = 0; i < len; i++)
                                    sprites[g][i] = SpriteData.createSpriteData(fg.spriteIndex[i]);
                            }
                            else if (existingData && existingData.sprites[g])
                            {
                                // For other groups, copy existing sprite data
                                for (var j:uint = 0; j < len; j++)
                                    sprites[g][j] = existingData.sprites[g][j];
                            }
                            else
                            {
                                // Fallback: create empty sprite data
                                for (var k:uint = 0; k < len; k++)
                                    sprites[g][k] = SpriteData.createSpriteData(fg.spriteIndex[k]);
                            }
                        }
                        var data:ThingData = ThingData.create(OBDVersions.OBD_VERSION_3, _version.value, thing, sprites);
                        data.setSpriteSheet(frameGroup, bitmap);
                        thingTypeEditor.thingData = data;
                        confirmButton.enabled = true;
                        thingTypeEditor.invalidateThingData();
                        // Restore the current framegroup selection after invalidation cycle completes
                        restoreFrameGroupSelection(groupType);
                    }
                    else
                    {
                        // Check if this is a combined spritesheet (from getTotalSpriteSheet)
                        var allSprites:Dictionary = new Dictionary();
                        var hasAnyGroup:Boolean = false;
            
                        for (var g2:uint = FrameGroupType.DEFAULT; g2 <= FrameGroupType.WALKING; g2++)
                        {
                            var fg2:FrameGroup = thing.getFrameGroup(g2);
                            if (!fg2)
                                continue;
            
                            hasAnyGroup = true;
                            var len2:uint = fg2.spriteIndex.length;
                            allSprites[g2] = new Vector.<SpriteData>(len2, true);
                            for (var m:uint = 0; m < len2; m++)
                                allSprites[g2][m] = SpriteData.createSpriteData(fg2.spriteIndex[m]);
                        }
            
                        if (hasAnyGroup)
                        {
                            var combinedData:ThingData = ThingData.create(OBDVersions.OBD_VERSION_3, _version.value, thing, allSprites);
                            var totalSize:Size = combinedData.getTotalSpriteSheetSize();
            
                            if (bitmap.width == totalSize.width && bitmap.height == totalSize.height)
                            {
                                // Combined spritesheet - import to all frame groups
                                combinedData.setTotalSpriteSheet(bitmap);
                                thingTypeEditor.thingData = combinedData;
                                confirmButton.enabled = true;
                                thingTypeEditor.invalidateThingData();
                                // Restore the current framegroup selection after invalidation cycle completes
                                restoreFrameGroupSelection(groupType);
                            }
                            else
                            {
                                var message:String = resourceManager.getString("strings", "invalidSpriteSheetSize");
                                Alert.show(StringUtil.format(message, size.width + " or " + totalSize.width, size.height + " or " + totalSize.height),
                                        resourceManager.getString("strings", "invalidSpriteSheetSizeTitle"));
                            }
                        }
                        else
                        {
                            var message2:String = resourceManager.getString("strings", "invalidSpriteSheetSize");
                            Alert.show(StringUtil.format(message2, size.width, size.height),
                                    resourceManager.getString("strings", "invalidSpriteSheetSizeTitle"));
                        }
                    }
                }
            }
            
            protected function replaceSpriteHandler(event:Event):void
            {
                if (!clientLoaded)
