            public function set thingData(value:ThingData):void
            {
                if (_thingData != value)
                {
                    _nextThingData = value;
                    _thingDataChanged = true;
            
                    // Check availability first
                    if (value && value.thing)
                    {
                        var fg:FrameGroup = value.thing.getFrameGroup(FrameGroupType.DEFAULT);
                        _canColorize = fg && fg.layers > 1;
                        _isOutfit = (value.category == ThingCategory.OUTFIT);
                    }
                    else
                    {
                        _canColorize = false;
                        _isOutfit = false;
                    }
            
                    // Then apply colorization logic (maintains persistence)
                    updateColorize();
            
                    invalidateProperties();
                }
            }
            
