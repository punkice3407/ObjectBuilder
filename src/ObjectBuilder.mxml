            public function requestEditThing(id:uint, category:String):void
            {
                if (!clientLoaded)
                    return;
            
                if (category != _category)
                {
                    // Store the pending edit ID so onSetCategory uses it instead of minimum
                    _pendingEditId = id;
                    _pendingEditThing = true;
                    currentCategory = category;
                    return; // onSetCategory will handle the rest
                }
            
                _pendingEditThing = true;
                if (thingData && thingData.id == id && thingData.category == category)
                {
                    editThing(thingData);
                    _pendingEditThing = false;
                }
                else
                {
                    _communicator.sendCommand(new GetThingCommand(id, category));
                }
            }
            
            public function selectThing(id:uint, category:String, requestList:Boolean = true):void
            {
                if (!clientLoaded)
                    return;
            
                if (category != _category)
                {
                    // Store the pending ID so onSetCategory uses it instead of minimum
                    _pendingEditId = id;
                    currentCategory = category;
                    return; // onSetCategory will handle the rest (and ALWAYS loads list)
                }
            
                // Same category - just select it
                thingStepper.value = id;
            
                // Force a clear to ensure the list refreshes when the new data arrives
                // This helps when performing quick actions like Remove from FindWindow
                thingList.removeAll();
                thingGridList.removeAll();
            
                // If requested, load the list
                if (requestList)
                {
                    sendCommand(new GetThingListCommand(id, category));
                }
            }
            
            public function copyThingToClipboard(thing:ThingType):void
            {
                if (!thing)
                    return;
            
                // Silently ignore if same object is already copied
                if (thingList && thingList.hasClipboardObject && _copiedSourceId == thing.id && _copiedSourceCategory == thing.category)
                {
                    return;
                }
            
                _copiedSourceId = thing.id;
                _copiedSourceCategory = thing.category;
            
                // Optimization: use loaded thingData if available
                if (thingData && thingData.id == thing.id && thingData.category == thing.category)
                {
                    _copiedThingData = thingData;
                    _copiedThingType = thingData.thing.clone();

                    setClipboardFlag("hasClipboardObject", true);
                    appendLog(StringUtil.format(resourceManager.getString('strings', 'objectCopied'), resourceManager.getString('strings', thingData.category), thingData.id));
                }
                else
                {
                    _pendingCopyObject = true;
                    sendCommand(new GetThingCommand(thing.id, thing.category));
                }
            }
            
            public function pasteThingFromClipboard(targets:Vector.<ThingType>):void
            {
                if (!clientLoaded || !_copiedThingData || !targets || targets.length == 0)
                    return;
            
                var sourceCategory:String = _copiedThingData.category;
            
                // Check all targets have same category as source
                for each (var t:ThingType in targets)
                {
                    if (t.category != sourceCategory)
                    {
                        var errorMsg:String = StringUtil.format(resourceManager.getString('strings', 'categoryMismatchError'), sourceCategory, t.category);
                        Alert.show(errorMsg, resourceManager.getString('strings', 'error'), Alert.OK, this);
                        return;
                    }
                }
            
                var confirmMessage:String = targets.length > 1
                    ? resourceManager.getString('strings', 'confirmPasteObject') + " (" + targets.length + " items)"
                    : resourceManager.getString('strings', 'confirmPasteObject');
            
                Alert.show(
                        confirmMessage,
                        resourceManager.getString('strings', 'confirm'),
                        Alert.YES | Alert.NO,
                        this,
                        confirmPasteObjectHandler
                    );
            
                function confirmPasteObjectHandler(e:CloseEvent):void
                {
                    if (e.detail == Alert.YES)
                    {
                        var dataList:Vector.<ThingData> = new Vector.<ThingData>();
                        for each (var target:ThingType in targets)
                        {
                            var clonedData:ThingData = _copiedThingData.clone();
                            clonedData.thing.id = target.id;
                            clonedData.thing.category = target.category;
                            dataList.push(clonedData);
                        }
                        sendCommand(new ReplaceThingsCommand(dataList));
            
                        if (_settings.deleteAfterPaste)
                        {
                            _copiedThingData = null;
                            if (thingList)
                                thingList.hasClipboardObject = false;
                        }
            
                        appendLog(StringUtil.format(resourceManager.getString('strings', 'objectPasted'), resourceManager.getString('strings', sourceCategory), _copiedSourceId, targets.length > 1 ? targets.length + " items" : targets[0].id));
                    }
                    if (thingList)
                        thingList.setFocus();
                }
            }
            
