            public function openNewWindow():void
            {
                try {
                    if (!NativeProcess.isSupported)
                    {
                        appendLog("NativeProcess not supported on this platform");
                        return;
                    }
                    var info:NativeProcessStartupInfo = new NativeProcessStartupInfo();
                    info.executable = File.applicationDirectory.resolvePath("ObjectBuilder.exe");
                    if (!info.executable.exists)
                    {
                        appendLog("Cannot find ObjectBuilder.exe");
                        return;
                    }
                    var process:NativeProcess = new NativeProcess();
                    process.start(info);
                    appendLog("New instance launched");
                } catch (error:Error) {
                    appendLog("Failed to open new instance: " + error.message);
                }
            }

            public function createNewProject():void
            {
                if (_locked)
                    return;
            
                _locked = true;
            
                var window:CreateAssetsWindow = new CreateAssetsWindow();
                window.extended = _settings.extended;
                window.transparency = _settings.transparency;
                window.improvedAnimations = _settings.improvedAnimations;
                window.frameGroups = _settings.frameGroups;
                window.addEventListener(Event.CLOSE, windowCloseHandler);
                window.open(this);
            
                function windowCloseHandler(event:Event):void
                {
                    _locked = false;
            
                    if (window.detail == DialogDetail.OK)
                    {
                        // TODO: check if it's changed/compiled
            
                        setSpriteExtend(window.spriteDimension);
                        var features:ClientFeatures = ClientFeatures.fromWindow(window);
                        sendCommand(new CreateNewFilesCommand(window.version.datSignature,
                                    window.version.sprSignature,
                                    features));
                    }
                }
            }
            
            public function openProject(directory:File = null):void
            {
                if (_locked)
                    return;
            
                _locked = true;
            
                var window:OpenAssetsWindow = new OpenAssetsWindow();
                window.clientDirectory = directory || _settings.getLastDirectory();
                window.serverItemsDirectory = _settings.getServerItemsDirectory();
                window.extended = _settings.extended;
                window.transparency = _settings.transparency;
                window.improvedAnimations = _settings.improvedAnimations;
                window.frameGroups = _settings.frameGroups;
                window.attributeServer = _settings.lastAttributeServer || "tfs1.4";
                window.addEventListener(Event.CLOSE, windowCloseHandler);
                window.open(this);
            
                function windowCloseHandler(event:Event):void
                {
                    _locked = false;
            
                    if (window.detail == DialogDetail.OK)
                    {
                        var mainFile:File = window.datFile || window.sprFile;
                        _settings.setLastDirectory(mainFile);
                        _settings.setServerItemsDirectory(window.serverItemsDirectory);
                        _settings.lastAttributeServer = window.attributeServer;
                        _filesName = FileUtil.getName(mainFile);
            
                        // Build server items path: check for OTB, then tibia.dat, then assets.dat
                        var serverItemsPath:String = null;
                        if (window.serverItemsDirectory && window.serverItemsDirectory.exists)
                        {
                            var otbFile:File = window.serverItemsDirectory.resolvePath("items.otb");
                            var tibiaDatFile:File = window.serverItemsDirectory.resolvePath("Tibia.dat");
                            var assetsDatFile:File = window.serverItemsDirectory.resolvePath("assets.dat");
            
                            if (otbFile.exists)
                            {
                                serverItemsPath = otbFile.nativePath;
                            }
                            else if (tibiaDatFile.exists)
                            {
                                serverItemsPath = tibiaDatFile.nativePath;
                            }
                            else if (assetsDatFile.exists)
                            {
                                serverItemsPath = assetsDatFile.nativePath;
                            }
                        }
            
                        setSpriteExtend(window.spriteDimension);
                        var features:ClientFeatures = ClientFeatures.fromWindow(window);
            
                        // Load selected attribute server before loading files (force reload to pick up any config changes)
                        _attributeRegistry.loadServer(window.attributeServer, true);
                        thingTypeEditor.refreshAttributeServer();
            
                        // Get known attributes to pass to worker (includes nested attributes)
                        var knownAttrs:Array = _attributeRegistry.getAttributeKeysInOrder();
            
                        // Close any active object editor
                        editThing(null);
            
                        sendCommand(new LoadFilesCommand(window.datFile,
                                    window.sprFile,
                                    window.version,
                                    serverItemsPath,
                                    features,
                                    knownAttrs));
                    }
                }
            }
            
            public function compileProject():void
            {
                if (!clientLoaded)
                    return;
            
                if (clientIsTemporary)
                {
                    compileProjectAs();
                    return;
                }
            
                if (_settings.autosaveThingChanges)
                    saveThingChanges();
            
                sendCommand(new CompileCommand());
            }
            
            public function compileProjectAs():void
            {
                if (!clientLoaded || _locked)
                    return;
            
                _locked = true;
            
                var window:CompileAssetsWindow = new CompileAssetsWindow();
                window.directory = _settings.getLastDirectory();
                window.version = _versionStorage.getFromClientInfo(_clientInfo);
                window.extended = _clientInfo.extended;
                window.transparency = _clientInfo.transparency;
                window.improvedAnimations = _clientInfo.improvedAnimations;
                window.frameGroups = _clientInfo.frameGroups;
                window.filesName = isNullOrEmpty(_filesName) ? "Tibia" : _filesName;
                window.serverItemsLoaded = _otbLoaded;
                window.serverItemsDirectory = _settings.getServerItemsDirectory();
                window.attributeServer = _settings.lastAttributeServer;
                window.addEventListener(Event.CLOSE, windowCloseHandler);
                window.open(this);
            
                function windowCloseHandler(event:Event):void
                {
                    _locked = false;
                    _settings.setLastDirectory(window.directory);
            
                    if (window.detail == DialogDetail.OK)
                    {
                        if (_settings.autosaveThingChanges)
                            saveThingChanges();
            
                        var features:ClientFeatures = ClientFeatures.fromWindow(window);
                        sendCommand(new CompileAsCommand(window.datFile,
                                    window.sprFile,
                                    window.serverItemsPath,
                                    window.serverItemsFormat,
                                    window.serverItemsBinaryPeer,
                                    window.version,
                                    features));
                    }
                }
            }
            
            public function unloadProject():void
            {
                if (!clientLoaded)
                    return;
            
                if (clientChanged)
                {
                    Alert.show(
                            resourceManager.getString("strings", "wantToCompile"),
                            "",
                            Alert.YES | Alert.NO | Alert.CANCEL,
                            this,
                            alertCloseHandler);
                }
                else
                {
                    clear();
                    sendCommand(new UnloadFilesCommand());
                }
            
                function alertCloseHandler(event:CloseEvent):void
                {
                    if (event.detail == Alert.YES)
                        compileProject();
                    else if (event.detail == Alert.NO)
                    {
                        clear();
                        sendCommand(new UnloadFilesCommand());
                    }
                }
            }
            
