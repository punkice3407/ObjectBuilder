            private function updateColorize():void
            {
                if (!colorizeGroupCheckBox || !thingView || !thingData)
                    return;
            
                if (colorizeGroupCheckBox.selected && _canColorize)
                {
                    var od:OutfitData = new OutfitData();
                    od.head = headColorPicker.color;
                    od.body = bodyColorPicker.color;
                    od.legs = legsColorPicker.color;
                    od.feet = feetColorPicker.color;
                    od.addons = addonsColorStepper.value;
                    thingView.outfitData = od;
                }
                else
                {
                    thingView.outfitData = null;
                }
            }
            
            protected function randomizeColorsHandler(event:MouseEvent):void
            {
                if (!colorizeGroupCheckBox || !colorizeGroupCheckBox.selected)
                    return;
            
                headColorPicker.color = Math.floor(Math.random() * 133);
                bodyColorPicker.color = Math.floor(Math.random() * 133);
                legsColorPicker.color = Math.floor(Math.random() * 133);
                feetColorPicker.color = Math.floor(Math.random() * 133);
                updateColorize();
            }
            
            protected function copyXmlLookHandler(event:MouseEvent):void
            {
                if (!thingData || thingData.category != ThingCategory.OUTFIT)
                    return;
            
                var xml:XML = <look/>;
                xml.@type = thingData.id;
            
                if (headColorPicker.color != 0)
                    xml.@head = headColorPicker.color;
                if (bodyColorPicker.color != 0)
                    xml.@body = bodyColorPicker.color;
                if (legsColorPicker.color != 0)
                    xml.@legs = legsColorPicker.color;
                if (feetColorPicker.color != 0)
                    xml.@feet = feetColorPicker.color;
                if (addonsColorStepper.value != 0)
                    xml.@addons = addonsColorStepper.value;
            
                Clipboard.generalClipboard.clear();
                Clipboard.generalClipboard.setData(ClipboardFormats.TEXT_FORMAT, xml.toXMLString());
            
                appendLog("Look XML copied to clipboard");
            }
            
