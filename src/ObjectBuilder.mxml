            public function setSpriteExtend(dimension:SpriteDimension):void
            {
                if (!dimension)
                    return;
            
                SpriteExtent.DEFAULT_VALUE = dimension.toString();
                SpriteExtent.DEFAULT_SIZE = dimension.size;
                SpriteExtent.DEFAULT_DATA_SIZE = dimension.dataSize;
            
                thingTypeEditor.spriteDimension = dimension;
                sendCommand(new SetSpriteDimensionCommand(dimension.toString(), dimension.size, dimension.dataSize));
            }
            
