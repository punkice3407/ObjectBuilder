            private function firstRun():void
            {
                // Sets as default application for supported extensions.
                // Wrap in try-catch since extensions must be declared in app descriptor
                try
                {
                    nativeApplication.setAsDefaultApplication("obd");
                    nativeApplication.setAsDefaultApplication("dat");
                    nativeApplication.setAsDefaultApplication("spr");
                    nativeApplication.setAsDefaultApplication("otb");
                }
                catch (e:Error)
                {
                    // Silently ignore - extension may not be declared in app descriptor
                }
            
                // Clear the application log
                _logTarget.clear();
            }
            
            private function setClientInfoCallback(info:ClientInfo):void
            {
                if (!info)
                    throw new NullArgumentError("info");
            
                _clientInfo = info;
                _version = _versionStorage.getBySignatures(info.datSignature, info.sprSignature);
                _extendedEnabled = info.extended;
                _transparencyEnabled = info.transparency;
                _clientChanged = info.changed;
                _clientIsTemporary = info.isTemporary;
                _clientLoaded = info.loaded;
                _otbLoaded = info.otbLoaded;
                thingList.otbLoaded = _otbLoaded;
                thingGridList.otbLoaded = _otbLoaded;
                foundThingsList.otbLoaded = _otbLoaded;

                infoPanel.setFilesInfo(info);
                thingTypeEditor.filesInfo = info;
            
                thingStepper.minimum = getMinThingId();
                thingStepper.maximum = getMaxThingId();
                spriteStepper.minimum = info.minSpriteId;
                spriteStepper.maximum = info.maxSpriteId;
            }
            
            private function setThingDataCallback(thingData:ThingData):void
            {
                if (!thingData)
                {
                    throw new NullArgumentError("thingData");
                }
            
                // Save current framegroup selection before updating
                var savedFrameGroup:uint = thingTypeEditor.frameGroupSlider.value;
            
                this.thingData = thingData;
            
                // Restore framegroup selection after invalidation cycle
                restoreFrameGroupSelection(savedFrameGroup);
            
                if (_pendingCopyObject)
                {
                    _pendingCopyObject = false;
                    _copiedThingData = thingData;
                    _copiedThingType = thingData.thing.clone();
                    setClipboardFlag("hasClipboardObject", true);
                    appendLog(StringUtil.format(resourceManager.getString('strings', 'objectCopied'), resourceManager.getString('strings', thingData.category), thingData.id));
                }
            
                if (_pendingEditThing)
                {
                    _pendingEditThing = false;
                    editThing(thingData);
                }
            }
            
            private function updateThingPropertiesCallback(thing:ThingType):void
            {
                if (!thing)
                    return;

                if (thingTypeEditor && thingTypeEditor.thingData &&
                        thingTypeEditor.thingData.id == thing.id &&
                        thingTypeEditor.thingData.category == thing.category)
                {
                    _ignoringPropertyChange = true;
                    thingTypeEditor.applyWorkerProperties(thing);
                    _ignoringPropertyChange = false;

                    confirmButton.enabled = false;
                    updateTitle(OtlibUtils.toLocale(thing.category) + " " + thing.id);
                }
            }
            
            private function setThingListCallback(selectedIds:Vector.<uint>, things:Vector.<ThingListItem>, forceUpdate:Boolean = false, prevPageId:int = -1, nextPageId:int = -1):void
            {
                if (!selectedIds)
                {
                    throw new NullArgumentError("selectedIds");
                }
            
                if (!things)
                {
                    throw new NullArgumentError("things");
                }
            
                _currentPrevPageId = prevPageId;
                _currentNextPageId = nextPageId;
            
                thingList.rememberScroll();
                if (forceUpdate)
                {
                    thingList.removeAll();
                    thingGridList.removeAll();
                }

                thingList.setListObjects(things);
                thingList.selectedIds = selectedIds;
                if (selectedIds && selectedIds.length > 0)
                {
                    thingList.ensureIdIsVisible(selectedIds[0]);
                }

                // Sync grid tab data
                thingGridList.setListObjects(things);
                thingGridList.selectedIds = selectedIds;

                getActiveThingList().setFocus();
            
                // Synchronize stepper with actual selected ID from worker
                if (selectedIds.length > 0 && thingStepper.value != selectedIds[0])
                {
                    thingStepper.value = selectedIds[0];
                }
            
                // Request thing data for the new selected ID if it differs from current
                if (selectedIds.length > 0 && (!thingData || thingData.id != selectedIds[0] || thingData.category != currentCategory))
                {
                    sendCommand(new GetThingCommand(selectedIds[0], currentCategory));
                }
            }
            
            private function setSpriteListCallback(selectedIds:Vector.<uint>, sprites:Vector.<SpriteData>, forceUpdate:Boolean = false):void
            {
                if (!selectedIds)
                {
                    throw new NullArgumentError("selectedIds");
                }
            
                if (!sprites)
                {
                    throw new NullArgumentError("sprites");
                }
            
                spritesList.rememberScroll();
                if (forceUpdate)
                {
                    spritesList.forceNextUpdate();
                }
                spritesList.setListObjects(sprites);
                if (selectedIds.length > 0)
                {
                    spritesList.ensureIdIsVisible(selectedIds[0]);
                }
                spritesList.selectedIds = selectedIds;

                // Sync sprite grid data
                if (spritesGridList)
                {
                    spritesGridList.dataProvider = spritesList.dataProvider;
                }
            }

