            protected function replaceThingFromPNGHandler(event:ThingEditorEvent):void
            {
                if (!clientLoaded || !thingTypeEditor.visible || !thingTypeEditor.bindableThingType)
                    return;

                var filter:FileFilter = new FileFilter("PNG Images (*.png)", "*.png");
                var file:File = _settings.getIODirectory() || File.userDirectory;
                file.addEventListener(Event.SELECT, function(e:Event):void
                    {
                        _settings.setIODirectory(file);
                        loadPNGAndReplaceThing(file);
                    });
                file.browseForOpen("Select PNG image", [filter]);
            }

            private function loadPNGAndReplaceThing(file:File):void
            {
                var loader:Loader = new Loader();
                loader.contentLoaderInfo.addEventListener(Event.COMPLETE, function(e:Event):void
                    {
                        var bmp:Bitmap = loader.content as Bitmap;
                        if (!bmp || !bmp.bitmapData)
                            return;

                        applyPNGToThing(bmp.bitmapData);
                        bmp.bitmapData.dispose();
                    });
                loader.contentLoaderInfo.addEventListener(IOErrorEvent.IO_ERROR, function(e:IOErrorEvent):void
                    {
                        Log.error("Failed to load PNG: " + e.text);
                    });
                loader.load(new flash.net.URLRequest(file.url));
            }

            private function applyPNGToThing(source:BitmapData):void
            {
                var bt:BindableThingType = thingTypeEditor.bindableThingType;
                var groupType:uint = thingTypeEditor.frameGroupSlider.value;
                var fg:FrameGroup = bt.getFrameGroup(groupType);
                if (!fg)
                    return;

                var spriteSize:uint = SpriteExtent.DEFAULT_SIZE;
                var cellW:uint = fg.width * spriteSize;
                var cellH:uint = fg.height * spriteSize;

                if (cellW == 0) cellW = spriteSize;
                if (cellH == 0) cellH = spriteSize;

                var totalSprites:uint = fg.spriteIndex.length;
                var spritesPerCell:uint = fg.width * fg.height;
                if (spritesPerCell == 0) spritesPerCell = 1;

                // Calculate how many cells fit in the PNG
                var cols:uint = Math.max(1, Math.floor(source.width / cellW));
                var rows:uint = Math.max(1, Math.floor(source.height / cellH));
                var totalCells:uint = cols * rows;

                // Number of frames we can replace
                var framesToReplace:uint = Math.min(totalCells, Math.ceil(totalSprites / spritesPerCell));

                var rect:Rectangle = new Rectangle(0, 0, spriteSize, spriteSize);
                var pt:Point = new Point(0, 0);
                var spriteIndex:uint = 0;

                for (var cell:uint = 0; cell < framesToReplace; cell++)
                {
                    var cellCol:uint = cell % cols;
                    var cellRow:uint = Math.floor(cell / cols);
                    var cellX:uint = cellCol * cellW;
                    var cellY:uint = cellRow * cellH;

                    // Each cell contains fg.width * fg.height sprite slots
                    for (var sy:uint = 0; sy < fg.height; sy++)
                    {
                        for (var sx:uint = 0; sx < fg.width; sx++)
                        {
                            if (spriteIndex >= totalSprites)
                                break;

                            // Extract 32x32 sprite from the cell
                            var sprX:uint = cellX + sx * spriteSize;
                            var sprY:uint = cellY + sy * spriteSize;

                            var spriteBmp:BitmapData = new BitmapData(spriteSize, spriteSize, true, 0);
                            rect.x = sprX;
                            rect.y = sprY;
                            rect.width = spriteSize;
                            rect.height = spriteSize;
                            spriteBmp.copyPixels(source, rect, pt);

                            var pixels:ByteArray = spriteBmp.getPixels(spriteBmp.rect);
                            var sd:SpriteData = SpriteData.createSpriteData(uint.MAX_VALUE, pixels);
                            bt.setSprite(groupType, spriteIndex, sd);

                            spriteBmp.dispose();
                            spriteIndex++;
                        }
                    }
                }

                thingTypeEditor.updatePreview();
                saveThingChanges();
