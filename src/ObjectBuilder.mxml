            private function applicationLoadComplete():void
            {
                visible = true;
                activate();
            
                if (_settings.maximized)
                    maximize();

                previewPanel.width = Math.max(previewPanel.minWidth, _settings.previewContainerWidth);
                thingsPanel.width = Math.max(thingsPanel.minWidth, _settings.thingListContainerWidth);
                spritesPanel.width = Math.max(spritesPanel.minWidth, _settings.spritesContainerWidth);

                if (_settings.largerWindowsFor4K)
                {
                    var scaleFactor:Number = 1.5;
                    if (previewPanel.width == previewPanel.minWidth)
                        previewPanel.width = Math.round(previewPanel.minWidth * scaleFactor);
                    if (thingsPanel.width == thingsPanel.minWidth)
                        thingsPanel.width = Math.round(thingsPanel.minWidth * scaleFactor);
                    if (spritesPanel.width == spritesPanel.minWidth)
                        spritesPanel.width = Math.round(spritesPanel.minWidth * scaleFactor);
                    thingsPanel.maxWidth = Math.round(thingsPanel.maxWidth * scaleFactor);
                    spritesPanel.maxWidth = Math.round(spritesPanel.maxWidth * scaleFactor);
                }
                showPreviewPanel = _settings.showPreviewPanel;
                showThingsPanel = _settings.showThingsPanel;
                showSpritesPanel = _settings.showSpritesPanel;
                thingStepper.amount = _settings.objectsListAmount;
                spriteStepper.amount = _settings.spritesListAmount;
                hideEmptyObjectsCheckbox.selected = _settings.hideEmptyObjects;
                if (_settings.objectsActiveTab < objectsViewStack.numChildren)
                    setObjectsView(_settings.objectsActiveTab);
                if (_settings.objectsGridColumns >= 2)
                {
                    gridColumnsStepper.value = _settings.objectsGridColumns;
                    thingGridList.gridColumns = _settings.objectsGridColumns;
                }
                if (_settings.objectsGridIconSize >= 16)
                {
                    gridIconSizeStepper.value = _settings.objectsGridIconSize;
                    thingGridList.iconSize = _settings.objectsGridIconSize;
                }
                if (_settings.spritesActiveTab < spritesViewStack.numChildren)
                    setSpritesView(_settings.spritesActiveTab);
                if (_settings.spritesGridColumns >= 2)
                {
                    spriteGridColumnsStepper.value = _settings.spritesGridColumns;
                    if (spritesGridList && spritesGridList.dataGroup && spritesGridList.dataGroup.layout is TileLayout)
                        TileLayout(spritesGridList.dataGroup.layout).requestedColumnCount = _settings.spritesGridColumns;
                }
                if (_settings.spritesGridIconSize >= 16)
                {
                    spriteGridIconSizeStepper.value = _settings.spritesGridIconSize;
                    if (spritesGridList) spritesGridList.iconSize = _settings.spritesGridIconSize;
                }
                if (_settings.previewZoom > 0)
                    callLater(setPreviewZoom, [_settings.previewZoom]);
                thingStepper.lastDisplayedIdCallback = getLastDisplayedThingId;
            
                if (_invokeArgs)
                {
                    setInvokeArgs(_invokeArgs);
                    _invokeArgs = null;
                }
            
                _creationComplete = true;
            }
            
            private function setInvokeArgs(args:Array):void
            {
                if (args)
                {
                    var path:String = args[0];
                    if (!isNullOrEmpty(path))
                    {
                        var file:File = new File(path);
            
                        if (file.extension == OTFormat.DAT || file.extension == OTFormat.SPR)
                            openProject(FileUtil.getDirectory(file));
                        else if (file.extension == OTFormat.OBD)
                            openObjectViewer(file);
                    }
                }
            }
            
