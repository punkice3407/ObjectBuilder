                        click="exportSpriteHandler(event)"/>
                    <s:Button id="exportAllSpriteButton"
                        toolTip="@Resource(key='exportAll', bundle='strings')"
                        width="22"
                        height="22"
                        icon="{Assets.EXPORT_ALL}"
                        click="exportAllSpritesHandler(event)"/>
                    <s:Button id="copySpriteButton"
                        toolTip="@Resource(key='copy', bundle='strings')"
                        width="22"
                        height="22"
                        icon="{Assets.MINI_COPY}"
                        click="onCopySprite()"/>
                    <s:Button id="pasteSpriteButton"
                        toolTip="@Resource(key='paste', bundle='strings')"
                        width="22"
                        height="22"
                        icon="{Assets.MINI_PASTE}"
                        click="onPasteSprite()"/>
                    <s:Button id="newSpriteButton"
                        toolTip="@Resource(key='new', bundle='strings')"
                        width="22"
                        height="22"
                        icon="{Assets.NEW}"
                        click="newSpriteButtonClickHandler(event)"/>
                    <s:Button id="removeSpriteButton"
                        toolTip="@Resource(key='remove', bundle='strings')"
                        width="22"
                        height="22"
                        icon="{Assets.DELETE}"
                        click="removeSpriteHandler(event)"/>
                </s:HGroup>
            </s:BorderContainer>
        </mx:HDividedBox>

        <!-- Log Panel at bottom -->
        <otlib:LogPanel id="logPanel"
            width="100%" height="150"
            minHeight="30"
            dataProvider="{_logs}"
            clear="logPanelClearHandler(event)"/>
    </mx:VDividedBox>
</s:WindowedApplication>
