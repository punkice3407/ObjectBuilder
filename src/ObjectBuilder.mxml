                if (thingList && thingList.hasClipboardPatterns && _copiedPatternsThingType && _copiedPatternsThingType.id == thing.id && _copiedPatternsThingType.category == thing.category)
                {
                    return;
                }
            
                _copiedPatternsThingType = thing.clone();
                setClipboardFlag("hasClipboardPatterns", true);
                appendLog(StringUtil.format(resourceManager.getString('strings', 'patternsCopied'), resourceManager.getString('strings', thing.category), thing.id));
            }
            
            public function pastePatternsFromClipboard(targets:Vector.<ThingType>):void
            {
                if (!clientLoaded || !_copiedPatternsThingType || !targets || targets.length == 0)
                    return;
            
                var confirmMessage:String = targets.length > 1
                    ? resourceManager.getString('strings', 'confirmPastePatterns') + " (" + targets.length + " items)"
                    : resourceManager.getString('strings', 'confirmPastePatterns');
            
                Alert.show(
                        confirmMessage,
                        resourceManager.getString('strings', 'confirm'),
                        Alert.YES | Alert.NO,
                        this,
                        confirmPastePatternsHandler
                    );
            
                function confirmPastePatternsHandler(e:CloseEvent):void
                {
                    if (e.detail == Alert.YES)
                    {
                        for each (var target:ThingType in targets)
                        {
                            sendCommand(new PasteThingDataCommand(target.id, target.category, _copiedPatternsThingType, ThingListEvent.PASTE_PATTERNS));
                        }
                        appendLog(StringUtil.format(resourceManager.getString('strings', 'patternsPasted'), resourceManager.getString('strings', targets[0].category), _copiedPatternsThingType.id, targets.length > 1 ? targets.length + " items" : targets[0].id));
                    }
                }
            }
            
            public function copyAttributesToClipboard(thing:ThingType):void
            {
                if (!clientLoaded || !_otbLoaded || !thing)
                    return;

                if (thing.category != ThingCategory.ITEM)
                    return;

                // Get attributes from the currently loaded ThingData
                var td:ThingData = this.thingData;
                if (!td || td.thing.id != thing.id || !td.xmlAttributes)
                {
                    appendLog("No attributes to copy (object not loaded or has no attributes).");
                    return;
                }

                // Deep copy attributes
                _copiedAttributes = {};
                for (var key:String in td.xmlAttributes)
                    _copiedAttributes[key] = td.xmlAttributes[key];
                _copiedAttributesSourceId = thing.id;

                setClipboardFlag("hasClipboardAttributes", true);

                appendLog(StringUtil.format(resourceManager.getString('strings', 'attributesCopied'), resourceManager.getString('strings', thing.category), thing.id));
            }

            public function pasteAttributesFromClipboard(targets:Vector.<ThingType>):void
            {
                if (!clientLoaded || !_otbLoaded || !_copiedAttributes || !targets || targets.length == 0)
                    return;

                // Only paste to items
                for each (var check:ThingType in targets)
                {
                    if (check.category != ThingCategory.ITEM) return;
                }

                var confirmMessage:String = targets.length > 1
                    ? resourceManager.getString('strings', 'confirmPasteAttributes') + " (" + targets.length + " items)"
                    : resourceManager.getString('strings', 'confirmPasteAttributes');

                Alert.show(
                        confirmMessage,
                        resourceManager.getString('strings', 'confirm'),
                        Alert.YES | Alert.NO,
                        this,
                        confirmPasteAttributesHandler
                    );

                function confirmPasteAttributesHandler(e:CloseEvent):void
                {
                    if (e.detail == Alert.YES)
                    {
                        // Create a temporary ThingType to carry attributes via PasteThingDataCommand
                        var sourceThing:ThingType = new ThingType();
                        sourceThing.id = _copiedAttributesSourceId;
                        sourceThing.category = ThingCategory.ITEM;

                        for each (var target:ThingType in targets)
                        {
                            sendCommand(new PasteThingDataCommand(target.id, target.category, sourceThing, ThingListEvent.PASTE_ATTRIBUTES));
                        }
                        appendLog(StringUtil.format(resourceManager.getString('strings', 'attributesPasted'), resourceManager.getString('strings', targets[0].category), _copiedAttributesSourceId, targets.length > 1 ? targets.length + " items" : targets[0].id));
                    }
                }
            }

            public function exportSpriteList(sprites:Vector.<SpriteData>):void
            {
                if (!sprites || sprites.length == 0)
                    return;
            
                var file:File = new File();
                file.addEventListener(Event.SELECT, fileSelectHandler);
                file.browseForDirectory(resourceManager.getString("strings", "exportSprites"));
            
                function fileSelectHandler(event:Event):void
                {
                    var directory:File = event.target as File;
                    var list:Vector.<PathHelper> = new Vector.<PathHelper>();
            
                    for each (var sprite:SpriteData in sprites)
                    {
                        if (sprite.id == uint.MAX_VALUE)
                            continue;
                        var name:String = sprite.id + ".png";
                        var path:String = directory.resolvePath(name).nativePath;
                        list.push(new PathHelper(path, sprite.id));
                    }
            
                    if (list.length > 0)
                        sendCommand(new ExportSpritesCommand(list, true, 100));
                }
            }
        ]]>
    </fx:Script>

