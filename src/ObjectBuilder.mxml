            protected function thingDataNativeDragDropHandler(event:NativeDragEvent):void
            {
                if (!clientLoaded)
                    return;
            
                var clipboard:Clipboard = event.clipboard;
                if (clipboard.hasFormat(ClipboardFormats.FILE_LIST_FORMAT))
