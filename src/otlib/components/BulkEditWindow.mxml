                                    <otlib:BulkPropertyRow id="isTranslucentRow" propertyName="isTranslucent" labelText="@Resource(key='translucent', bundle='strings')" change="onPropertyChange(event)"/>
                                    <otlib:BulkPropertyRow propertyName="isLyingObject" labelText="@Resource(key='lyingObject', bundle='strings')" change="onPropertyChange(event)"/>
                                    <otlib:BulkPropertyRow propertyName="animateAlways" labelText="@Resource(key='animateAlways', bundle='strings')" change="onPropertyChange(event)"/>
                                    <otlib:BulkPropertyRow propertyName="isFullGround" labelText="@Resource(key='fullGround', bundle='strings')" change="onPropertyChange(event)"/>
                                    <otlib:BulkPropertyRow id="ignoreLookRow" propertyName="ignoreLook" labelText="@Resource(key='ignoreLook', bundle='strings')" change="onPropertyChange(event)"/>
                                    <otlib:BulkPropertyRow id="usableRow" propertyName="usable" labelText="@Resource(key='usable', bundle='strings')" change="onPropertyChange(event)"/>
