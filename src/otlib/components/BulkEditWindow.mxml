                                </s:HGroup>
                                <s:HGroup width="100%" verticalAlign="middle" horizontalAlign="right" gap="10" paddingRight="30">
                                    <s:Label text="@Resource(key='actionType', bundle='strings')" textAlign="right" minWidth="60"/>
                                    <s:DropDownList id="defaultActionDropDown" width="170" height="20" fontSize="11" requireSelection="true" selectedIndex="0"
                                        enabled="{changeDefaultActionCheckbox.selected &amp;&amp; defaultActionValueCheckbox.selected}">
                                        <s:dataProvider>
                                            <s:ArrayList>
                                                <fx:String>{resourceManager.getString('strings', 'action.none')}</fx:String>
                                                <fx:String>{resourceManager.getString('strings', 'action.look')}</fx:String>
