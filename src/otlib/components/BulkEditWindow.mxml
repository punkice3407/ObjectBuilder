                                            </s:ArrayList>
                                        </s:dataProvider>
                                    </s:DropDownList>
                                </s:HGroup>
                            </nail:GroupBox>

                            <!-- 10. lensHelp group (ITEM only) -->
                            <nail:GroupBox label="@Resource(key='lensHelp', bundle='strings')"
                                width="100%" includeIn="item">
                                <nail:layout><s:VerticalLayout padding="10" gap="5"/></nail:layout>
                                <s:HGroup width="100%" verticalAlign="middle" gap="10">
                                    <s:CheckBox id="changeLensHelpCheckbox" label="Change" toolTip="@Resource(key='change', bundle='strings')" change="onPropertyChange(event)"/>
                                    <s:CheckBox id="lensHelpValueCheckbox" label="@Resource(key='lensHelp', bundle='strings')" enabled="{changeLensHelpCheckbox.selected}" change="onPropertyChange(event)"/>
                                </s:HGroup>
                                <s:HGroup width="100%" verticalAlign="middle" horizontalAlign="right" gap="10" paddingRight="30">
                                    <s:Label text="{resourceManager.getString('strings', 'type') + ':'}" minWidth="60" textAlign="right"/>
                                    <s:DropDownList id="lensHelpDropDown" width="170" height="20" fontSize="11" requireSelection="true" selectedIndex="0"
                                        enabled="{changeLensHelpCheckbox.selected &amp;&amp; lensHelpValueCheckbox.selected}">
                                        <s:dataProvider>
                                            <s:ArrayList>
                                                <fx:String>{resourceManager.getString('strings', 'lensHelp.ladders')}</fx:String>
