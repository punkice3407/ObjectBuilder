<s:Window xmlns:fx="http://ns.adobe.com/mxml/2009"
    xmlns:s="library://ns.adobe.com/flex/spark"
    xmlns:mx="library://ns.adobe.com/flex/mx"
    xmlns:nail="library://ns.nail.com/naillib"
    xmlns:otlib="otlib.components.*"
    title="@Resource(key='bulkPropertyEditor', bundle='strings')"
    width="900"
    height="700"
    minWidth="625"
    minHeight="400"
    backgroundColor="0x494949"
    showStatusBar="false"
    fontSize="11"
    creationComplete="creationCompleteHandler(event)"
    closing="closingHandler(event)">

    <fx:Metadata>
        [ResourceBundle("strings")]
    </fx:Metadata>

    <fx:Script>
        <![CDATA[
            import com.mignari.utils.DialogDetail;
            
            import mx.events.FlexEvent;
            import mx.resources.IResourceManager;
            import mx.resources.ResourceManager;
            import mx.core.IVisualElementContainer;
            
            import spark.components.CheckBox;
            import spark.components.DropDownList;
            import spark.components.HGroup;
            import spark.components.VGroup;
            import spark.components.Label;
            import spark.components.NumericStepper;
            import mx.collections.ArrayList;
            
            import otlib.things.ThingCategory;
            import otlib.things.ThingType;
            import flash.utils.Dictionary;
            import ob.settings.ObjectBuilderSettings;
            import otlib.utils.ClientInfo;
            
            // --------------------------------------------------------------------------
            // PROPERTIES
            // --------------------------------------------------------------------------
            
            private var _detail:uint = DialogDetail.CANCEL;
            private var _selectedIds:Vector.<uint>;
            private var _category:String;
            
            /** Settings reference for loading server attributes. */
            [Bindable]
            public var settings:ObjectBuilderSettings;
            
            /** Whether OTB/items.xml is loaded */
            [Bindable]
            public var otbLoaded:Boolean = false;

            /** Client version info for version-dependent property visibility. */
            [Bindable]
            public var clientInfo:ClientInfo;
            
            /** Reference to the Attributes Editor for collecting bulk attribute changes. */
            private var _attributesEditor:AttributesEditor;
            
            // Lazy loading for AttributesEditor
            [Bindable]
            private var _currentTabIndex:int = 0;
            
            private var _attributesTabInitialized:Boolean = false;
            
            // --------------------------------------
            // Getters / Setters
            // --------------------------------------
            
            public function get detail():uint
            {
                return _detail;
            }
            
            public function get selectedIds():Vector.<uint>
            {
                return _selectedIds;
            }
            public function set selectedIds(value:Vector.<uint>):void
            {
                _selectedIds = value;
                if (_selectedIds)
                    _selectedIds.sort(Array.NUMERIC);
                if (selectedCountLabel)
                    selectedCountLabel.text = resourceManager.getString("strings", "itemsSelected", [value ? value.length : 0]);
                if (selectedIdsText && value)
                    selectedIdsText.text = "IDs: " + value.join(", ");
            }
            
            public function get category():String
            {
                return _category;
            }
            public function set category(value:String):void
            {
                _category = value;
                this.currentState = value;
            }
            
            public function get changedProperties():Array
            {
                var result:Array = [];
            
                // Collect from all BulkPropertyRow components in the current state
                var rows:Vector.<BulkPropertyRow> = getAllPropertyRows();
                for each (var row:BulkPropertyRow in rows)
                {
                    if (row.isChanged)
                    {
                        result.push({
                                    property: row.propertyName,
                                    value: row.value
                                });
                    }
                }
            
                // Ground Speed
                if (changeGroundSpeedCheckbox && changeGroundSpeedCheckbox.selected)
                {
                    result.push({ property: "groundSpeed", value: groundSpeedStepper.value });
                }

                // Light
                if (changeLightCheckbox && changeLightCheckbox.selected)
                {
                    result.push({ property: "hasLight", value: lightValueCheckbox.selected });
                    if (lightValueCheckbox.selected)
                    {
                        result.push({ property: "lightColor", value: lightColorStepper.value });
                        result.push({ property: "lightLevel", value: lightLevelStepper.value });
                    }
                }

                // Automap / MiniMap
                if (changeMinimapCheckbox && changeMinimapCheckbox.selected)
                {
                    result.push({ property: "miniMap", value: minimapValueCheckbox.selected });
                    if (minimapValueCheckbox.selected)
                    {
                        result.push({ property: "miniMapColor", value: minimapColorStepper.value });
                    }
                }

                // Offset
                if (changeOffsetCheckbox && changeOffsetCheckbox.selected)
                {
                    result.push({ property: "hasOffset", value: offsetValueCheckbox.selected });
                    if (offsetValueCheckbox.selected)
                    {
                        result.push({ property: "offsetX", value: offsetXStepper.value });
                        result.push({ property: "offsetY", value: offsetYStepper.value });
                    }
                }

                // Elevation
                if (changeElevationCheckbox && changeElevationCheckbox.selected)
                {
                    result.push({ property: "hasElevation", value: elevationValueCheckbox.selected });
                    if (elevationValueCheckbox.selected)
                    {
                        result.push({ property: "elevation", value: elevationStepper.value });
                    }
                }

                // Cloth
                if (changeClothCheckbox && changeClothCheckbox.selected)
                {
                    result.push({ property: "cloth", value: clothValueCheckbox.selected });
                    if (clothValueCheckbox.selected)
                    {
                        result.push({ property: "clothSlot", value: clothSlotDropDown.selectedIndex });
                    }
                }

                // Default Action
                if (changeDefaultActionCheckbox && changeDefaultActionCheckbox.selected)
                {
                    result.push({ property: "hasDefaultAction", value: defaultActionValueCheckbox.selected });
                    if (defaultActionValueCheckbox.selected)
                    {
                        result.push({ property: "defaultAction", value: defaultActionDropDown.selectedIndex });
                    }
                }

                // Lens Help
                if (changeLensHelpCheckbox && changeLensHelpCheckbox.selected)
                {
                    result.push({ property: "isLensHelp", value: lensHelpValueCheckbox.selected });
                    if (lensHelpValueCheckbox.selected)
                    {
                        result.push({ property: "lensHelp", value: lensHelpDropDown.selectedIndex + 1100 });
                    }
                }

                // Market
                if (changeMarketCheckbox && changeMarketCheckbox.selected)
                {
                    result.push({ property: "isMarketItem", value: marketValueCheckbox.selected });
                    if (marketValueCheckbox.selected)
                    {
                        result.push({ property: "marketName", value: marketNameInput.text });
                        result.push({ property: "marketCategory", value: marketCategoryDropDown.selectedIndex + 1 });
                        result.push({ property: "marketTradeAs", value: marketTradeAsStepper.value });
                        result.push({ property: "marketShowAs", value: marketShowAsStepper.value });
                        result.push({ property: "marketRestrictProfession", value: marketVocationStepper.value });
                        result.push({ property: "marketRestrictLevel", value: marketLevelStepper.value });
                    }
                }

                // Writable
                if (changeWritableCheckbox && changeWritableCheckbox.selected)
                {
                    result.push({ property: "writable", value: writableValueCheckbox.selected });
                    if (writableValueCheckbox.selected)
                    {
                        result.push({ property: "maxReadWriteChars", value: maxReadWriteCharsStepper.value });
                    }
                }

                // Writable Once
                if (changeWritableOnceCheckbox && changeWritableOnceCheckbox.selected)
                {
                    result.push({ property: "writableOnce", value: writableOnceValueCheckbox.selected });
                    if (writableOnceValueCheckbox.selected)
                    {
                        result.push({ property: "maxReadChars", value: maxReadCharsStepper.value });
                    }
                }

                // Add duration changes if applicable
                if (changeDurationCheckbox && changeDurationCheckbox.selected)
                {
                    result.push({
                                property: "_bulkDuration",
                                minDuration: minDurationStepper.value,
                                maxDuration: maxDurationStepper.value,
                                frameGroupTarget: (frameGroupSelector && _category == ThingCategory.OUTFIT) ? frameGroupSelector.selectedItem.value : -1
                            });
                }
            
                // Add animation mode changes if applicable
                if (changeAnimationModeCheckbox && changeAnimationModeCheckbox.selected)
                {
                    result.push({
                                property: "_bulkAnimationMode",
                                animationMode: animationModeDropDown.selectedIndex
                            });
                }
            
                // Add frame strategy changes if applicable
                if (changeFrameStrategyCheckbox && changeFrameStrategyCheckbox.selected)
                {
                    result.push({
                                property: "_bulkFrameStrategy",
                                frameStrategy: frameStrategyDropDown.selectedIndex
                            });
                }
            
                // Add attribute changes if applicable
                // First: add clear flag if checkbox is checked AND we are on the Attributes tab (must come before _bulkAttributes)
                if (clearAttributesCheckbox && clearAttributesCheckbox.selected && _category == ThingCategory.ITEM && _currentTabIndex == 1)
                {
                    var preserve:Boolean = (preserveNamePluralCheckbox && preserveNamePluralCheckbox.selected);
                    result.push({
                                property: "_bulkClearAttributes",
                                value: preserve
                            });
                }
            
                // Then: add attributes to set (merge or replace depending on clear flag)
                if (_attributesEditor)
                {
                    var collectedAttrs:Dictionary = _attributesEditor.collectedAttributes;
                    var plainAttrs:Object = {};
                    var hasAttrs:Boolean = false;
                    for (var key:String in collectedAttrs)
                    {
                        plainAttrs[key] = collectedAttrs[key];
                        hasAttrs = true;
                    }
                    if (hasAttrs)
                    {
                        result.push({
                                    property: "_bulkAttributes",
                                    value: plainAttrs
                                });
                    }
                }
            
                return result;
            }
            
            // --------------------------------------------------------------------------
            // METHODS
            // --------------------------------------------------------------------------
            
            private function getAllPropertyRows():Vector.<BulkPropertyRow>
            {
                var list:Vector.<BulkPropertyRow> = new Vector.<BulkPropertyRow>();
                if (propertiesContainer)
                    collectRows(propertiesContainer, list);
                return list;
            }
            
            private function collectRows(container:IVisualElementContainer, list:Vector.<BulkPropertyRow>):void
            {
                for (var i:int = 0; i < container.numElements; i++)
                {
                    var element:Object = container.getElementAt(i);
                    if (element is BulkPropertyRow)
                    {
                        list.push(element as BulkPropertyRow);
                    }
                    else if (element is IVisualElementContainer)
                    {
                        collectRows(element as IVisualElementContainer, list);
                    }
                }
            }
            
            private function onPropertyChange(event:Event):void
            {
                applyButton.enabled = (changedProperties.length > 0);
            }
            
            private function updateVersionVisibility():void
            {
                if (!clientInfo) return;

                var v:uint = clientInfo.clientVersion;

                if (_category == ThingCategory.ITEM)
                {
                    // Flags - version-dependent BulkPropertyRows
                    setRowVisible(hangableRow, v >= 755);
                    setRowVisible(isHorizontalRow, v >= 755);
                    setRowVisible(isVerticalRow, v >= 755);
                    setRowVisible(dontHideRow, v >= 780);
                    setRowVisible(ignoreLookRow, v >= 780);
                    setRowVisible(hasChargesRow, v >= 780 && v <= 854);
                    setRowVisible(floorChangeRow, v >= 710 && v <= 854);
                    setRowVisible(isTranslucentRow, v >= 860);
                    setRowVisible(noMoveAnimationRow, v >= 1010);
                    setRowVisible(usableRow, v >= 1021);

                    var wrapVisible:Boolean = (v >= 710 && v <= 792) || (v >= 1092);
                    setRowVisible(wrappableRow, wrapVisible);
                    setRowVisible(unwrappableRow, wrapVisible);

                    // GroupBoxes
                    setRowVisible(clothGroupBox, v >= 900);
                    setRowVisible(marketGroupBox, v >= 940);
                    setRowVisible(actionGroupBox, v >= 1021);

                    // Offset stepper ranges
                    if (v >= 755)
                    {
                        offsetXStepper.minimum = -256;
                        offsetXStepper.maximum = 256;
                        offsetYStepper.minimum = -256;
                        offsetYStepper.maximum = 256;
                    }
                    else
                    {
                        offsetXStepper.minimum = 8;
                        offsetXStepper.maximum = 8;
                        offsetYStepper.minimum = 8;
                        offsetYStepper.maximum = 8;
                    }
                }
                else if (_category == ThingCategory.EFFECT)
                {
                    var teVisible:Boolean = (v >= 710 && v <= 792) || (v >= 1092);
                    setRowVisible(topEffectEffectRow, teVisible);
                }
            }

            private function setRowVisible(component:Object, visible:Boolean):void
            {
                if (component)
                {
                    component.visible = visible;
                    component.includeInLayout = visible;
                }
            }

            // --------------------------------------
            // Event Handlers
            // --------------------------------------
            
            protected function creationCompleteHandler(event:FlexEvent):void
            {
                if (_selectedIds)
                {
                    selectedCountLabel.text = resourceManager.getString("strings", "itemsSelected", [_selectedIds.length]);
                    if (selectedIdsText)
                        selectedIdsText.text = "IDs: " + _selectedIds.join(", ");
                }

                if (currentState != _category && _category)
                    currentState = _category;

                updateVersionVisibility();
            }
            
            protected function applyButtonClickHandler(event:MouseEvent):void
            {
                _detail = DialogDetail.OK;
                close();
            }
            
            protected function cancelButtonClickHandler(event:MouseEvent):void
            {
                _detail = DialogDetail.CANCEL;
                close();
            }
            
            protected function closingHandler(event:Event):void
            {
                if (_detail != DialogDetail.OK)
                    _detail = DialogDetail.CANCEL;
            }

            protected function onAttributesEditorReady(event:FlexEvent):void
            {
                _attributesEditor = attributesEditorComponent;
                _attributesEditor.addEventListener(Event.CHANGE, onPropertyChange);
            }
            
            protected function onTabChange(event:Event):void
            {
                if (tabNavigator)
                    _currentTabIndex = tabNavigator.selectedIndex;
            
                if (!_attributesTabInitialized && tabNavigator && tabNavigator.selectedIndex == 1)
                {
                    _attributesTabInitialized = true;
                    if (attributesTabContent)
                        attributesTabContent.createDeferredContent();
                }
            }
            
            private function frameGroupLabelFunction(item:Object):String
            {
                return item ? item.label : "";
            }
        ]]>
    </fx:Script>

    <s:states>
        <s:State name="item"/>
        <s:State name="outfit"/>
        <s:State name="effect"/>
        <s:State name="missile"/>
    </s:states>

    <s:Group width="100%" height="100%">
        <s:VGroup width="100%" height="100%" paddingLeft="10" paddingRight="10" paddingTop="10" paddingBottom="10" gap="10">

            <!-- Header -->
            <s:VGroup width="100%" gap="5">
                <s:Label id="selectedCountLabel"
                    text="@Resource(key='itemsSelected', bundle='strings')"
                    fontSize="12" fontWeight="bold"/>
                <s:Label text="@Resource(key='bulkEditDescription', bundle='strings')"
                    fontSize="11" color="0x999999"/>
                <s:Scroller maxHeight="60" width="100%">
                    <s:RichEditableText id="selectedIdsText"
                        editable="false" selectable="true"
                        width="100%"
                        fontSize="10" color="0xAAAAAA"
                        text=""/>
                </s:Scroller>
            </s:VGroup>

            <nail:ShadowLine width="100%"/>

            <!-- Tab Navigator for Properties and Attributes -->
            <nail:TabNavigator id="tabNavigator" width="100%" height="100%" change="onTabChange(event)">
                <!-- Properties Tab -->
                <s:NavigatorContent label="@Resource(key='properties', bundle='strings')" width="100%" height="100%">
                    <s:Scroller width="100%" height="100%">
                        <s:VGroup id="propertiesContainer"
                            width="100%"
                            gap="10"
                            paddingLeft="10" paddingRight="10" paddingTop="10">

                            <!-- 1. isGround group (ITEM only) -->
                            <nail:GroupBox label="@Resource(key='isGround', bundle='strings')"
                                width="100%" includeIn="item">
                                <nail:layout><s:VerticalLayout padding="10" gap="5"/></nail:layout>
                                <otlib:BulkPropertyRow propertyName="isGround" labelText="@Resource(key='isGround', bundle='strings')" change="onPropertyChange(event)"/>
                                <s:HGroup width="100%" verticalAlign="middle" horizontalAlign="right" gap="10" paddingRight="30">
                                    <s:CheckBox id="changeGroundSpeedCheckbox" label="Change" toolTip="@Resource(key='change', bundle='strings')" change="onPropertyChange(event)"/>
                                    <s:Label text="{resourceManager.getString('strings', 'groundSpeed') + ':'}" minWidth="60" textAlign="right"/>
                                    <s:NumericStepper id="groundSpeedStepper" width="80" minimum="0" maximum="1000" value="0" enabled="{changeGroundSpeedCheckbox.selected}" change="onPropertyChange(event)"/>
                                </s:HGroup>
                            </nail:GroupBox>

                            <!-- 2. hasLight group (ITEM only) -->
                            <nail:GroupBox label="@Resource(key='hasLight', bundle='strings')"
                                width="100%" includeIn="item">
                                <nail:layout><s:VerticalLayout padding="10" gap="5"/></nail:layout>
                                <s:HGroup width="100%" verticalAlign="middle" gap="10">
                                    <s:CheckBox id="changeLightCheckbox" label="Change" toolTip="@Resource(key='change', bundle='strings')" change="onPropertyChange(event)"/>
                                    <s:CheckBox id="lightValueCheckbox" label="@Resource(key='hasLight', bundle='strings')" enabled="{changeLightCheckbox.selected}" change="onPropertyChange(event)"/>
                                </s:HGroup>
                                <s:HGroup width="100%" verticalAlign="middle" horizontalAlign="right" gap="10" paddingRight="30">
                                    <s:Label text="{resourceManager.getString('strings', 'lightColor') + ':'}" minWidth="60" textAlign="right"/>
                                    <s:NumericStepper id="lightColorStepper" width="80" minimum="0" maximum="215" value="0"
                                        enabled="{changeLightCheckbox.selected &amp;&amp; lightValueCheckbox.selected}" change="onPropertyChange(event)"/>
                                    <otlib:EightBitColorPicker id="bulkLightColorPicker" color="{lightColorStepper.value}"
                                        enabled="{changeLightCheckbox.selected &amp;&amp; lightValueCheckbox.selected}"
                                        change="{lightColorStepper.value = bulkLightColorPicker.color; onPropertyChange(event);}"/>
                                </s:HGroup>
                                <s:HGroup width="100%" verticalAlign="middle" horizontalAlign="right" gap="10" paddingRight="30">
                                    <s:Label text="{resourceManager.getString('strings', 'lightIntensity') + ':'}" minWidth="60" textAlign="right"/>
                                    <s:NumericStepper id="lightLevelStepper" width="80" minimum="0" maximum="255" value="0"
                                        enabled="{changeLightCheckbox.selected &amp;&amp; lightValueCheckbox.selected}" change="onPropertyChange(event)"/>
                                    <s:Spacer width="30"/>
                                </s:HGroup>
                            </nail:GroupBox>

                            <!-- 3. automap group (ITEM only) -->
                            <nail:GroupBox label="@Resource(key='automap', bundle='strings')"
                                width="100%" includeIn="item">
                                <nail:layout><s:VerticalLayout padding="10" gap="5"/></nail:layout>
                                <s:HGroup width="100%" verticalAlign="middle" gap="10">
                                    <s:CheckBox id="changeMinimapCheckbox" label="Change" toolTip="@Resource(key='change', bundle='strings')" change="onPropertyChange(event)"/>
                                    <s:CheckBox id="minimapValueCheckbox" label="@Resource(key='automap', bundle='strings')" enabled="{changeMinimapCheckbox.selected}" change="onPropertyChange(event)"/>
                                </s:HGroup>
                                <s:HGroup width="100%" verticalAlign="middle" horizontalAlign="right" gap="10" paddingRight="30">
                                    <s:Label text="{resourceManager.getString('strings', 'automapColor') + ':'}" minWidth="60" textAlign="right"/>
                                    <s:NumericStepper id="minimapColorStepper" width="80" minimum="0" maximum="215" value="0"
                                        enabled="{changeMinimapCheckbox.selected &amp;&amp; minimapValueCheckbox.selected}" change="onPropertyChange(event)"/>
                                    <otlib:EightBitColorPicker id="bulkMinimapColorPicker" color="{minimapColorStepper.value}"
                                        enabled="{changeMinimapCheckbox.selected &amp;&amp; minimapValueCheckbox.selected}"
                                        change="{minimapColorStepper.value = bulkMinimapColorPicker.color; onPropertyChange(event);}"/>
                                </s:HGroup>
                            </nail:GroupBox>

                            <!-- 4. hasOffset group (ITEM only) -->
                            <nail:GroupBox label="@Resource(key='hasOffset', bundle='strings')"
                                width="100%" includeIn="item">
                                <nail:layout><s:VerticalLayout padding="10" gap="5"/></nail:layout>
                                <s:HGroup width="100%" verticalAlign="middle" gap="10">
                                    <s:CheckBox id="changeOffsetCheckbox" label="Change" toolTip="@Resource(key='change', bundle='strings')" change="onPropertyChange(event)"/>
                                    <s:CheckBox id="offsetValueCheckbox" label="@Resource(key='hasOffset', bundle='strings')" enabled="{changeOffsetCheckbox.selected}" change="onPropertyChange(event)"/>
                                </s:HGroup>
                                <s:HGroup width="100%" verticalAlign="middle" horizontalAlign="right" gap="10" paddingRight="30">
                                    <s:Label text="{resourceManager.getString('strings', 'offsetX') + ':'}" minWidth="60" textAlign="right"/>
                                    <s:NumericStepper id="offsetXStepper" width="80" minimum="-128" maximum="127" value="0"
                                        enabled="{changeOffsetCheckbox.selected &amp;&amp; offsetValueCheckbox.selected}" change="onPropertyChange(event)"/>
                                    <s:Spacer width="30"/>
                                </s:HGroup>
                                <s:HGroup width="100%" verticalAlign="middle" horizontalAlign="right" gap="10" paddingRight="30">
                                    <s:Label text="{resourceManager.getString('strings', 'offsetY') + ':'}" minWidth="60" textAlign="right"/>
                                    <s:NumericStepper id="offsetYStepper" width="80" minimum="-128" maximum="127" value="0"
                                        enabled="{changeOffsetCheckbox.selected &amp;&amp; offsetValueCheckbox.selected}" change="onPropertyChange(event)"/>
                                    <s:Spacer width="30"/>
                                </s:HGroup>
                            </nail:GroupBox>

                            <!-- 5. hasElevation group (ITEM only) -->
                            <nail:GroupBox label="@Resource(key='hasElevation', bundle='strings')"
                                width="100%" includeIn="item">
                                <nail:layout><s:VerticalLayout padding="10" gap="5"/></nail:layout>
                                <s:HGroup width="100%" verticalAlign="middle" gap="10">
                                    <s:CheckBox id="changeElevationCheckbox" label="Change" toolTip="@Resource(key='change', bundle='strings')" change="onPropertyChange(event)"/>
                                    <s:CheckBox id="elevationValueCheckbox" label="@Resource(key='hasElevation', bundle='strings')" enabled="{changeElevationCheckbox.selected}" change="onPropertyChange(event)"/>
                                </s:HGroup>
                                <s:HGroup width="100%" verticalAlign="middle" horizontalAlign="right" gap="10" paddingRight="30">
                                    <s:Label text="{resourceManager.getString('strings', 'elevation') + ':'}" minWidth="60" textAlign="right"/>
                                    <s:NumericStepper id="elevationStepper" width="80" minimum="0" maximum="32" value="0"
                                        enabled="{changeElevationCheckbox.selected &amp;&amp; elevationValueCheckbox.selected}" change="onPropertyChange(event)"/>
                                    <s:Spacer width="30"/>
                                </s:HGroup>
                            </nail:GroupBox>

                            <!-- 6. cloth group (ITEM only) -->
                            <nail:GroupBox id="clothGroupBox" label="@Resource(key='cloth', bundle='strings')"
                                width="100%" includeIn="item">
                                <nail:layout><s:VerticalLayout padding="10" gap="5"/></nail:layout>
                                <s:HGroup width="100%" verticalAlign="middle" gap="10">
                                    <s:CheckBox id="changeClothCheckbox" label="Change" toolTip="@Resource(key='change', bundle='strings')" change="onPropertyChange(event)"/>
                                    <s:CheckBox id="clothValueCheckbox" label="@Resource(key='cloth', bundle='strings')" enabled="{changeClothCheckbox.selected}" change="onPropertyChange(event)"/>
                                </s:HGroup>
                                <s:HGroup width="100%" verticalAlign="middle" horizontalAlign="right" gap="10" paddingRight="30">
                                    <s:Label text="{resourceManager.getString('strings', 'clothSlot') + ':'}" minWidth="60" textAlign="right"/>
                                    <s:DropDownList id="clothSlotDropDown" width="100%" height="20" fontSize="11" requireSelection="true" selectedIndex="0"
                                        enabled="{changeClothCheckbox.selected &amp;&amp; clothValueCheckbox.selected}">
                                        <s:dataProvider>
                                            <s:ArrayList>
                                                <fx:String>{resourceManager.getString('strings', 'slot.twoHandWeapon')}</fx:String>
                                                <fx:String>{resourceManager.getString('strings', 'slot.helmet')}</fx:String>
                                                <fx:String>{resourceManager.getString('strings', 'slot.amulet')}</fx:String>
                                                <fx:String>{resourceManager.getString('strings', 'slot.backpack')}</fx:String>
                                                <fx:String>{resourceManager.getString('strings', 'slot.armor')}</fx:String>
                                                <fx:String>{resourceManager.getString('strings', 'slot.shield')}</fx:String>
                                                <fx:String>{resourceManager.getString('strings', 'slot.oneHandWeapon')}</fx:String>
                                                <fx:String>{resourceManager.getString('strings', 'slot.legs')}</fx:String>
                                                <fx:String>{resourceManager.getString('strings', 'slot.boots')}</fx:String>
                                                <fx:String>{resourceManager.getString('strings', 'slot.ring')}</fx:String>
                                                <fx:String>{resourceManager.getString('strings', 'slot.arrow')}</fx:String>
                                            </s:ArrayList>
                                        </s:dataProvider>
                                    </s:DropDownList>
                                </s:HGroup>
                            </nail:GroupBox>

                            <!-- 7. market group (ITEM only) -->
                            <nail:GroupBox id="marketGroupBox" label="@Resource(key='market', bundle='strings')"
                                width="100%" includeIn="item">
                                <nail:layout><s:VerticalLayout paddingLeft="10" paddingRight="45" paddingTop="10" paddingBottom="10" gap="5"/></nail:layout>
