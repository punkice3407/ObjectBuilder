            private var _filmRollBitmaps:Vector.<BitmapData> = new Vector.<BitmapData>();
            private var _suppressDrawCropSize:Boolean = false;  // guards drawCropSize() during batch button adds
            private var _multiSelectedFrames:Dictionary = new Dictionary();
            private var _rect:Rectangle;
            private var _point:Point;
