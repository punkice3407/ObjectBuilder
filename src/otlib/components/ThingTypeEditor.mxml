                }

                bitmapView.source = _viewBitmap;
                buttonsContainer.width = _viewBitmap.width;
                buttonsContainer.height = _viewBitmap.height;
                spriteViewContainer.scaleX = _zoom;
                spriteViewContainer.scaleY = _zoom;
                drawCropSize();
            }

            private function updateFilmRollView():void
            {
                removeButtons();
                _rect.x = 0; _rect.y = 0;
                _rect.width = SpriteExtent.DEFAULT_SIZE; _rect.height = SpriteExtent.DEFAULT_SIZE;
                if (!_thingData || !_frameGroup || _frameGroup.frames <= 1) return;

                var size:uint = SpriteExtent.DEFAULT_SIZE;
                var fgWidth:uint = _frameGroup.width;
                var fgHeight:uint = _frameGroup.height;
                var patX:uint = _frameGroup.patternX;
                var patY:uint = _frameGroup.patternY;
                var frameW:uint = Math.max(size, (patX * fgWidth) * size);
                var frameH:uint = Math.max(size, (patY * fgHeight) * size);
                var frames:uint = _frameGroup.frames;
                var spacing:uint = 4;
                var pad:uint = 4;
                var groupType:uint = frameGroupSlider.value;
                var l:uint = layerSlider.value;
                var z:uint = mountSlider.value;
                var currentFrame:uint = animationSlider.value;

                var totalW:uint = pad + frames * frameW + (frames - 1) * spacing + pad;

                var availW:uint = appearanceGroupBox.width > 40 ? appearanceGroupBox.width - 40 : 300;
                var scrollerW:uint = Math.min(totalW + 14, availW);

                var scroller:Scroller = new Scroller();
                scroller.width = scrollerW;
                scroller.height = frameH + 14 + pad * 2 + 14;

                var container:Group = new Group();

                for (var f:uint = 0; f < frames; f++)
                {
                    var xPos:int = pad + f * (frameW + spacing);

                    // Frame label
                    var lbl:Label = new Label();
                    lbl.text = String(f + 1);
                    lbl.setStyle("color", 0x999999);
                    lbl.setStyle("fontSize", 8);
                    lbl.x = xPos + frameW / 2 - 4;
                    lbl.y = pad;
                    container.addElement(lbl);

                    // Frame container
                    var frameGrp:Group = new Group();
                    frameGrp.x = xPos;
                    frameGrp.y = 12 + pad;
                    frameGrp.name = "filmRollFrame_" + f;
                    frameGrp.addEventListener(MouseEvent.CLICK, filmRollFrameClickHandler);
                    container.addElement(frameGrp);

                    // Gray background
                    var bgRect:Rect = new Rect();
                    bgRect.width = frameW;
                    bgRect.height = frameH;
                    bgRect.fill = new SolidColor(0x636363);
                    frameGrp.addElement(bgRect);

                    // Compose frame bitmap
                    var frameBmp:BitmapData = new BitmapData(frameW, frameH, true, 0x00FF00FF);
                    _filmRollBitmaps.push(frameBmp);
                    var pixelsWidth:int = fgWidth * size;
                    var pixelsHeight:int = fgHeight * size;

                    for (var y:uint = 0; y < patY; y++)
                    {
                        for (var x:uint = 0; x < patX; x++)
                        {
                            for (var w:uint = 0; w < fgWidth; w++)
                            {
                                for (var h:uint = 0; h < fgHeight; h++)
                                {
                                    var idx:int = _frameGroup.getSpriteIndex(w, h, l, x, y, z, f);
                                    var bmp:BitmapData = _thingBinding.getSpriteBitmap(groupType, idx);
                                    if (bmp)
                                    {
                                        var px:int = ((fgWidth - w - 1) * size) + x * pixelsWidth;
                                        var py:int = ((fgHeight - h - 1) * size) + y * pixelsHeight;
                                        frameBmp.copyPixels(bmp, _rect, new Point(px, py));
                                        bmp.dispose();
                                    }
                                }
                            }
                        }
                    }

                    // Frame image
                    var img:Image = new Image();
                    img.source = frameBmp;
                    img.mouseEnabled = false;
                    frameGrp.addElement(img);

                    // Sprite buttons (interactive — inside frameGrp so drag-drop works)
                    for (y = 0; y < patY; y++)
                    {
                        for (x = 0; x < patX; x++)
                        {
                            for (w = 0; w < fgWidth; w++)
                            {
                                for (h = 0; h < fgHeight; h++)
                                {
                                    idx = _frameGroup.getSpriteIndex(w, h, l, x, y, z, f);
                                    var sid:uint = (idx < _frameGroup.spriteIndex.length) ? _frameGroup.spriteIndex[idx] : 0;
                                    px = ((fgWidth - w - 1) * size) + x * pixelsWidth;
                                    py = ((fgHeight - h - 1) * size) + y * pixelsHeight;
                                    var btn:Button = getSpriteButtonFromPool();
                                    btn.alpha = showGridCheckBox.selected ? 1 : 0;
                                    btn.label = idx.toString();
                                    btn.toolTip = sid.toString();
                                    btn.move(px, py);
                                    frameGrp.addElement(btn);
                                }
                            }
                        }
                    }

                    // Pixel grid overlay (edit pixels mode only)
                    if (_editPixelsMode)
                        frameGrp.addElement(createPixelGridOverlay(frameW, frameH));

                    // Selection border
                    var isCurrent:Boolean = (f == currentFrame);
                    var isMulti:Boolean = isFrameMultiSelected(frameGrp.name);
                    if (isCurrent || isMulti)
                    {
                        var borderColor:uint;
                        if (isCurrent)
                            borderColor = _editPixelsMode ? 0x6CACEC : 0x00FF00;
                        else
                            borderColor = 0xFFAA00;
                        var selRect:Rect = new Rect();
                        selRect.x = -1;
                        selRect.y = -1;
                        selRect.width = frameW + 2;
                        selRect.height = frameH + 2;
                        selRect.stroke = new SolidColorStroke(borderColor, 1);
                        frameGrp.addElement(selRect);
                    }
                }

                scroller.viewport = container;

                bitmapView.visible = false;
                buttonsContainer.addElement(scroller);
                buttonsContainer.width = scrollerW;
                buttonsContainer.height = frameH + 14 + pad * 2 + 14;

                spriteViewContainer.scaleX = _zoom;
                spriteViewContainer.scaleY = _zoom;
            }

            private function updateMultiDirectionFilmRollView():void
            {
                removeButtons();
                _rect.x = 0; _rect.y = 0;
                _rect.width = SpriteExtent.DEFAULT_SIZE; _rect.height = SpriteExtent.DEFAULT_SIZE;
                if (!_thingData || !_frameGroup || _frameGroup.frames <= 1)
                {
                    updateViewWithDirection();
                    return;
                }

                var size:uint = SpriteExtent.DEFAULT_SIZE;
                var fgWidth:uint = _frameGroup.width;
                var fgHeight:uint = _frameGroup.height;
                var frameW:uint = fgWidth * size;
                var frameH:uint = fgHeight * size;
                var frames:uint = _frameGroup.frames;
                var spacing:uint = 4;
                var dirSpacing:uint = 5;
                var pad:uint = 4;
                var groupType:uint = frameGroupSlider.value;
                var l:uint = layerSlider.value;
                var z:uint = mountSlider.value;
                var currentFrame:uint = animationSlider.value;
                var isOutfit:Boolean = (_thingData.category == ThingCategory.OUTFIT);

                var addonY:uint = isOutfit ? addonsSlider.value : 0;
                var directions:Array = [
                    { label: "N", patX: isOutfit ? 0 : 1, patY: addonY },
                    { label: "E",  patX: isOutfit ? 1 : 2, patY: isOutfit ? addonY : 1 },
                    { label: "S", patX: isOutfit ? 2 : 1, patY: isOutfit ? addonY : 2 },
                    { label: "W",  patX: isOutfit ? 3 : 0, patY: isOutfit ? addonY : 1 }
                ];

                var labelW:uint = 15;
                var rowH:uint = frameH + 14;
                var totalW:uint = pad + labelW + frames * frameW + (frames - 1) * spacing + pad;
                var totalH:uint = pad + directions.length * rowH + (directions.length - 1) * dirSpacing + pad;

                var availW:uint = appearanceGroupBox.width > 40 ? appearanceGroupBox.width - 40 : 300;
                var scrollerW:uint = Math.min(totalW + 14, availW);

                var scroller:Scroller = new Scroller();
                scroller.width = scrollerW;
                scroller.height = totalH + 14;

                var container:Group = new Group();

                for (var d:uint = 0; d < directions.length; d++)
                {
                    var dir:Object = directions[d];
                    var yOff:int = pad + d * (rowH + dirSpacing);

                    // Direction label
                    var dirLabel:Label = new Label();
                    dirLabel.text = dir.label;
                    dirLabel.setStyle("color", 0x999999);
                    dirLabel.setStyle("fontSize", 8);
                    dirLabel.x = pad;
                    dirLabel.y = yOff + frameH / 2 + 8;
                    container.addElement(dirLabel);

                    for (var f:uint = 0; f < frames; f++)
                    {
                        var xPos:int = pad + labelW + f * (frameW + spacing);

                        // Frame number (only for first direction row)
                        if (d == 0)
                        {
                            var numLbl:Label = new Label();
                            numLbl.text = String(f + 1);
                            numLbl.setStyle("color", 0x999999);
                            numLbl.setStyle("fontSize", 8);
                            numLbl.x = xPos + frameW / 2 - 4;
                            numLbl.y = yOff;
                            container.addElement(numLbl);
                        }

                        // Compose frame
                        var frameBmp:BitmapData = new BitmapData(frameW, frameH, true, 0x00FF00FF);
                        for (var w:uint = 0; w < fgWidth; w++)
                        {
                            for (var h:uint = 0; h < fgHeight; h++)
                            {
                                var idx:int = _frameGroup.getSpriteIndex(w, h, l, dir.patX, dir.patY, z, f);
                                var bmp:BitmapData = _thingBinding.getSpriteBitmap(groupType, idx);
                                if (bmp)
                                {
                                    var px:int = (fgWidth - w - 1) * size;
                                    var py:int = (fgHeight - h - 1) * size;
                                    frameBmp.copyPixels(bmp, _rect, new Point(px, py));
                                    bmp.dispose();
                                }
                            }
                        }

                        _filmRollBitmaps.push(frameBmp);
                        var imgY:int = yOff + (d == 0 ? 12 : 2);

                        // Frame container with click handler
                        var mdFrameGrp:Group = new Group();
                        mdFrameGrp.x = xPos;
                        mdFrameGrp.y = imgY;
                        mdFrameGrp.name = "filmRollFrame_" + d + "_" + f;
                        mdFrameGrp.addEventListener(MouseEvent.CLICK, filmRollFrameClickHandler);
                        container.addElement(mdFrameGrp);

                        // Gray background
                        var mdBgRect:Rect = new Rect();
                        mdBgRect.width = frameW;
                        mdBgRect.height = frameH;
                        mdBgRect.fill = new SolidColor(0x636363);
                        mdFrameGrp.addElement(mdBgRect);

                        var img:Image = new Image();
                        img.source = frameBmp;
                        img.mouseEnabled = false;
                        mdFrameGrp.addElement(img);

                        // Sprite buttons inside frame container
                        for (w = 0; w < fgWidth; w++)
                        {
                            for (h = 0; h < fgHeight; h++)
                            {
                                idx = _frameGroup.getSpriteIndex(w, h, l, dir.patX, dir.patY, z, f);
                                var mdSid:uint = (idx < _frameGroup.spriteIndex.length) ? _frameGroup.spriteIndex[idx] : 0;
                                var mdPx:int = (fgWidth - w - 1) * size;
                                var mdPy:int = (fgHeight - h - 1) * size;
                                var mdBtn:Button = getSpriteButtonFromPool();
                                mdBtn.alpha = showGridCheckBox.selected ? 1 : 0;
                                mdBtn.label = idx.toString();
                                mdBtn.toolTip = mdSid.toString();
                                mdBtn.move(mdPx, mdPy);
                                mdFrameGrp.addElement(mdBtn);
                            }
                        }

                        // Pixel grid overlay (edit pixels mode only)
                        if (_editPixelsMode)
                            mdFrameGrp.addElement(createPixelGridOverlay(frameW, frameH));

                        // Selection border
                        var selPatY:uint = isOutfit ? (_patternY + addonY) : _patternY;
                        var mdIsCurrent:Boolean = (f == currentFrame && dir.patX == _patternX && dir.patY == selPatY);
                        var mdIsMulti:Boolean = isFrameMultiSelected(mdFrameGrp.name);
                        if (mdIsCurrent || mdIsMulti)
                        {
                            var mdBorderColor:uint;
                            if (mdIsCurrent)
                                mdBorderColor = _editPixelsMode ? 0x6CACEC : 0x00FF00;
                            else
                                mdBorderColor = 0xFFAA00;
                            var mdSelRect:Rect = new Rect();
                            mdSelRect.x = -1;
                            mdSelRect.y = -1;
                            mdSelRect.width = frameW + 2;
                            mdSelRect.height = frameH + 2;
                            mdSelRect.stroke = new SolidColorStroke(mdBorderColor, 1);
                            mdFrameGrp.addElement(mdSelRect);
                        }
                    }
                }

                scroller.viewport = container;

                bitmapView.visible = false;
                buttonsContainer.addElement(scroller);
                buttonsContainer.width = scrollerW;
                buttonsContainer.height = totalH + 14;

                spriteViewContainer.scaleX = _zoom;
                spriteViewContainer.scaleY = _zoom;
            }

            private function filmRollFrameClickHandler(event:MouseEvent):void
            {
                var target:Group = event.currentTarget as Group;
                if (!target || !target.name) return;

                var name:String = target.name;
                if (name.indexOf("filmRollFrame_") != 0) return;

                // Ctrl+Click: toggle multi-select without changing current frame
                if (event.ctrlKey && _editPixelsMode)
                {
                    // On first Ctrl+Click, add the currently active frame to multi-select
                    if (getMultiSelectedFrameCount() == 0)
                    {
                        var currentName:String = findCurrentFrameName(buttonsContainer);
                        if (currentName)
                            _multiSelectedFrames[currentName] = true;
                    }

                    if (_multiSelectedFrames[name])
                        delete _multiSelectedFrames[name];
                    else
                        _multiSelectedFrames[name] = true;
                    updateFilmRollSelection();
                    return;
                }

                // Normal click: clear multi-select, select single frame
                clearMultiSelection();

                var suffix:String = name.substr(14);
                var underscoreIdx:int = suffix.indexOf("_");
                if (underscoreIdx >= 0)
                {
                    var dirIndex:uint = uint(suffix.substr(0, underscoreIdx));
                    var frameIdx:uint = uint(suffix.substr(underscoreIdx + 1));

                    var directions:Array = getDirectionMappings();

                    if (dirIndex < directions.length)
                    {
                        _patternX = directions[dirIndex].patX;
                        _patternY = directions[dirIndex].patY;
                    }
                    animationSlider.value = frameIdx;
                }
                else
                {
                    animationSlider.value = uint(suffix);
                }

                updateFilmRollSelection();
            }

            private function updateFilmRollSelection():void
            {
                // Find all frame groups and update their selection border
                updateSelectionRecursive(buttonsContainer);
            }

            private function updateSelectionRecursive(container:IVisualElementContainer):void
            {
                for (var i:int = 0; i < container.numElements; i++)
                {
                    var el:Object = container.getElementAt(i);
                    if (el is Group)
                    {
                        var grp:Group = el as Group;
                        if (grp.name && grp.name.indexOf("filmRollFrame_") == 0)
                        {
                            // Check if this frame is selected
                            var isSelected:Boolean = false;
                            var frameName:String = grp.name.substr(14);
                            var uidx:int = frameName.indexOf("_");
                            if (uidx >= 0)
                            {
                                var dIdx:uint = uint(frameName.substr(0, uidx));
                                var fIdx:uint = uint(frameName.substr(uidx + 1));
                                var dirs:Array = getDirectionMappings();
                                isSelected = (fIdx == animationSlider.value && dIdx < dirs.length &&
                                    dirs[dIdx].patX == _patternX && dirs[dIdx].patY == _patternY);
                            }
                            else
                            {
                                isSelected = (uint(frameName) == animationSlider.value);
                            }

                            // Remove old selection rect (last element if it's a Rect with stroke)
                            var lastEl:Object = grp.numElements > 0 ? grp.getElementAt(grp.numElements - 1) : null;
                            if (lastEl is Rect && Rect(lastEl).stroke != null)
                                grp.removeElementAt(grp.numElements - 1);

                            // Add selection border
                            var isMultiSel:Boolean = isFrameMultiSelected(grp.name);
                            if (isSelected || isMultiSel)
                            {
                                var borderColor:uint;
                                if (isSelected)
                                    borderColor = _editPixelsMode ? 0x6CACEC : 0x00FF00;
                                else
                                    borderColor = 0xFFAA00; // Orange for multi-select
                                var bgEl:Object = grp.numElements > 0 ? grp.getElementAt(0) : null;
                                var fW:Number = (bgEl is Rect) ? Rect(bgEl).width : 32;
                                var fH:Number = (bgEl is Rect) ? Rect(bgEl).height : 32;
                                var selRect:Rect = new Rect();
                                selRect.x = -1;
                                selRect.y = -1;
                                selRect.width = fW + 2;
                                selRect.height = fH + 2;
                                selRect.stroke = new SolidColorStroke(borderColor, 1);
                                grp.addElement(selRect);
                            }
                        }
                        else
                        {
                            updateSelectionRecursive(grp);
                        }
                    }
                    else if (el is IVisualElementContainer)
                    {
                        updateSelectionRecursive(el as IVisualElementContainer);
                    }
                }
            }

            private function addButton(index:uint, id:uint, x:uint, y:uint):void
            {
                var button:Button = getSpriteButtonFromPool();
                button.alpha = showGridCheckBox.selected ? 1 : 0;
                button.label = index.toString();
                button.toolTip = id.toString();
                buttonsContainer.addElement(button);
                button.move(x, y);
            }
            
            private function getSpriteButtonFromPool():Button
            {
                if (_spriteButtonPool.length > 0)
                    return _spriteButtonPool.pop();
            
                var button:Button = new Button();
                button.width = SpriteExtent.DEFAULT_SIZE;
                button.height = SpriteExtent.DEFAULT_SIZE;
                button.setStyle("fontSize", 10);
                button.setStyle("skinClass", SpriteButtonSkin);
                button.doubleClickEnabled = true;
            
                // One-time setup
                button.contextMenu = _spriteContextMenu;
                button.addEventListener(DragEvent.DRAG_ENTER, buttonDragEnterHandler);
                button.addEventListener(DragEvent.DRAG_EXIT, buttonDragExitHandler);
                button.addEventListener(DragEvent.DRAG_DROP, buttonDragDropHandler);
                button.addEventListener(MouseEvent.DOUBLE_CLICK, buttonDoubleClickHandler);
                button.addEventListener(MouseEvent.RIGHT_MOUSE_DOWN, spriteButtonRightMouseDownHandler);
            
                return button;
            }
            
            private function drawCropSize():void
            {
                if (!_thingData || _suppressDrawCropSize)
                    return;

                if (_filmRollMode && _frameGroup && _frameGroup.frames > 1)
                {
                    buttonsContainer.graphics.clear();
                    return;
                }
            
                var size:uint = cropSizeNumericStepper.value;
                buttonsContainer.graphics.clear();
                if (showCropSizeCheckBox.selected &&
                        size > 0 &&
                        buttonsContainer.width > 0 &&
                        buttonsContainer.height > 0)
                {
            
                    var w:uint = Math.min(_frameGroup.width * SpriteExtent.DEFAULT_SIZE, size);
                    var h:uint = Math.min(_frameGroup.height * SpriteExtent.DEFAULT_SIZE, size);
                    var px:int = bitmapView.width - w;
                    var py:int = bitmapView.height - h;
                    buttonsContainer.graphics.lineStyle(1, 0x00FF00);
                    buttonsContainer.graphics.drawRect(px, py, w, h);
                }
                buttonsContainer.graphics.endFill();
            }
            
            private function poolButtonsFrom(container:IVisualElementContainer):void
            {
                for (var i:int = 0; i < container.numElements; i++)
                {
                    var el:Object = container.getElementAt(i);
                    if (el is Button)
                        _spriteButtonPool.push(el as Button);
                    else if (el is IVisualElementContainer)
                        poolButtonsFrom(el as IVisualElementContainer);
                }
            }

            private function removeButtons():void
            {
                // Move focus away from buttons before removing to prevent FocusManager crash
                if (focusManager)
                {
                    try { setFocus(); } catch (e:Error) {}
                }

                // Dispose film roll bitmaps
                for each (var bmpDispose:BitmapData in _filmRollBitmaps)
                {
                    if (bmpDispose) bmpDispose.dispose();
                }
                _filmRollBitmaps.length = 0;

                // Remove film roll frame click listeners to prevent memory leaks
                removeFrameClickListeners(buttonsContainer);

                poolButtonsFrom(buttonsContainer);
                buttonsContainer.removeAllElements();
                bitmapView.visible = true;
            }

            private function removeFrameClickListeners(container:IVisualElementContainer):void
            {
                for (var i:int = 0; i < container.numElements; i++)
                {
                    var el:Object = container.getElementAt(i);
                    if (el is Group)
                    {
                        var grp:Group = el as Group;
                        if (grp.name && grp.name.indexOf("filmRollFrame_") == 0)
                            grp.removeEventListener(MouseEvent.CLICK, filmRollFrameClickHandler);
                        removeFrameClickListeners(grp);
                    }
                    else if (el is IVisualElementContainer)
                    {
                        removeFrameClickListeners(el as IVisualElementContainer);
                    }
                }
            }

            private function changeButtonsVisible(visible:Boolean):void
            {
                setButtonsVisibleRecursive(buttonsContainer, visible);
            }

            /**
             * Creates a pixel grid overlay (4px cells, white, alpha 0.3) for a film roll frame.
             */
            private function createPixelGridOverlay(w:uint, h:uint):UIComponent
            {
                var overlay:UIComponent = new UIComponent();
                var cellSize:uint = 4;
                var cols:uint = w / cellSize;
                var rows:uint = h / cellSize;
                var g:Graphics = overlay.graphics;
                g.lineStyle(0.5, 0xFFFFFF, 0.3);
                for (var c:uint = 1; c < cols; c++)
                {
                    var cx:Number = c * cellSize;
                    g.moveTo(cx, 0);
                    g.lineTo(cx, h);
                }
                for (var r:uint = 1; r < rows; r++)
                {
                    var ry:Number = r * cellSize;
                    g.moveTo(0, ry);
                    g.lineTo(w, ry);
                }
                overlay.width = w;
                overlay.height = h;
                overlay.mouseEnabled = false;
                overlay.mouseChildren = false;
                return overlay;
            }

            private function setButtonsVisibleRecursive(container:IVisualElementContainer, visible:Boolean):void
            {
                for (var i:int = 0; i < container.numElements; i++)
                {
                    var el:Object = container.getElementAt(i);
                    if (el is Button)
                        Button(el).alpha = visible ? 1 : 0;
                    else if (el is IVisualElementContainer)
                        setButtonsVisibleRecursive(el as IVisualElementContainer, visible);
                }
            }
            
            /**
             * Lightweight bitmap-only refresh: recomposes _viewBitmap from current sprite data
             * without destroying/recreating buttons. Used after shiftPixels() where only
             * pixel content changed but sprite layout remains identical.
             */
            private function refreshViewBitmap():void
            {
                if (!_thingData || !_frameGroup || !_viewBitmap) return;

                // Defensive _rect initialization
                _rect.x = 0; _rect.y = 0;
                _rect.width = SpriteExtent.DEFAULT_SIZE; _rect.height = SpriteExtent.DEFAULT_SIZE;

                var isOutfitOrMissile:Boolean = (_thingData.category == ThingCategory.OUTFIT || _thingData.category == ThingCategory.MISSILE);

                _viewBitmap.fillRect(_viewBitmap.rect, 0x00FF00FF);

                var size:uint = SpriteExtent.DEFAULT_SIZE;
                var fgWidth:uint = _frameGroup.width;
                var fgHeight:uint = _frameGroup.height;
                var f:uint = animationSlider.value;
                var l:uint = layerSlider.value;
                var z:uint = mountSlider.value;

                if (isOutfitOrMissile)
                {
                    var x:uint = _patternX % _frameGroup.patternX;
                    var y:uint = (_patternY + addonsSlider.value) % _frameGroup.patternY;
                    for (var w:uint = 0; w < fgWidth; w++)
                    {
                        for (var h:uint = 0; h < fgHeight; h++)
                        {
                            var index:int = _frameGroup.getSpriteIndex(w, h, l, x, y, z, f);
                            copyPixels(_frameGroup.type, index, _viewBitmap, (fgWidth - w - 1) * size, (fgHeight - h - 1) * size);
                        }
                    }
                }
                else
                {
                    var patternX:uint = _frameGroup.patternX;
                    var patternY:uint = _frameGroup.patternY;
                    var pixelsWidth:int = fgWidth * size;
                    var pixelsHeight:int = fgHeight * size;
                    for (var py:uint = 0; py < patternY; py++)
                    {
                        for (var px:uint = 0; px < patternX; px++)
                        {
                            var fx:int = px * pixelsWidth;
                            var fy:int = py * pixelsHeight;
                            for (var w2:uint = 0; w2 < fgWidth; w2++)
                            {
                                for (var h2:uint = 0; h2 < fgHeight; h2++)
                                {
                                    var idx:int = _frameGroup.getSpriteIndex(w2, h2, l, px, py, z, f);
                                    copyPixels(frameGroupSlider.value, idx, _viewBitmap, ((fgWidth - w2 - 1) * size) + fx, ((fgHeight - h2 - 1) * size) + fy);
                                }
                            }
                        }
                    }
                }

                // Force re-render without layout thrashing — swap to temp bitmap then back
                _suppressDrawCropSize = true;
                bitmapView.source = null;
                bitmapView.source = _viewBitmap;
                _suppressDrawCropSize = false;

                // Update button tooltips (sprite IDs may have changed)
                for (var bi:int = 0; bi < buttonsContainer.numElements; bi++)
                {
                    var btn:Button = buttonsContainer.getElementAt(bi) as Button;
                    if (btn)
                    {
                        var btnIdx:int = int(btn.label);
                        var sid:uint = (btnIdx >= 0 && btnIdx < _frameGroup.spriteIndex.length) ? _frameGroup.spriteIndex[btnIdx] : 0;
                        btn.toolTip = sid.toString();
                    }
                }
            }

            /**
             * Lightweight film roll refresh: recomposes only the current frame's bitmap
             * without destroying/rebuilding the entire film roll structure.
             */
            private function refreshFilmRollFrame():void
            {
                if (!_thingData || !_frameGroup || _frameGroup.frames <= 1) return;

                var size:uint = SpriteExtent.DEFAULT_SIZE;
                var fgWidth:uint = _frameGroup.width;
                var fgHeight:uint = _frameGroup.height;
                var groupType:uint = frameGroupSlider.value;
                var l:uint = layerSlider.value;
                var z:uint = mountSlider.value;
                var f:uint = animationSlider.value;
                var isOutfitOrMissile:Boolean = (_thingData.category == ThingCategory.OUTFIT || _thingData.category == ThingCategory.MISSILE);

                _rect.x = 0; _rect.y = 0;
                _rect.width = size; _rect.height = size;

                // Find the frame Group for the current frame and recompose its bitmap
                findAndRefreshFrame(buttonsContainer, f, isOutfitOrMissile, groupType, l, z, size, fgWidth, fgHeight);
            }

            private function findAndRefreshFrame(container:IVisualElementContainer, targetFrame:uint,
                isOutfitOrMissile:Boolean, groupType:uint, l:uint, z:uint,
                size:uint, fgWidth:uint, fgHeight:uint):void
            {
                for (var i:int = 0; i < container.numElements; i++)
                {
                    var el:Object = container.getElementAt(i);
                    if (el is Group)
                    {
                        var grp:Group = el as Group;
                        if (grp.name && grp.name.indexOf("filmRollFrame_") == 0)
                        {
                            // Parse frame index from name
                            var suffix:String = grp.name.substr(14);
                            var frameIdx:uint;
                            var dirPatX:int = -1;
                            var dirPatY:int = -1;
                            var uidx:int = suffix.indexOf("_");
                            if (uidx >= 0)
                            {
                                // Multi-direction: "filmRollFrame_D_F"
                                var dIdx:uint = uint(suffix.substr(0, uidx));
                                frameIdx = uint(suffix.substr(uidx + 1));
                                var dirs:Array = getDirectionMappings();
                                if (dIdx < dirs.length)
                                {
                                    dirPatX = dirs[dIdx].patX;
                                    dirPatY = dirs[dIdx].patY;
                                }
                            }
                            else
                            {
                                frameIdx = uint(suffix);
                            }

                            // Only refresh the frame matching current shift target
                            var shouldRefresh:Boolean = (frameIdx == targetFrame);
                            if (isOutfitOrMissile && dirPatX >= 0)
                                shouldRefresh = shouldRefresh && (dirPatX == _patternX && dirPatY == _patternY);

                            if (shouldRefresh)
                            {
                                // Find the Image child and recompose its bitmap
                                for (var ci:int = 0; ci < grp.numElements; ci++)
                                {
                                    var child:Object = grp.getElementAt(ci);
                                    if (child is Image)
                                    {
                                        var frameImg:Image = child as Image;
                                        var frameBmp:BitmapData = frameImg.source as BitmapData;
                                        if (!frameBmp) break;

                                        frameBmp.fillRect(frameBmp.rect, 0x00FF00FF);

                                        if (dirPatX >= 0)
                                        {
                                            // Outfit/missile: single direction pattern + addon offset
                                            var addonPatY:int = dirPatY;
                                            var isOutfitRefresh:Boolean = (_thingData.category == ThingCategory.OUTFIT);
                                            if (isOutfitRefresh)
                                                addonPatY = dirPatY + addonsSlider.value;
                                            for (var w:uint = 0; w < fgWidth; w++)
                                            {
                                                for (var h:uint = 0; h < fgHeight; h++)
                                                {
                                                    var idx:int = _frameGroup.getSpriteIndex(w, h, l, dirPatX, addonPatY, z, frameIdx);
                                                    var bmp:BitmapData = _thingBinding.getSpriteBitmap(groupType, idx);
                                                    if (bmp)
                                                    {
                                                        frameBmp.copyPixels(bmp, _rect, new Point((fgWidth - w - 1) * size, (fgHeight - h - 1) * size));
                                                        bmp.dispose();
                                                    }
                                                }
                                            }
                                        }
                                        else
                                        {
                                            // Non-outfit: iterate ALL patterns (matches updateFilmRollView)
                                            var fgPatX:uint = _frameGroup.patternX;
                                            var fgPatY:uint = _frameGroup.patternY;
                                            var pixW:int = fgWidth * size;
                                            var pixH:int = fgHeight * size;
                                            for (var ry:uint = 0; ry < fgPatY; ry++)
                                            {
                                                for (var rx:uint = 0; rx < fgPatX; rx++)
                                                {
                                                    for (w = 0; w < fgWidth; w++)
                                                    {
                                                        for (h = 0; h < fgHeight; h++)
                                                        {
                                                            idx = _frameGroup.getSpriteIndex(w, h, l, rx, ry, z, frameIdx);
                                                            bmp = _thingBinding.getSpriteBitmap(groupType, idx);
                                                            if (bmp)
                                                            {
                                                                frameBmp.copyPixels(bmp, _rect, new Point(((fgWidth - w - 1) * size) + rx * pixW, ((fgHeight - h - 1) * size) + ry * pixH));
                                                                bmp.dispose();
                                                            }
                                                        }
                                                    }
                                                }
                                            }
                                        }

                                        frameImg.source = null;
                                        frameImg.source = frameBmp;
                                        break;
                                    }
                                }
                                // Update button tooltips in this frame
                                for (ci = 0; ci < grp.numElements; ci++)
                                {
                                    child = grp.getElementAt(ci);
                                    if (child is Button)
                                    {
                                        var btn:Button = child as Button;
                                        var bIdx:int = int(btn.label);
                                        var sid:uint = (bIdx >= 0 && bIdx < _frameGroup.spriteIndex.length) ? _frameGroup.spriteIndex[bIdx] : 0;
                                        btn.toolTip = sid.toString();
                                    }
                                }
                            }
                        }
                        else
                        {
                            findAndRefreshFrame(grp, targetFrame, isOutfitOrMissile, groupType, l, z, size, fgWidth, fgHeight);
                        }
                    }
                    else if (el is IVisualElementContainer)
                    {
                        findAndRefreshFrame(el as IVisualElementContainer, targetFrame, isOutfitOrMissile, groupType, l, z, size, fgWidth, fgHeight);
                    }
                }
            }

            private function copyPixels(groupType:uint, index:uint, bitmap:BitmapData, x:uint, y:uint):void
            {
                var bmp:BitmapData = _thingBinding.getSpriteBitmap(groupType, index);
                if (bmp)
                {
                    _point.x = x;
                    _point.y = y;
                    bitmap.copyPixels(bmp, _rect, _point);
                    bmp.dispose();
                }
            }
            
            private function selectDirectionButton(button:DirectionButton):void
            {
                if (!_thingData || !button)
                    return;
            
                var length:uint = directionGroup.numElements;
                for (var i:uint = 0; i < length; i++)
                {
                    var element:IVisualElement = directionGroup.getElementAt(i);
                    if (element is DirectionButton)
                    {
                        DirectionButton(element).selected = false;
                    }
                }
            
                var isOutfit:Boolean = (_thingData.category == ThingCategory.OUTFIT);
                button.selected = true;
            
                switch (button.direction)
                {
                    case Direction.NORTH:
                        _patternX = isOutfit ? 0 : 1;
                        _patternY = 0;
                        break;
                    case Direction.EAST:
                        _patternX = isOutfit ? 1 : 2;
                        _patternY = isOutfit ? 0 : 1;
                        break;
                    case Direction.SOUTH:
                        _patternX = isOutfit ? 2 : 1;
                        _patternY = isOutfit ? 0 : 2;
                        break;
                    case Direction.WEST:
                        _patternX = isOutfit ? 3 : 0;
                        _patternY = isOutfit ? 0 : 1;
                        break;
                    case Direction.NORTHWEST:
                        _patternX = 0;
                        _patternY = 0;
                        break;
                    case Direction.NORTHEAST:
                        _patternX = 2;
                        _patternY = 0;
                        break;
                    case Direction.SOUTHWEST:
                        _patternX = 0;
                        _patternY = 2;
                        break;
                    case Direction.SOUTHEAST:
                        _patternX = 2;
                        _patternY = 2;
                        break;
                    default:
                        _patternX = 0;
                        _patternY = 0;
                        break;
                }
            
                _direction = button.direction;
                _currentDirectionLabel = getDirectionLabel(_direction);
                bonesOffsetXNumericStepper.value = _thingBinding.bonesOffsetX[_direction];
                bonesOffsetYNumericStepper.value = _thingBinding.bonesOffsetY[_direction];
            
                updatePreview();
            }
            
            private function checkThingOrder():void
            {
                if (filesInfo.clientVersion > 750 && _thingBinding.isGroundBorder)
                    renderOrder.selectedIndex = 1;
                else if (_thingBinding.isOnBottom)
                    renderOrder.selectedIndex = 2;
                else if (_thingBinding.isOnTop)
                    renderOrder.selectedIndex = 3;
                else
                    renderOrder.selectedIndex = 0;
            }
            
            private function setPreviewMode(enabled:Boolean):void
            {
                var thingData:ThingData;
                var frameGroupType:uint = FrameGroupType.DEFAULT;
            
                _previewMode = enabled;
                if (_previewMode)
                {
                    thingData = _thingBinding.toThingData(_thingData.clientVersion);
                    frameGroupType = _frameGroup.type;
            
                    thingView.outfitData = new OutfitData(0, 0, 0, 0, addonsSlider.value);
                    _lastAnimationFrame = animationSlider.value;
                }
                else
                {
                    setAnimationSlide(_lastAnimationFrame);
                }
            
                if (_previewMode != playAnimationButton.selected)
                    playAnimationButton.selected = _previewMode;
            
                thingView.thingData = thingData;
                thingView.frameGroupType = frameGroupType;
            
                thingView.visible = _previewMode;
                if (_previewMode)
                {
                    thingView.play();
                    // Hide film roll during animation preview
                    buttonsContainer.removeAllElements();
                }

                var controlsEnabled:Boolean = !_previewMode;
                bitmapView.visible = controlsEnabled && !(_filmRollMode && _frameGroup && _frameGroup.frames > 1);
                animationSlider.mouseChildren = controlsEnabled;
                mountGroup.enabled = controlsEnabled;
                addonGroup.enabled = controlsEnabled;
                patternsTileGroup.enabled = controlsEnabled;
                minimumGroup.enabled = controlsEnabled;
                maximumGroup.enabled = controlsEnabled;
                layerGroup.enabled = controlsEnabled;
                animationTileGroup.enabled = controlsEnabled;
                frameGroup.enabled = controlsEnabled;

                // Restore film roll view after animation stops
                if (!_previewMode && _filmRollMode && _frameGroup && _frameGroup.frames > 1)
                    updatePreview();
            }
            
            private function setAnimationSlide(value:uint):void
            {
                animationSlider.value = value;
                animationCountLabel.text = (value + 1) + '/' + (animationSlider.maximum + 1);
            }
            
            private function propertyChanged(property:String, oldValue:Object, newValue:Object):void
            {
                _changed = true;
            
                var evt:ThingEditorEvent = new ThingEditorEvent(ThingEditorEvent.THING_PROPERTY_CHANGE, this.thingData);
                var label:String = BindableThingType.toLabel(property);
                evt.property = (label && label.length > 0) ? label : property;
                evt.oldValue = oldValue;
                evt.newValue = newValue;
                dispatchEvent(evt);
            }
            
            // --------------------------------------
            // Event Handlers
            // --------------------------------------
            
            protected function creationCompleteHandler(event:FlexEvent):void
            {
                _thingBinding = new BindableThingType();
                _thingBinding.addEventListener(PropertyChangeEvent.PROPERTY_CHANGE, thingPropertyChangeHandler);
                _point = new Point();
                _rect = new Rectangle(0, 0, SpriteExtent.DEFAULT_SIZE, SpriteExtent.DEFAULT_SIZE);

                // Initialize Context Menu
                initializeSpriteContextMenu();

                // Keyboard listener for pixel shifting
                addEventListener(KeyboardEvent.KEY_DOWN, editPixelsKeyHandler);
            }
            
            /**
             * Handler for AttributesEditor change events - updates ThingData.xmlAttributes.
             */
            protected function onAttributesEditorChange(event:Event):void
            {
                if (!_loading && _thingData && attributesEditor)
                {
                    // Dictionary extends Object, so direct assignment works
                    _thingData.xmlAttributes = attributesEditor.collectedAttributes;
                }
                _changed = true;
                if (_thingData)
                    dispatchEvent(new ThingEditorEvent(ThingEditorEvent.THING_PROPERTY_CHANGE, _thingData));
            }
            
            /**
             * Checks if the mouse wheel event target is a component that handles its own scrolling.
             */
            private function allowChildScroll(target:DisplayObject, stopContainer:DisplayObject):Boolean
            {
                while (target != null && target != stopContainer)
                {
                    if (target is spark.components.NumericStepper ||
                            target is spark.components.TextArea ||
                            target is spark.components.List ||
                            target is spark.components.DropDownList)
                    {
                        return true;
                    }
                    target = target.parent;
                }
                return false;
            }
            
            /**
             * Manual mouseWheel handler for Properties Scroller to bypass child component event consumption.
             * Allows NumericStepper and other interactive components to handle wheel events.
             */
            protected function onPropertiesMouseWheel(event:MouseEvent):void
            {
                if (allowChildScroll(event.target as DisplayObject, propertiesScroller))
                    return;
            
                if (propertiesScroller && propertiesScroller.viewport)
                {
                    event.preventDefault();
                    event.stopPropagation();
                    performManualScroll(event, propertiesScroller);
                }
            }
            
            protected function onTextureMouseWheel(event:MouseEvent):void
            {
                if (allowChildScroll(event.target as DisplayObject, textureScroller))
                    return;
            
                if (textureScroller && textureScroller.viewport)
                {
                    event.preventDefault();
                    event.stopPropagation();
                    performManualScroll(event, textureScroller);
                }
            }
            
            private function performManualScroll(event:MouseEvent, scroller:Scroller):void
            {
                var d:Number = event.delta;
                // Clamp delta to avoid massive jumps but allow some acceleration
                if (d > 3)
                    d = 3;
                if (d < -3)
                    d = -3;
            
                var step:Number = 10;
                var newY:Number = scroller.viewport.verticalScrollPosition - (d * step);
                newY = Math.max(0, Math.min(newY, scroller.viewport.contentHeight - scroller.viewport.height));
                scroller.viewport.verticalScrollPosition = newY;
            }
            
            protected function buttonDragEnterHandler(event:DragEvent):void
            {
                var button:Button = event.target as Button;
                if (!_previewMode && _thingBinding && button)
                {
                    DragManager.acceptDragDrop(button);
                    button.alpha = 1;
                }
            }
            
            protected function buttonDragExitHandler(event:DragEvent):void
            {
                var button:Button = event.target as Button;
                if (button && !showGridCheckBox.selected)
                    button.alpha = 0;
            }
            
            protected function buttonDragDropHandler(event:DragEvent):void
            {
                var button:Button = event.target as Button;
                if (!button || !_thingBinding)
                    return;
            
                if (!showGridCheckBox.selected)
                    button.alpha = 0;
            
                var source:DragSource = event.dragSource;
                var spriteData:SpriteData = source.dataForFormat(source.formats[0])[0] as SpriteData;
                if (!spriteData)
                    return;
            
                var index:int = int(button.label);
                var groupType:uint = frameGroupSlider.value;
                _thingBinding.setSprite(groupType, index, spriteData);
                button.toolTip = spriteData.id.toString();

                // Film Roll: local bitmap patch — find parent frame Group and update its Image
                if (_filmRollMode && _frameGroup && _frameGroup.frames > 1)
                {
                    _changed = true;
                    var parentGrp:Group = button.parent as Group;
                    if (parentGrp)
                    {
                        for (var fi:int = 0; fi < parentGrp.numElements; fi++)
                        {
                            var child:Object = parentGrp.getElementAt(fi);
                            if (child is Image)
                            {
                                var frameImg:Image = child as Image;
                                var frameBmp:BitmapData = frameImg.source as BitmapData;
                                if (frameBmp)
                                {
                                    var size:uint = SpriteExtent.DEFAULT_SIZE;
                                    var clearRect:Rectangle = new Rectangle(button.x, button.y, size, size);
                                    frameBmp.fillRect(clearRect, 0x00FF00FF);
                                    var spriteBmp:BitmapData = _thingBinding.getSpriteBitmap(groupType, index);
                                    if (spriteBmp)
                                    {
                                        _rect.x = 0; _rect.y = 0;
                                        _rect.width = size; _rect.height = size;
                                        frameBmp.copyPixels(spriteBmp, _rect, new Point(button.x, button.y));
                                        spriteBmp.dispose();
                                    }
                                    frameImg.source = null;
                                    frameImg.source = frameBmp;
                                }
                                break;
                            }
                        }
                    }
                    return;
                }

                // Optimized local bitmap update (reuses class-level _rect)
                if (_viewBitmap)
                {
                    // 1. Set rect to DESTINATION coordinates for clearing
                    _rect.x = button.x;
                    _rect.y = button.y;
                    _rect.width = SpriteExtent.DEFAULT_SIZE;
                    _rect.height = SpriteExtent.DEFAULT_SIZE;
                    _viewBitmap.fillRect(_rect, 0x00FF00FF);
            
                    // 2. Reset rect to SOURCE coordinates (0,0) for copyPixels
                    _rect.x = 0;
                    _rect.y = 0;
            
                    copyPixels(groupType, index, _viewBitmap, button.x, button.y);
                    bitmapView.source = null;
                    bitmapView.source = _viewBitmap;
                }
            }
            
            protected function buttonDoubleClickHandler(event:MouseEvent):void
            {
                var index:uint = uint(event.target.toolTip);
                dispatchEvent(new ThingEditorEvent(ThingEditorEvent.SPRITE_DOUBLE_CLICK, this.thingData, index));
            }
            
            protected function thingPropertyChangeHandler(event:PropertyChangeEvent):void
            {
                if (!_loading)
                {
                    _changed = true;
                    if (event.property != null)
                    {
                        var evt:ThingEditorEvent = new ThingEditorEvent(ThingEditorEvent.THING_PROPERTY_CHANGE, this.thingData);
                        evt.property = BindableThingType.toLabel(event.property as String);
                        evt.oldValue = event.oldValue;
                        evt.newValue = event.newValue;
                        dispatchEvent(evt);
                    }
                }
            }
            
            protected function checkFrameGroups(event:Event):void
            {
                if (_thingBinding.groups > 1)
                {
                    var group:FrameGroup = _thingBinding.getFrameGroup(FrameGroupType.WALKING);
                    if (!group)
                    {
                        group = new FrameGroup();
                        group.type = FrameGroupType.WALKING;
                        group.makeOutfitGroup(_settings.getDefaultDuration(ThingCategory.OUTFIT));
            
                        _thingBinding.setFrameGroup(FrameGroupType.WALKING, group);
                    }
                }
            }
            
            protected function textureUpdate(event:Event):void
            {
                _thingBinding.updateSpriteCount(_frameGroup);
                updatePreview();
            }
            
            protected function directionButtonClickHandler(event:MouseEvent):void
            {
                selectDirectionButton(event.target as DirectionButton);
            }
            
            protected function renderOrderChangeHandler(event:Event):void
            {
                _thingBinding.isGroundBorder = (renderOrder.selectedIndex == 1);
                _thingBinding.isOnBottom = (renderOrder.selectedIndex == 2);
                _thingBinding.isOnTop = (renderOrder.selectedIndex == 3);
                checkThingOrder();
            }
            
            protected function playAnimationButtonClickHandler(event:MouseEvent):void
            {
                setPreviewMode(playAnimationButton.selected);
            }
            
            protected function thingViewFrameChangeHandler(event:Event):void
            {
                if (_previewMode)
                    setAnimationSlide(thingView.frame);
            }
            
            protected function thingViewAnimationCompleteHandler(event:Event):void
            {
                setPreviewMode(false);
            }
            
            protected function groupsNumericStepperChangeHandler(event:Event):void
            {
                var oldValue:int = _thingBinding.groups;
                _thingBinding.groups = frameGroupsNumericStepper.value;
                propertyChanged("frameGroups", oldValue, _frameGroup.width);
            }
            
            protected function widthNumericStepperChangeHandler(event:Event):void
            {
                var oldValue:int = _frameGroup.width;
                _frameGroup.width = widthNumericStepper.value;
                propertyChanged("width", oldValue, _frameGroup.width);
            }
            
            protected function heightNumericStepperChangeHandler(event:Event):void
            {
                var oldValue:int = _frameGroup.height;
                _frameGroup.height = heightNumericStepper.value;
                propertyChanged("height", oldValue, _frameGroup.height);
            }
            
            protected function exactSizeNumericStepperChangeHandler(event:Event):void
            {
                var oldValue:int = _frameGroup.exactSize;
                _frameGroup.exactSize = cropSizeNumericStepper.value;
                propertyChanged("exactSize", oldValue, _frameGroup.exactSize);
            }
            
            protected function layersNumericStepperChangeHandler(event:Event):void
            {
                var oldValue:int = _frameGroup.layers;
                _frameGroup.layers = layersNumericStepper.value;
                propertyChanged("layers", oldValue, _frameGroup.layers);
            }
            
            protected function patternXNumericStepperChangeHandler(event:Event):void
            {
                var oldValue:int = _frameGroup.patternX;
                _frameGroup.patternX = patternXNumericStepper.value;
                propertyChanged("patternX", oldValue, _frameGroup.patternX);
            }
            
            protected function patternYNumericStepperChangeHandler(event:Event):void
            {
                var oldValue:int = _frameGroup.patternY;
                _frameGroup.patternY = patternYNumericStepper.value;
                propertyChanged("patternY", oldValue, _frameGroup.patternY);
            }
            
            protected function patternZNumericStepperChangeHandler(event:Event):void
            {
                var oldValue:int = _frameGroup.patternZ;
                _frameGroup.patternZ = patternZNumericStepper.value;
                propertyChanged("patternZ", oldValue, _frameGroup.patternZ);
            }
            
            protected function framesNumericStepperChangeHandler(event:Event):void
            {
                var oldValue:int = _frameGroup.frames;
                _frameGroup.frames = framesNumericStepper.value;
                propertyChanged("frames", oldValue, _frameGroup.frames);
            }
            
            protected function minimumNumericStepperChangeHandler(event:Event):void
            {
                if (minimumNumericStepper.value > maximumNumericStepper.value)
                    maximumNumericStepper.value = minimumNumericStepper.value;
            
                var oldDuration:FrameDuration = _frameGroup.frameDurations[animationSlider.value];
                var newDuration:FrameDuration = oldDuration.clone();
                newDuration.minimum = minimumNumericStepper.value;
                newDuration.maximum = maximumNumericStepper.value;
            
                if (!oldDuration.equals(newDuration))
                {
                    _frameGroup.frameDurations[animationSlider.value] = newDuration;
            
                    if (oldDuration.minimum != newDuration.minimum)
                        propertyChanged("minimumDuration", oldDuration.minimum, newDuration.minimum);
            
                    if (oldDuration.maximum != newDuration.maximum)
                        propertyChanged("maximumDuration", oldDuration.maximum, newDuration.maximum);
            
                    refreshFrameDurationsTime();
                }
            }
            
            protected function maximumNumericStepperChangeHandler(event:Event):void
            {
                if (maximumNumericStepper.value < minimumNumericStepper.value)
                    minimumNumericStepper.value = maximumNumericStepper.value;
            
                var oldDuration:FrameDuration = _frameGroup.frameDurations[animationSlider.value];
                var newDuration:FrameDuration = oldDuration.clone();
                newDuration.minimum = minimumNumericStepper.value;
                newDuration.maximum = maximumNumericStepper.value;
            
                if (!oldDuration.equals(newDuration))
                {
                    _frameGroup.frameDurations[animationSlider.value] = newDuration;
            
                    if (oldDuration.minimum != newDuration.minimum)
                        propertyChanged("minimumDuration", oldDuration.minimum, newDuration.minimum);
            
                    if (oldDuration.maximum != newDuration.maximum)
                        propertyChanged("maximumDuration", oldDuration.maximum, newDuration.maximum);
            
                    refreshFrameDurationsTime();
                }
            }
            
            protected function bonesOffsetXNumericStepperChangeHandler(event:Event):void
            {
                var oldValue:int = _thingBinding.bonesOffsetY[_direction];
                _thingBinding.bonesOffsetX[_direction] = bonesOffsetXNumericStepper.value;
            
                propertyChanged("bonesOffsetX", oldValue, bonesOffsetXNumericStepper.value);
            }
            
            protected function bonesOffsetYNumericStepperChangeHandler(event:Event):void
            {
                var oldValue:int = _thingBinding.bonesOffsetY[_direction];
                _thingBinding.bonesOffsetY[_direction] = bonesOffsetYNumericStepper.value;
            
                propertyChanged("bonesOffsetY", oldValue, bonesOffsetYNumericStepper.value);
            }
            
            protected function animationModeDropDownListChangeHandler(event:IndexChangeEvent):void
            {
                var oldValue:uint = _frameGroup.animationMode;
                _frameGroup.animationMode = animationModeDropDownList.selectedIndex;
                propertyChanged("animationMode", oldValue, _frameGroup.animationMode);
            }
            
            protected function frameStrategyDropDownListChangeHandler(event:IndexChangeEvent):void
            {
                var loop:Boolean = frameStrategyDropDownList.selectedIndex == 0;
            
                var oldValue:int = _frameGroup.loopCount;
                _frameGroup.loopCount = loop ? loopCountNumericStepper.value : -1;
                loopCountNumericStepper.enabled = loop;
                propertyChanged("loopCount", oldValue, _frameGroup.loopCount);
            }
            
            protected function loopCountNumericStepperChangeHandler(event:Event):void
            {
                var oldValue:int = _frameGroup.loopCount;
                _frameGroup.loopCount = loopCountNumericStepper.value;
                propertyChanged("loopCount", oldValue, _frameGroup.loopCount);
            }
            
            protected function startFrameNumericStepperChangeHandler(event:Event):void
            {
                var oldValue:int = _frameGroup.startFrame;
                _frameGroup.startFrame = startFrameNumericStepper.value;
                propertyChanged("startFrame", oldValue, _frameGroup.startFrame);
            }
            
            protected function setDefaultDurationsHandler(event:Event):void
            {
                var oldDuration:FrameDuration = _frameGroup.frameDurations[animationSlider.value];
                var newDuration:FrameDuration = oldDuration.clone();
            
                var duration:uint = _settings.getDefaultDuration(_thingData.category);
                newDuration.minimum = duration;
                newDuration.maximum = duration;
            
                if (!oldDuration.equals(newDuration))
                {
                    _frameGroup.frameDurations[animationSlider.value] = newDuration;
            
                    if (oldDuration.minimum != newDuration.minimum)
                    {
                        minimumNumericStepper.value = duration;
                        propertyChanged("minimumDuration", oldDuration.minimum, newDuration.minimum);
                    }
            
                    if (oldDuration.maximum != newDuration.maximum)
                    {
                        maximumNumericStepper.value = duration;
                        propertyChanged("maximumDuration", oldDuration.maximum, newDuration.maximum);
                    }
            
                    refreshFrameDurationsTime();
                }
            }
            
            protected function setForAllFramesHandler(event:Event):void
            {
                var currentDuration:FrameDuration = _frameGroup.frameDurations[animationSlider.value];
            
                for (var frame:uint = 0; frame < _frameGroup.frames; frame++)
                {
                    var oldDuration:FrameDuration = _frameGroup.frameDurations[frame];
                    if (!oldDuration.equals(currentDuration))
                    {
                        _frameGroup.frameDurations[frame] = currentDuration.clone();
                    }
                }
            }
            
            protected function refreshFrameDurationsTime():void
            {
                var minimum:uint = 0;
                var maximum:uint = 0;
                for (var frame:uint = 0; frame < _frameGroup.frames; frame++)
                {
                    minimum += _frameGroup.frameDurations[frame].minimum;
                    maximum += _frameGroup.frameDurations[frame].maximum;
                }
            
                if (minimum > 0)
                    minimumDurationLabel.text = resourceManager.getString('strings', 'minimumDuration') + ' (' + minimum.toString() + ' ms):';
                else
                    minimumDurationLabel.text = resourceManager.getString('strings', 'minimumDuration') + ':';
            
                if (maximum > 0)
                    maximumDurationLabel.text = resourceManager.getString('strings', 'maximumDuration') + ' (' + maximum.toString() + ' ms):';
                else
                    maximumDurationLabel.text = resourceManager.getString('strings', 'maximumDuration') + ':';
            }
            
            private function initializeSpriteContextMenu():void
            {
                var resource:IResourceManager = ResourceManager.getInstance();
                var clearSpriteMenu:ContextMenuItem = new ContextMenuItem("Clear Sprite");
                clearSpriteMenu.data = ThingEditorEvent.CLEAR_SPRITE;
                var copyFrameMenu:ContextMenuItem = new ContextMenuItem("Copy Frame", true);
                copyFrameMenu.data = ThingEditorEvent.COPY_FRAME;
                var pasteFrameMenu:ContextMenuItem = new ContextMenuItem("Paste Frame");
                pasteFrameMenu.data = ThingEditorEvent.PASTE_FRAME;
                var clearFrameMenu:ContextMenuItem = new ContextMenuItem("Clear Frame");
                clearFrameMenu.data = ThingEditorEvent.CLEAR_FRAME;
            
                var replaceFromPngMenu:ContextMenuItem = new ContextMenuItem("Replace from PNG", true);
                replaceFromPngMenu.data = ThingEditorEvent.REPLACE_FROM_PNG;

                _spriteContextMenu = new ContextMenu();
                _spriteContextMenu.customItems = [clearSpriteMenu, copyFrameMenu, pasteFrameMenu, clearFrameMenu, replaceFromPngMenu];
                _spriteContextMenu.addEventListener(Event.DISPLAYING, spriteContextMenuDisplayingHandler);
                _spriteContextMenu.addEventListener(Event.SELECT, spriteContextMenuSelectHandler);
            }
            
            private function spriteButtonRightMouseDownHandler(event:MouseEvent):void
            {
                _contextButton = event.currentTarget as Button;
            }
            
            private function spriteContextMenuDisplayingHandler(event:Event):void
            {
                if (_contextButton && buttonsContainer.contains(_contextButton))
                {
                    if (!hasTransferData)
                    {
                        // Assuming Paste Frame is the 3rd item (index 2)
                        // This relies on the order defined in initializeSpriteContextMenu
                        if (_spriteContextMenu.items.length > 2)
                        {
                            _spriteContextMenu.items[2].enabled = false;
                        }
                    }
                    else
                    {
                        if (_spriteContextMenu.items.length > 2)
                        {
                            _spriteContextMenu.items[2].enabled = true;
                        }
                    }
                }
            }
            
            private function spriteContextMenuSelectHandler(event:Event):void
            {
                if (_contextButton && buttonsContainer.contains(_contextButton))
                {
                    var type:String = NativeMenuItem(event.target).data as String;
            
                    switch (type)
                    {
                        case ThingEditorEvent.CLEAR_SPRITE:
                            var frame:int = this.currentFrame;
                            var index:int = parseInt(_contextButton.label);
                            this.clearSprite(frame, index);
                            break;
            
                        case ThingEditorEvent.COPY_FRAME:
                            this.copyFrame(this.currentFrame);
                            break;
            
                        case ThingEditorEvent.PASTE_FRAME:
                            this.pasteFrame(this.currentFrame);
                            break;
            
                        case ThingEditorEvent.CLEAR_FRAME:
                            this.clearFrame(this.currentFrame);
                            break;

                        case ThingEditorEvent.REPLACE_FROM_PNG:
                            dispatchEvent(new ThingEditorEvent(ThingEditorEvent.REPLACE_FROM_PNG, this.thingData));
                            break;
                    }
                }
            }
        ]]>
    </fx:Script>

    <nail:TabNavigator id="tabNavigator"
        width="100%" height="100%"
        change="{setPreviewMode(false);}">
        <s:NavigatorContent label="@Resource(key='texture', bundle='strings')"
            width="100%" height="100%">
            <s:Scroller id="textureScroller" width="100%" height="100%"
                mouseWheel="onTextureMouseWheel(event)">
                <s:Group>
                    <s:layout>
                        <s:VerticalLayout padding="10" gap="10"/>
                    </s:layout>

                    <!-- appearance group -->
                    <mg:GroupBox id="appearanceGroupBox"
                        label="@Resource(key='appearance', bundle='strings')"
                        width="100%"
                        minHeight="470">
                        <mg:layout>
                            <s:VerticalLayout padding="10" gap="10"/>
                        </mg:layout>

                        <s:HGroup width="100%" verticalAlign="middle" gap="5">
                            <s:Label text="{resourceManager.getString('strings', 'zoom') + ':'}"/>
                            <s:HSlider id="zoomSlider"
                                width="100"
                                minimum="1.0"
                                maximum="5.0"
                                stepSize="0.1"
                                value="{_zoom}"
                                liveDragging="true"
                                change="{_zoom = zoomSlider.value; spriteViewContainer.scaleX = _zoom; spriteViewContainer.scaleY = _zoom;}"/>
                            <s:Label text="{_zoom + 'x'}" minWidth="25"/>

                            <s:Spacer width="100%"/>

                            <s:HGroup id="directionGroup" verticalAlign="middle" horizontalAlign="center">
                                <otlib:DirectionButton id="topLeftButton"
                                    direction="{Direction.NORTHWEST}"
                                    toolTip="@Resource(key='northwest', bundle='strings')"
                                    icon="@Embed('/../assets/icons/arrow_top_left.png')"
                                    click="directionButtonClickHandler(event)"/>
                                <otlib:DirectionButton id="topCenterButton"
                                    direction="{Direction.NORTH}"
                                    toolTip="@Resource(key='north', bundle='strings')"
                                    icon="@Embed('/../assets/icons/arrow_up.png')"
                                    click="directionButtonClickHandler(event)"/>
                                <otlib:DirectionButton id="topRightButton"
                                    direction="{Direction.NORTHEAST}"
                                    toolTip="@Resource(key='northeast', bundle='strings')"
                                    icon="@Embed('/../assets/icons/arrow_top_right.png')"
                                    click="directionButtonClickHandler(event)"/>
                                <otlib:DirectionButton id="middleRightButton"
                                    direction="{Direction.EAST}"
                                    toolTip="@Resource(key='east', bundle='strings')"
                                    icon="@Embed('/../assets/icons/arrow_right.png')"
                                    click="directionButtonClickHandler(event)"/>
                                <otlib:DirectionButton id="bottomRightButton"
                                    direction="{Direction.SOUTHEAST}"
                                    toolTip="@Resource(key='southeast', bundle='strings')"
                                    icon="@Embed('/../assets/icons/arrow_bottom_right.png')"
                                    click="directionButtonClickHandler(event)"/>
                                <otlib:DirectionButton id="bottomCenterButton"
                                    direction="{Direction.SOUTH}"
                                    toolTip="@Resource(key='south', bundle='strings')"
                                    icon="@Embed('/../assets/icons/arrow_down.png')"
                                    click="directionButtonClickHandler(event)"/>
                                <otlib:DirectionButton id="bottomLeftButton"
                                    direction="{Direction.SOUTHWEST}"
                                    toolTip="@Resource(key='southwest', bundle='strings')"
                                    icon="@Embed('/../assets/icons/arrow_bottom_left.png')"
                                    click="directionButtonClickHandler(event)"/>
                                <otlib:DirectionButton id="middleLeftButton"
                                    direction="{Direction.WEST}"
                                    toolTip="@Resource(key='west', bundle='strings')"
                                    icon="@Embed('/../assets/icons/arrow_left.png')"
                                    click="directionButtonClickHandler(event)"/>
                            </s:HGroup>

                            <s:Spacer width="100%"/>
                            <s:Label text="{_currentDirectionLabel}" minWidth="35" fontSize="10" color="0xAAAAAA"/>
                            <s:Spacer width="100%"/>

                            <s:CheckBox id="editPixelsCheckBox"
                                label="Edit Pixels"
                                selected="{_editPixelsMode}"
                                change="{_editPixelsMode = editPixelsCheckBox.selected; clearMultiSelection(); if (_editPixelsMode) setFocus(); if (_filmRollMode) updatePreview();}"/>

                            <s:CheckBox id="filmRollCheckBox"
                                label="Film Roll"
                                selected="{_filmRollMode}"
                                change="{_filmRollMode = filmRollCheckBox.selected; clearMultiSelection(); updatePreview();}"/>
                        </s:HGroup>

                        <s:Group width="100%" minHeight="200">
                            <s:Group id="spriteViewContainer" horizontalCenter="0" verticalCenter="0">
                                <s:Rect width="{bitmapView.width}"
                                    height="{bitmapView.height}"
                                    visible="{bitmapView.visible}">
                                    <s:fill>
                                        <s:SolidColor color="0x636363"/>
                                    </s:fill>
                                    <s:stroke>
                                        <s:SolidColorStroke color="{_editPixelsMode ? 0x6CACEC : 0x636363}"
                                            weight="{_editPixelsMode ? 2 : 0}"/>
                                    </s:stroke>
                                </s:Rect>

                                <otlib:SurfaceCells id="pixelGrid"
                                    visible="{_editPixelsMode &amp;&amp; !(_filmRollMode &amp;&amp; _frameGroup != null &amp;&amp; _frameGroup.frames > 1)}"
                                    cellWidth="4" cellHeight="4"
                                    lineColor="0xFFFFFF"
                                    lineAlpha="0.3"/>

                                <s:Image id="bitmapView"/>

                                <otlib:ThingDataView id="thingView"
                                    visible="false"
                                    change="thingViewFrameChangeHandler(event)"
                                    complete="thingViewAnimationCompleteHandler(event)"/>

                                <s:Group id="buttonsContainer"
                                    updateComplete="drawCropSize()"/>

                            </s:Group>

                            <!-- Pixel shift buttons — bound to spriteViewContainer position -->
                            <s:Button width="22" height="22"
                                skinClass="otlib.components.skins.DirectionButtonSkin"
                                icon="@Embed('/../assets/icons/arrow_up.png')"
                                toolTip="Shift pixels up"
                                x="{spriteViewContainer.x + (spriteViewContainer.width * _zoom) / 2 - 11}"
                                y="{spriteViewContainer.y - 24}"
                                visible="{_editPixelsMode &amp;&amp; !(_filmRollMode &amp;&amp; _frameGroup != null &amp;&amp; _frameGroup.frames > 1)}"
                                click="shiftPixels(0, -1)"/>
                            <s:Button width="22" height="22"
                                skinClass="otlib.components.skins.DirectionButtonSkin"
                                icon="@Embed('/../assets/icons/arrow_down.png')"
                                toolTip="Shift pixels down"
                                x="{spriteViewContainer.x + (spriteViewContainer.width * _zoom) / 2 - 11}"
                                y="{spriteViewContainer.y + spriteViewContainer.height * _zoom + 2}"
                                visible="{_editPixelsMode &amp;&amp; !(_filmRollMode &amp;&amp; _frameGroup != null &amp;&amp; _frameGroup.frames > 1)}"
                                click="shiftPixels(0, 1)"/>
                            <s:Button width="22" height="22"
                                skinClass="otlib.components.skins.DirectionButtonSkin"
                                icon="@Embed('/../assets/icons/arrow_left.png')"
                                toolTip="Shift pixels left"
                                x="{spriteViewContainer.x - 24}"
                                y="{spriteViewContainer.y + (spriteViewContainer.height * _zoom) / 2 - 11}"
                                visible="{_editPixelsMode &amp;&amp; !(_filmRollMode &amp;&amp; _frameGroup != null &amp;&amp; _frameGroup.frames > 1)}"
                                click="shiftPixels(-1, 0)"/>
                            <s:Button width="22" height="22"
                                skinClass="otlib.components.skins.DirectionButtonSkin"
                                icon="@Embed('/../assets/icons/arrow_right.png')"
                                toolTip="Shift pixels right"
                                x="{spriteViewContainer.x + spriteViewContainer.width * _zoom + 2}"
                                y="{spriteViewContainer.y + (spriteViewContainer.height * _zoom) / 2 - 11}"
                                visible="{_editPixelsMode &amp;&amp; !(_filmRollMode &amp;&amp; _frameGroup != null &amp;&amp; _frameGroup.frames > 1)}"
                                click="shiftPixels(1, 0)"/>
                        </s:Group>

                        <nail:ShadowLine width="100%"/>

                        <s:Spacer height="5"/>

                        <s:HGroup id="animationGroup" width="100%"
                            verticalAlign="middle"
                            horizontalAlign="right"
                            visible="{_frameGroup.frames > 1}">
                            <s:Label text="{resourceManager.getString('strings', 'animations') + ':'}"/>
                            <otlib:PatternSlider id="animationSlider"
                                maximum="{_frameGroup.frames - 1}"
                                change="updatePreview()"/>
                            <s:Label id="animationCountLabel"
                                minWidth="40"/>

                            <otlib:PlayButton id="playAnimationButton"
                                width="20" height="20"
                                click="playAnimationButtonClickHandler(event)"/>
                        </s:HGroup>

                        <s:HGroup id="minimumGroup" width="100%" horizontalAlign="right" visible="false">
                            <s:Label id="minimumDurationLabel" text="{resourceManager.getString('strings', 'minimumDuration') + ':'}" paddingTop="5"/>
                            <s:NumericStepper id="minimumNumericStepper"
                                width="100"
                                minimum="0"
                                maximum="360000"
                                change="minimumNumericStepperChangeHandler(event)"/>

                            <s:Button id="defaultDurations"
                                toolTip="@Resource(key='defaultDurations', bundle='strings')"
                                width="19"
                                height="19"
                                icon="{Assets.EDIT}"
                                click="setDefaultDurationsHandler(event)"/>
                        </s:HGroup>

                        <s:HGroup id="maximumGroup" width="100%" verticalAlign="middle" horizontalAlign="right" visible="false">
                            <s:Label id="maximumDurationLabel" text="{resourceManager.getString('strings', 'maximumDuration') + ':'}" paddingTop="5"/>
                            <s:NumericStepper id="maximumNumericStepper"
                                width="100"
                                minimum="0"
                                maximum="360000"
                                change="maximumNumericStepperChangeHandler(event)"/>

                            <s:Button id="forAllFrames"
                                toolTip="@Resource(key='setForAllFrames', bundle='strings')"
                                width="19"
                                height="19"
                                icon="{Assets.EDIT}"
                                click="setForAllFramesHandler(event)"/>
                        </s:HGroup>

                        <s:HGroup id="addonGroup"
                            width="100%"
                            verticalAlign="middle"
                            horizontalAlign="right"
                            paddingRight="27"
                            visible="false">
                            <s:Label text="{resourceManager.getString('strings', 'addons') + ':'}"/>
                            <otlib:PatternSlider id="addonsSlider"
                                maximum="{_frameGroup.patternY - 1}"
                                change="updatePreview()"/>
                            <s:Label id="addonCountLabel"
                                minWidth="40"/>
                        </s:HGroup>

                        <s:HGroup id="mountGroup"
                            width="100%"
                            verticalAlign="middle"
                            horizontalAlign="right"
                            paddingRight="27"
                            visible="{_frameGroup.patternZ > 1}">
                            <s:Label text="{resourceManager.getString('strings', 'mount') + ':'}"/>
                            <otlib:PatternSlider id="mountSlider"
                                maximum="{_frameGroup.patternZ - 1}"
                                change="updatePreview()"/>
                            <s:Label id="mountCountLabel"
                                minWidth="40"/>
                        </s:HGroup>

                        <s:HGroup id="frameGroup"
                            width="100%"
                            verticalAlign="middle"
                            horizontalAlign="right"
                            visible="{_thingBinding.groups > 1}">
                            <s:Label text="{'Group:'}"/>
                            <otlib:PatternSlider id="frameGroupSlider"
                                minimum="0"
                                maximum="{_thingBinding.groups - 1}"
                                change="frameGroupSliderChange()"/>
                            <s:Label id="frameGroupNameLabel"
                                minWidth="40"/>
                        </s:HGroup>

                        <s:HGroup id="layerGroup"
                            width="100%"
                            verticalAlign="middle"
                            horizontalAlign="right"
                            paddingRight="27"
                            visible="{_frameGroup.layers > 1}">
                            <s:Label text="{resourceManager.getString('strings', 'layer') + ':'}"/>
                            <otlib:PatternSlider id="layerSlider"
                                maximum="{_frameGroup.layers - 1}"
                                change="updatePreview()"/>
                            <s:Label id="layerCountLabel"
                                minWidth="40"/>
                        </s:HGroup>

                        <s:CheckBox id="showCropSizeCheckBox"
                            label="@Resource(key='showCropSize', bundle='strings')"
                            change="drawCropSize()"/>

                        <s:CheckBox id="showGridCheckBox"
                            label="@Resource(key='showGrid', bundle='strings')"
                            change="{changeButtonsVisible(showGridCheckBox.selected);}"/>

                    </mg:GroupBox>

                    <!-- has bones group -->
                    <mg:GroupCheckBox id="hasBonesGroupCheckBox"
                        label="@Resource(key='hasBones', bundle='strings')"
                        width="100%"
                        selected="{_thingBinding.hasBones}"
                        change="{_thingBinding.hasBones = hasBonesGroupCheckBox.selected;}">
                        <s:Group width="100%"
                            height="100%"
                            enabled="{hasBonesGroupCheckBox.selected}">
                            <s:layout>
                                <s:VerticalLayout padding="10"/>
                            </s:layout>

                            <s:HGroup width="100%"
                                verticalAlign="middle"
                                horizontalAlign="right">
                                <s:Label text="{resourceManager.getString('strings', 'offsetX') + ':'}"
                                    minWidth="60"
                                    textAlign="right"/>
                                <s:NumericStepper id="bonesOffsetXNumericStepper"
                                    width="80"
                                    value="0"
                                    change="bonesOffsetXNumericStepperChangeHandler(event)"/>
                                <s:Spacer width="30"/>
                            </s:HGroup>
                            <s:HGroup width="100%"
                                verticalAlign="middle"
                                horizontalAlign="right">
                                <s:Label text="{resourceManager.getString('strings', 'offsetY') + ':'}"
                                    minWidth="60"
                                    textAlign="right"/>
                                <s:NumericStepper id="bonesOffsetYNumericStepper"
                                    width="80"
                                    value="0"
                                    change="bonesOffsetYNumericStepperChangeHandler(event)"/>
                                <s:Spacer width="30"/>
                            </s:HGroup>

                        </s:Group>
                    </mg:GroupCheckBox>

                    <!-- patterns group -->
                    <mg:GroupBox id="patternsGroupBox"
                        label="@Resource(key='patterns', bundle='strings')"
                        width="100%">

                        <s:TileGroup id="patternsTileGroup" right="35"
                            requestedColumnCount="2"
                            padding="10">
                            <s:Label id="frameGroupsLabel"
                                text="{resourceManager.getString('strings', 'frameGroups') + ':'}"
                                verticalAlign="middle"
                                textAlign="right"/>
                            <s:NumericStepper id="frameGroupsNumericStepper"
                                width="70"
                                minimum="1"
                                maximum="2"
                                value="{_thingBinding.groups}"
                                change="{groupsNumericStepperChangeHandler(event); checkFrameGroups(event); textureUpdate(event);}"/>
                            <s:Label text="{resourceManager.getString('strings', 'width') + ':'}"
                                verticalAlign="middle"
                                textAlign="right"/>
                            <s:NumericStepper id="widthNumericStepper"
                                width="70"
                                minimum="1"
                                value="{_frameGroup.width}"
                                change="{widthNumericStepperChangeHandler(event); textureUpdate(event);}"/>
                            <s:Label text="{resourceManager.getString('strings', 'height') + ':'}"
                                verticalAlign="middle"
                                textAlign="right"/>
                            <s:NumericStepper id="heightNumericStepper"
                                width="70"
                                minimum="1"
                                value="{_frameGroup.height}"
                                change="{heightNumericStepperChangeHandler(event); textureUpdate(event);}"/>
                            <s:Label text="{resourceManager.getString('strings', 'cropSize') + ':'}"
                                verticalAlign="middle"
                                textAlign="right"/>
                            <s:NumericStepper id="cropSizeNumericStepper"
                                width="70"
                                maximum="1000"
                                value="{_frameGroup.exactSize}"
                                change="{exactSizeNumericStepperChangeHandler(event); textureUpdate(event);}"/>
                            <s:Label text="{resourceManager.getString('strings', 'layers') + ':'}"
                                verticalAlign="middle"
                                textAlign="right"/>
                            <s:NumericStepper id="layersNumericStepper"
                                width="70"
                                minimum="1"
                                value="{_frameGroup.layers}"
                                change="{layersNumericStepperChangeHandler(event); textureUpdate(event);}"/>
                            <s:Label text="{resourceManager.getString('strings', 'patternX') + ':'}"
                                verticalAlign="middle"
                                textAlign="right"/>
                            <s:NumericStepper id="patternXNumericStepper"
                                width="70"
                                minimum="1"
                                value="{_frameGroup.patternX}"
                                change="{patternXNumericStepperChangeHandler(event); textureUpdate(event);}"/>
                            <s:Label text="{resourceManager.getString('strings', 'patternY') + ':'}"
                                verticalAlign="middle"
                                textAlign="right"/>
                            <s:NumericStepper id="patternYNumericStepper"
                                width="70"
                                minimum="1"
                                value="{_frameGroup.patternY}"
                                change="{patternYNumericStepperChangeHandler(event); textureUpdate(event);}"/>
                            <s:Label id="patternZLabel"
                                text="{resourceManager.getString('strings', 'patternZ') + ':'}"
                                verticalAlign="middle"
                                textAlign="right"/>
                            <s:NumericStepper id="patternZNumericStepper"
                                width="70"
                                minimum="1"
                                value="{_frameGroup.patternZ}"
                                change="{patternZNumericStepperChangeHandler(event); textureUpdate(event);}"/>
                            <s:Label text="{resourceManager.getString('strings', 'animations') + ':'}"
                                verticalAlign="middle"
                                textAlign="right"/>
                            <s:NumericStepper id="framesNumericStepper"
                                width="70"
                                minimum="1"
                                maximum="1000"
                                value="{_frameGroup.frames}"
                                change="{framesNumericStepperChangeHandler(event); textureUpdate(event); updateAnimationControls();}"/>
                        </s:TileGroup>
                    </mg:GroupBox>

                    <!-- animation -->
                    <mg:GroupBox id="animationGroupBox"
                        label="@Resource(key='animation', bundle='strings')"
                        width="100%"
                        visible="{_frameGroup.frames > 1}"
                        includeInLayout="{_frameGroup.frames > 1}">
                        <s:TileGroup id="animationTileGroup"
                            right="35"
                            requestedColumnCount="2"
                            padding="10">

                            <s:Label text="{resourceManager.getString('strings', 'animationMode') + ':'}"
                                verticalAlign="middle"
                                textAlign="right"/>
                            <s:DropDownList id="animationModeDropDownList"
                                requireSelection="true"
                                width="170"
                                change="animationModeDropDownListChangeHandler(event)">
                                <s:dataProvider>
                                    <s:ArrayList>
                                        <fx:String>{resourceManager.getString('strings', 'asynchronous')}</fx:String>
                                        <fx:String>{resourceManager.getString('strings', 'synchronous')}</fx:String>
                                    </s:ArrayList>
                                </s:dataProvider>
                            </s:DropDownList>

                            <s:Label text="{resourceManager.getString('strings', 'frameStrategy') + ':'}"
                                verticalAlign="middle"
                                textAlign="right"/>
                            <s:DropDownList id="frameStrategyDropDownList"
                                requireSelection="true"
                                width="170"
                                change="frameStrategyDropDownListChangeHandler(event)">
                                <s:dataProvider>
                                    <s:ArrayList>
                                        <fx:String>{resourceManager.getString('strings', 'loop')}</fx:String>
                                        <fx:String>{resourceManager.getString('strings', 'pingPong')}</fx:String>
                                    </s:ArrayList>
                                </s:dataProvider>
                            </s:DropDownList>

                            <!-- loop count -->
                            <s:Label text="{resourceManager.getString('strings', 'loopCount') + ':'}"
                                verticalAlign="middle"
                                textAlign="right"/>
                            <s:NumericStepper id="loopCountNumericStepper"
                                width="170"
                                change="loopCountNumericStepperChangeHandler(event)"/>

                            <s:Label text="{resourceManager.getString('strings', 'startFrame') + ':'}"
                                verticalAlign="middle"
                                textAlign="right"/>
                            <s:NumericStepper id="startFrameNumericStepper"
                                width="70"
                                minimum="-1"
                                maximum="{_frameGroup.frames - 1}"
                                change="startFrameNumericStepperChangeHandler(event)"/>
                        </s:TileGroup>
                    </mg:GroupBox>
                </s:Group>
            </s:Scroller>
        </s:NavigatorContent>
        <s:NavigatorContent label="@Resource(key='properties', bundle='strings')"
            width="100%" height="100%">
            <s:Scroller id="propertiesScroller" width="100%" height="100%"
                mouseWheel="onPropertiesMouseWheel(event)">
                <s:Group>
                    <s:layout>
                        <s:VerticalLayout padding="10" gap="10"/>
                    </s:layout>

                    <!-- ground group -->
                    <mg:GroupCheckBox id="groundGroupCheckBox"
                        label="@Resource(key='isGround', bundle='strings')"
                        width="100%"
                        selected="{_thingBinding.isGround}"
                        change="{_thingBinding.isGround = groundGroupCheckBox.selected;}">
                        <s:Group width="100%" height="100%"
                            enabled="{groundGroupCheckBox.selected}">
                            <s:layout>
                                <s:HorizontalLayout padding="10" verticalAlign="middle" horizontalAlign="right"/>
                            </s:layout>
                            <s:Label text="{resourceManager.getString('strings', 'groundSpeed') + ':'}"
                                minWidth="60"
                                textAlign="right"/>
                            <s:NumericStepper id="groundSpeedNumericStepper"
                                width="80"
                                maximum="1000"
                                value="{_thingBinding.groundSpeed}"
                                change="{_thingBinding.groundSpeed = groundSpeedNumericStepper.value;}"/>
                            <s:Spacer width="30"/>
                        </s:Group>
                    </mg:GroupCheckBox>

                    <!-- has ligth group -->
                    <mg:GroupCheckBox id="hasLigthGroupCheckBox"
                        label="@Resource(key='hasLight', bundle='strings')"
                        width="100%"
                        selected="{_thingBinding.hasLight}"
                        change="{_thingBinding.hasLight = hasLigthGroupCheckBox.selected;}">
                        <s:Group width="100%" height="100%"
                            enabled="{hasLigthGroupCheckBox.selected}">
                            <s:layout>
                                <s:VerticalLayout padding="10"/>
                            </s:layout>
                            <s:HGroup width="100%"
                                verticalAlign="middle"
                                horizontalAlign="right">
                                <s:Label text="{resourceManager.getString('strings', 'lightColor') + ':'}"
                                    minWidth="60"
                                    textAlign="right"/>
                                <s:NumericStepper id="lightColorNumericStepper"
                                    width="80"
                                    maximum="215"
                                    value="{_thingBinding.lightColor}"
                                    change="{_thingBinding.lightColor = lightColorNumericStepper.value;}"/>

                                <otlib:EightBitColorPicker id="lightColorSwitchColor"
                                    color="{_thingBinding.lightColor}"
                                    change="{_thingBinding.lightColor = lightColorSwitchColor.color;}"/>
                            </s:HGroup>
                            <s:HGroup width="100%"
                                verticalAlign="middle"
                                horizontalAlign="right">
                                <s:Label text="{resourceManager.getString('strings', 'lightIntensity') + ':'}"
                                    minWidth="60"
                                    textAlign="right"/>
                                <s:NumericStepper id="lightLevelNumericStepper"
                                    width="80"
                                    value="{_thingBinding.lightLevel}"
                                    change="{_thingBinding.lightLevel = lightLevelNumericStepper.value;}"/>
                                <s:Spacer width="30"/>
                            </s:HGroup>
                        </s:Group>
                    </mg:GroupCheckBox>

                    <!-- automap group -->
                    <mg:GroupCheckBox id="automapGroupCheckBox"
                        label="@Resource(key='automap', bundle='strings')"
                        width="100%"
                        selected="{_thingBinding.miniMap}"
                        change="{_thingBinding.miniMap = automapGroupCheckBox.selected;}">
                        <s:Group width="100%"
                            height="100%"
                            enabled="{automapGroupCheckBox.selected}">
                            <s:layout>
                                <s:HorizontalLayout padding="10" verticalAlign="middle" horizontalAlign="right"/>
                            </s:layout>
                            <s:Label text="{resourceManager.getString('strings', 'automapColor') + ':'}"
                                minWidth="60"
                                textAlign="right"/>
                            <s:NumericStepper id="automapColorNumericStepper"
                                width="80"
                                maximum="215"
                                value="{_thingBinding.miniMapColor}"
                                change="{_thingBinding.miniMapColor = automapColorNumericStepper.value;}"/>
                            <otlib:EightBitColorPicker id="automapColorSwitchColor"
                                color="{_thingBinding.miniMapColor}"
                                change="{_thingBinding.miniMapColor = automapColorSwitchColor.color;}"/>
                        </s:Group>
                    </mg:GroupCheckBox>

                    <!-- has offset group -->
                    <mg:GroupCheckBox id="hasOffsetGroupCheckBox"
                        label="@Resource(key='hasOffset', bundle='strings')"
                        width="100%"
                        selected="{_thingBinding.hasOffset}"
                        change="{_thingBinding.hasOffset = hasOffsetGroupCheckBox.selected;}">
                        <s:Group width="100%"
                            height="100%"
                            enabled="{hasOffsetGroupCheckBox.selected}">
                            <s:layout>
                                <s:VerticalLayout padding="10"/>
                            </s:layout>
                            <s:HGroup width="100%"
                                verticalAlign="middle"
                                horizontalAlign="right">
                                <s:Label text="{resourceManager.getString('strings', 'offsetX') + ':'}"
                                    minWidth="60"
                                    textAlign="right"/>
                                <s:NumericStepper id="offsetXNumericStepper"
                                    width="80"
                                    value="{_thingBinding.offsetX}"
                                    change="{_thingBinding.offsetX = offsetXNumericStepper.value;}"/>
                                <s:Spacer width="30"/>
                            </s:HGroup>
                            <s:HGroup width="100%"
                                verticalAlign="middle"
                                horizontalAlign="right">
                                <s:Label text="{resourceManager.getString('strings', 'offsetY') + ':'}"
                                    minWidth="60"
                                    textAlign="right"/>
                                <s:NumericStepper id="offsetYNumericStepper"
                                    width="80"
                                    value="{_thingBinding.offsetY}"
                                    change="{_thingBinding.offsetY = offsetYNumericStepper.value;}"/>
                                <s:Spacer width="30"/>
                            </s:HGroup>
                        </s:Group>
                    </mg:GroupCheckBox>

                    <!-- has elevation group -->
                    <mg:GroupCheckBox id="hasElevationGroupCheckBox"
                        label="@Resource(key='hasElevation', bundle='strings')"
                        width="100%"
                        selected="{_thingBinding.hasElevation}"
                        change="{_thingBinding.hasElevation = hasElevationGroupCheckBox.selected;}">
                        <s:Group width="100%"
                            height="100%"
                            enabled="{hasElevationGroupCheckBox.selected}">
                            <s:layout>
                                <s:HorizontalLayout padding="10" verticalAlign="middle" horizontalAlign="right"/>
                            </s:layout>
                            <s:Label text="{resourceManager.getString('strings', 'elevation') + ':'}"
                                minWidth="60"
                                textAlign="right"/>
                            <s:NumericStepper id="elevationNumericStepper"
                                width="80"
                                maximum="32"
                                value="{_thingBinding.elevation}"
                                change="{_thingBinding.elevation = elevationNumericStepper.value;}"/>
                            <s:Spacer width="30"/>
                        </s:Group>
                    </mg:GroupCheckBox>

                    <!-- equip group -->
                    <mg:GroupCheckBox id="equipGroupCheckBox"
                        label="@Resource(key='cloth', bundle='strings')"
                        width="100%"
                        selected="{_thingBinding.cloth}"
                        change="{_thingBinding.cloth = equipGroupCheckBox.selected;
                                      if (!equipGroupCheckBox.selected)equipSlotDropDownList.selectedIndex = -1;}">
                        <s:Group width="100%"
                            height="100%"
                            enabled="{equipGroupCheckBox.selected}">
                            <s:layout>
                                <s:HorizontalLayout padding="10" verticalAlign="middle" horizontalAlign="right"/>
                            </s:layout>
                            <s:Label text="{resourceManager.getString('strings', 'clothSlot') + ':'}"
                                minWidth="60"
                                textAlign="right"/>
                            <s:DropDownList id="equipSlotDropDownList"
                                width="100%"
                                height="20"
                                fontSize="11"
                                prompt="@Resource(key='slot.prompt', bundle='strings')"
                                selectedIndex="{_thingBinding.clothSlot}"
                                change="{_thingBinding.clothSlot = equipSlotDropDownList.selectedIndex;}">
                                <s:dataProvider>
                                    <s:ArrayList>
                                        <fx:String>{resourceManager.getString('strings', 'slot.twoHandWeapon')}</fx:String>
                                        <fx:String>{resourceManager.getString('strings', 'slot.helmet')}</fx:String>
                                        <fx:String>{resourceManager.getString('strings', 'slot.amulet')}</fx:String>
                                        <fx:String>{resourceManager.getString('strings', 'slot.backpack')}</fx:String>
                                        <fx:String>{resourceManager.getString('strings', 'slot.armor')}</fx:String>
                                        <fx:String>{resourceManager.getString('strings', 'slot.shield')}</fx:String>
                                        <fx:String>{resourceManager.getString('strings', 'slot.oneHandWeapon')}</fx:String>
                                        <fx:String>{resourceManager.getString('strings', 'slot.legs')}</fx:String>
                                        <fx:String>{resourceManager.getString('strings', 'slot.boots')}</fx:String>
                                        <fx:String>{resourceManager.getString('strings', 'slot.ring')}</fx:String>
                                        <fx:String>{resourceManager.getString('strings', 'slot.arrow')}</fx:String>
                                    </s:ArrayList>
                                </s:dataProvider>
                            </s:DropDownList>
                        </s:Group>
                    </mg:GroupCheckBox>

                    <!-- market group -->
                    <mg:GroupCheckBox id="marketGroupCheckBox"
                        label="@Resource(key='market', bundle='strings')"
                        width="100%"
                        selected="{_thingBinding.isMarketItem}"
                        change="{_thingBinding.isMarketItem = marketGroupCheckBox.selected;}">
                        <s:Group width="100%"
                            height="100%"
                            enabled="{marketGroupCheckBox.selected}">
                            <s:layout>
                                <s:VerticalLayout paddingLeft="10"
                                    paddingRight="45"
                                    paddingTop="20"
                                    paddingBottom="10"/>
                            </s:layout>
                            <s:HGroup width="100%"
                                verticalAlign="middle"
                                horizontalAlign="right">
                                <s:Label text="{resourceManager.getString('strings', 'name') + ':'}"/>
                                <s:TextInput id="marketNameTextInput" width="100%"
                                    text="{_thingBinding.marketName}"
                                    change="{_thingBinding.marketName = marketNameTextInput.text;}"/>
                            </s:HGroup>

                            <s:HGroup width="100%"
                                verticalAlign="middle"
                                horizontalAlign="right">
                                <s:Label text="{resourceManager.getString('strings', 'category') + ':'}"
                                    minWidth="60"
                                    textAlign="right"/>
                                <s:DropDownList id="marketCategoryDropDownList"
                                    width="170"
                                    height="20"
                                    fontSize="11"
                                    selectedIndex="{_thingBinding.marketCategory == 0 ? 8 : _thingBinding.marketCategory - 1}"
                                    change="{_thingBinding.marketCategory = marketCategoryDropDownList.selectedIndex + 1;}">
                                    <s:ArrayList>
                                        <fx:String>{resourceManager.getString('strings', 'market.armors')}</fx:String>
                                        <fx:String>{resourceManager.getString('strings', 'market.amulets')}</fx:String>
                                        <fx:String>{resourceManager.getString('strings', 'market.boots')}</fx:String>
                                        <fx:String>{resourceManager.getString('strings', 'market.containers')}</fx:String>
                                        <fx:String>{resourceManager.getString('strings', 'market.decoration')}</fx:String>
                                        <fx:String>{resourceManager.getString('strings', 'market.foods')}</fx:String>
                                        <fx:String>{resourceManager.getString('strings', 'market.helmetsAndHats')}</fx:String>
                                        <fx:String>{resourceManager.getString('strings', 'market.legs')}</fx:String>
                                        <fx:String>{resourceManager.getString('strings', 'market.others')}</fx:String>
                                        <fx:String>{resourceManager.getString('strings', 'market.potions')}</fx:String>
                                        <fx:String>{resourceManager.getString('strings', 'market.rings')}</fx:String>
                                        <fx:String>{resourceManager.getString('strings', 'market.runes')}</fx:String>
                                        <fx:String>{resourceManager.getString('strings', 'market.shields')}</fx:String>
                                        <fx:String>{resourceManager.getString('strings', 'market.tools')}</fx:String>
                                        <fx:String>{resourceManager.getString('strings', 'market.valuables')}</fx:String>
                                        <fx:String>{resourceManager.getString('strings', 'market.ammunition')}</fx:String>
                                        <fx:String>{resourceManager.getString('strings', 'market.axes')}</fx:String>
                                        <fx:String>{resourceManager.getString('strings', 'market.clubs')}</fx:String>
                                        <fx:String>{resourceManager.getString('strings', 'market.distance')}</fx:String>
                                        <fx:String>{resourceManager.getString('strings', 'market.swords')}</fx:String>
                                        <fx:String>{resourceManager.getString('strings', 'market.wandsAndRods')}</fx:String>
                                        <fx:String>{resourceManager.getString('strings', 'market.premiumScrolls')}</fx:String>
                                        <fx:String>{resourceManager.getString('strings', 'market.metaWeapons')}</fx:String>
                                    </s:ArrayList>
                                </s:DropDownList>
                            </s:HGroup>
                            <s:HGroup width="100%"
                                verticalAlign="middle"
                                horizontalAlign="right">
                                <s:Label text="{resourceManager.getString('strings', 'tradeAs') + ':'}"
                                    minWidth="60"
                                    textAlign="right"/>
                                <s:NumericStepper id="tradeAsNumericStepper"
                                    width="80"
                                    minimum="0"
                                    maximum="0xFFFFFF"
                                    value="{_thingBinding.marketTradeAs}"
                                    change="{_thingBinding.marketTradeAs = tradeAsNumericStepper.value;}"/>
                            </s:HGroup>
                            <s:HGroup width="100%"
                                verticalAlign="middle"
                                horizontalAlign="right">
                                <s:Label text="{resourceManager.getString('strings', 'showAs') + ':'}"
                                    minWidth="60"
                                    textAlign="right"/>
                                <s:NumericStepper id="showAsNumericStepper"
                                    width="80"
                                    minimum="0"
                                    maximum="0xFFFFFF"
                                    value="{_thingBinding.marketShowAs}"
                                    change="{_thingBinding.marketShowAs = showAsNumericStepper.value;}"/>
                            </s:HGroup>
                            <s:HGroup width="100%"
                                verticalAlign="middle"
                                horizontalAlign="right">
                                <s:Label text="{resourceManager.getString('strings', 'vocation') + ':'}"
                                    minWidth="60"
                                    textAlign="right"/>
                                <s:NumericStepper id="vocationNumericStepper"
                                    width="80"
                                    minimum="0"
                                    maximum="0xFFFFFF"
                                    value="{_thingBinding.marketRestrictProfession}"
                                    change="{_thingBinding.marketRestrictProfession = vocationNumericStepper.value;}"/>
                            </s:HGroup>
                            <s:HGroup width="100%"
                                verticalAlign="middle"
                                horizontalAlign="right">
                                <s:Label text="{resourceManager.getString('strings', 'level') + ':'}"
                                    minWidth="60"
                                    textAlign="right"/>
                                <s:NumericStepper id="marketRestrictLevelNumericStepper"
                                    width="80"
                                    minimum="0"
                                    maximum="0xFFFFFF"
                                    value="{_thingBinding.marketRestrictLevel}"
                                    change="{_thingBinding.marketRestrictLevel = marketRestrictLevelNumericStepper.value;}"/>
                            </s:HGroup>
                        </s:Group>
                    </mg:GroupCheckBox>

                    <!-- write / read group -->
                    <mg:GroupBox id="writeReadGroupCheckBox"
                        label="@Resource(key='writeRead', bundle='strings')"
                        width="100%">
                        <s:Group width="100%"
                            height="100%">
                            <s:layout>
                                <s:VerticalLayout paddingLeft="10"
                                    paddingRight="45"
                                    paddingTop="10"
                                    paddingBottom="10"
                                    horizontalAlign="right"/>
                            </s:layout>

                            <s:HGroup width="100%" verticalAlign="middle" horizontalAlign="right">
                                <s:CheckBox id="writableCheckBox"
                                    label="@Resource(key='writable', bundle='strings')"
                                    minWidth="100"
                                    selected="{_thingBinding.writable}"
                                    change="{_thingBinding.writable = writableCheckBox.selected;}"/>
                                <s:Label text="@Resource(key='maxLength', bundle='strings')"
                                    minWidth="80"
                                    textAlign="right"
                                    enabled="{writableCheckBox.selected}"/>
                                <s:NumericStepper id="maxReadWriteCharsNumericStepper" width="80"
                                    value="{_thingBinding.maxReadWriteChars}"
                                    enabled="{writableCheckBox.selected}"
                                    change="{_thingBinding.maxReadWriteChars = maxReadWriteCharsNumericStepper.value;}"/>
                            </s:HGroup>

                            <s:HGroup width="100%" verticalAlign="middle" horizontalAlign="right">
                                <s:CheckBox id="writableOnceCheckBox"
                                    label="@Resource(key='writableOnce', bundle='strings')"
                                    minWidth="100"
                                    selected="{_thingBinding.writableOnce}"
                                    change="{_thingBinding.writableOnce = writableOnceCheckBox.selected;}"/>
                                <s:Label text="@Resource(key='maxLength', bundle='strings')"
                                    minWidth="80"
                                    textAlign="right"
                                    enabled="{writableOnceCheckBox.selected}"/>
                                <s:NumericStepper id="maxReadCharsNumericStepper" width="80"
                                    value="{_thingBinding.maxReadChars}"
                                    enabled="{writableOnceCheckBox.selected}"
                                    change="{_thingBinding.maxReadChars = maxReadCharsNumericStepper.value;}"/>
                            </s:HGroup>
                        </s:Group>
                    </mg:GroupBox>

                    <mg:GroupCheckBox id="actionGroupCheckBox"
                        label="@Resource(key='hasAction', bundle='strings')"
                        width="100%"
                        selected="{_thingBinding.hasDefaultAction}"
                        change="{_thingBinding.hasDefaultAction = actionGroupCheckBox.selected;}">
                        <s:Group width="100%"
                            height="100%"
                            enabled="{actionGroupCheckBox.selected}">
                            <s:layout>
                                <s:HorizontalLayout paddingLeft="10"
                                    paddingRight="45"
                                    paddingTop="10"
                                    paddingBottom="10"
                                    verticalAlign="middle"
                                    horizontalAlign="right"/>
                            </s:layout>
                            <s:Label text="@Resource(key='actionType', bundle='strings')"
                                textAlign="right"
                                minWidth="60"/>
                            <s:DropDownList id="actionDropDownList"
                                width="170"
                                height="20"
                                fontSize="11"
                                selectedIndex="{_thingBinding.defaultAction}"
                                change="{_thingBinding.defaultAction = actionDropDownList.selectedIndex;}">
                                <s:dataProvider>
                                    <s:ArrayList>
                                        <fx:String>{resourceManager.getString('strings', 'action.none')}</fx:String>
                                        <fx:String>{resourceManager.getString('strings', 'action.look')}</fx:String>
                                        <fx:String>{resourceManager.getString('strings', 'action.use')}</fx:String>
                                        <fx:String>{resourceManager.getString('strings', 'action.open')}</fx:String>
                                        <fx:String>{resourceManager.getString('strings', 'action.autowalkHighlight')}</fx:String>
                                    </s:ArrayList>
                                </s:dataProvider>
                            </s:DropDownList>
                        </s:Group>
                    </mg:GroupCheckBox>

                    <!-- Lens Help-->
                    <mg:GroupCheckBox id="isLensHelpGroupCheckBox"
                        label="@Resource(key='lensHelp', bundle='strings')"
                        width="100%"
                        selected="{_thingBinding.isLensHelp}"
                        change="{_thingBinding.isLensHelp = isLensHelpGroupCheckBox.selected;}">
                        <s:HGroup width="100%"
                            paddingLeft="10"
                            paddingRight="45"
                            paddingTop="10"
                            paddingBottom="10"
                            verticalAlign="middle"
                            horizontalAlign="right"
                            enabled="{isLensHelpGroupCheckBox.selected}">
                            <s:Label text="{resourceManager.getString('strings', 'type') + ':'}"
                                minWidth="60"
                                textAlign="right"/>
                            <s:DropDownList id="lensHelpDropDownList"
                                width="170"
                                height="20"
                                fontSize="11"
                                selectedIndex="{Math.max(0, _thingBinding.lensHelp - 1100)}"
                                change="{_thingBinding.lensHelp = lensHelpDropDownList.selectedIndex + 1100;}">
                                <s:dataProvider>
                                    <s:ArrayList>
                                        <fx:String>{resourceManager.getString('strings', 'lensHelp.ladders')}</fx:String>
                                        <fx:String>{resourceManager.getString('strings', 'lensHelp.sewerGrates')}</fx:String>
                                        <fx:String>{resourceManager.getString('strings', 'lensHelp.dungeonFloor')}</fx:String>
                                        <fx:String>{resourceManager.getString('strings', 'lensHelp.levers')}</fx:String>
                                        <fx:String>{resourceManager.getString('strings', 'lensHelp.doors')}</fx:String>
                                        <fx:String>{resourceManager.getString('strings', 'lensHelp.specialDoors')}</fx:String>
                                        <fx:String>{resourceManager.getString('strings', 'lensHelp.stairs')}</fx:String>
                                        <fx:String>{resourceManager.getString('strings', 'lensHelp.mailboxes')}</fx:String>
                                        <fx:String>{resourceManager.getString('strings', 'lensHelp.depotBoxes')}</fx:String>
                                        <fx:String>{resourceManager.getString('strings', 'lensHelp.dustbins')}</fx:String>
                                        <fx:String>{resourceManager.getString('strings', 'lensHelp.stonePiles')}</fx:String>
                                        <fx:String>{resourceManager.getString('strings', 'lensHelp.signs')}</fx:String>
                                        <fx:String>{resourceManager.getString('strings', 'lensHelp.booksAndScrolls')}</fx:String>
                                    </s:ArrayList>
                                </s:dataProvider>
                            </s:DropDownList>
                        </s:HGroup>
                    </mg:GroupCheckBox>

                    <!-- flags -->
                    <mg:GroupBox id="flagsGroupBox"
                        label="@Resource(key='flags', bundle='strings')"
                        width="100%">
                        <mg:layout>
                            <s:HorizontalLayout padding="10"/>
                        </mg:layout>

                        <s:VGroup id="flagsLeftColumn" width="100%" height="100%">
                            <s:RadioButton id="commonRadioButton"
                                label="@Resource(key='isCommon', bundle='strings')"
                                group="{renderOrder}"/>
                            <s:RadioButton id="groundBorderRadioButton"
                                label="@Resource(key='isGroundBorder', bundle='strings')"
                                group="{renderOrder}"/>
                            <s:RadioButton id="onBottomRadioButton"
                                label="@Resource(key='isOnBottom', bundle='strings')"
                                group="{renderOrder}"/>
                            <s:RadioButton id="onTopRadioButton"
                                label="@Resource(key='isOnTop', bundle='strings')"
                                group="{renderOrder}"/>
                            <s:CheckBox id="containerCheckBox"
                                label="@Resource(key='container', bundle='strings')"
                                selected="{_thingBinding.isContainer}"
                                change="{_thingBinding.isContainer = containerCheckBox.selected;}"/>
                            <s:CheckBox id="stackableCheckBox"
                                label="@Resource(key='stackable', bundle='strings')"
                                selected="{_thingBinding.stackable}"
                                change="{_thingBinding.stackable = stackableCheckBox.selected;}"/>
                            <s:CheckBox id="forceUseCheckBox"
                                label="@Resource(key='forceUse', bundle='strings')"
                                selected="{_thingBinding.forceUse}"
                                change="{_thingBinding.forceUse = forceUseCheckBox.selected;}"/>
                            <s:CheckBox id="multiUseCheckBox"
                                label="@Resource(key='multiUse', bundle='strings')"
                                selected="{_thingBinding.multiUse}"
                                change="{_thingBinding.multiUse = multiUseCheckBox.selected;}"/>
                            <s:CheckBox id="liquidContainerCheckBox"
                                label="@Resource(key='fluidContainer', bundle='strings')"
                                selected="{_thingBinding.isFluidContainer}"
                                change="{_thingBinding.isFluidContainer = liquidContainerCheckBox.selected;}"/>
                            <s:CheckBox id="liquidPoolCheckBox"
                                label="@Resource(key='fluid', bundle='strings')"
                                selected="{_thingBinding.isFluid}"
                                change="{_thingBinding.isFluid = liquidPoolCheckBox.selected;}"/>
                            <s:CheckBox id="unpassableCheckBox"
                                label="@Resource(key='unpassable', bundle='strings')"
                                selected="{_thingBinding.isUnpassable}"
                                change="{_thingBinding.isUnpassable = unpassableCheckBox.selected;}"/>
                            <s:CheckBox id="unmovableCheckBox"
                                label="@Resource(key='unmovable', bundle='strings')"
                                selected="{_thingBinding.isUnmoveable}"
                                change="{_thingBinding.isUnmoveable = unmovableCheckBox.selected;}"/>
                            <s:CheckBox id="blockMissileCheckBox"
                                label="@Resource(key='blockMissile', bundle='strings')"
                                selected="{_thingBinding.blockMissile}"
                                change="{_thingBinding.blockMissile = blockMissileCheckBox.selected;}"/>
                            <s:CheckBox id="blockPathfindCheckBox"
                                label="@Resource(key='blockPathfinder', bundle='strings')"
                                selected="{_thingBinding.blockPathfind}"
                                change="{_thingBinding.blockPathfind = blockPathfindCheckBox.selected;}"/>
                        </s:VGroup>

                        <s:VGroup id="flagsRightColumn" width="100%" height="100%">
                            <s:CheckBox id="noMoveAnimationCheckBox"
                                label="@Resource(key='noMoveAnimation', bundle='strings')"
                                selected="{_thingBinding.noMoveAnimation}"
                                change="{_thingBinding.noMoveAnimation = noMoveAnimationCheckBox.selected;}"/>
                            <s:CheckBox id="pickupableCheckBox"
                                label="@Resource(key='pickupable', bundle='strings')"
                                selected="{_thingBinding.pickupable}"
                                change="{_thingBinding.pickupable = pickupableCheckBox.selected;}"/>
                            <s:CheckBox id="hangableCheckBox"
                                label="@Resource(key='hangable', bundle='strings')"
                                selected="{_thingBinding.hangable}"
                                change="{_thingBinding.hangable = hangableCheckBox.selected;}"/>
                            <s:CheckBox id="horizontalCheckBox"
                                label="@Resource(key='horizontalWall', bundle='strings')"
                                selected="{_thingBinding.isHorizontal}"
                                change="{_thingBinding.isHorizontal = horizontalCheckBox.selected;}"/>
                            <s:CheckBox id="verticalCheckBox"
                                label="@Resource(key='verticalWall', bundle='strings')"
                                selected="{_thingBinding.isVertical}"
                                change="{_thingBinding.isVertical = verticalCheckBox.selected;}"/>
                            <s:CheckBox id="rotatableCheckBox"
                                label="@Resource(key='rotatable', bundle='strings')"
                                selected="{_thingBinding.rotatable}"
                                change="{_thingBinding.rotatable = rotatableCheckBox.selected;}"/>
                            <s:CheckBox id="dontHideCheckBox"
                                label="@Resource(key='dontHide', bundle='strings')"
                                selected="{_thingBinding.dontHide}"
                                change="{_thingBinding.dontHide = dontHideCheckBox.selected;}"/>
                            <s:CheckBox id="translucentCheckBox"
                                label="@Resource(key='translucent', bundle='strings')"
                                selected="{_thingBinding.isTranslucent}"
                                change="{_thingBinding.isTranslucent = translucentCheckBox.selected;}"/>
                            <s:CheckBox id="isLyingObjectCheckBox"
                                label="@Resource(key='lyingObject', bundle='strings')"
                                selected="{_thingBinding.isLyingObject}"
                                change="{_thingBinding.isLyingObject = isLyingObjectCheckBox.selected;}"/>
                            <s:CheckBox id="animateAlwaysCheckBox"
                                label="@Resource(key='animateAlways', bundle='strings')"
                                selected="{_thingBinding.animateAlways}"
                                change="{_thingBinding.animateAlways = animateAlwaysCheckBox.selected; updateAnimationControls();}"/>
                            <s:CheckBox id="fullGroundCheckBox"
                                label="@Resource(key='fullGround', bundle='strings')"
                                selected="{_thingBinding.isFullGround}"
                                change="{_thingBinding.isFullGround = fullGroundCheckBox.selected;}"/>
                            <s:CheckBox id="ignoreLookCheckBox"
                                label="@Resource(key='ignoreLook', bundle='strings')"
                                selected="{_thingBinding.ignoreLook}"
                                change="{_thingBinding.ignoreLook = ignoreLookCheckBox.selected;}"/>
                            <s:CheckBox id="usableCheckBox"
                                label="@Resource(key='usable', bundle='strings')"
                                selected="{_thingBinding.usable}"
                                change="{_thingBinding.usable = usableCheckBox.selected;}"/>
                            <s:CheckBox id="chargesCheckBox"
                                label="@Resource(key='hasCharges', bundle='strings')"
                                selected="{_thingBinding.hasCharges}"
                                change="{_thingBinding.hasCharges = chargesCheckBox.selected;}"/>
                            <s:CheckBox id="floorChangeCheckBox"
                                label="@Resource(key='floorChange', bundle='strings')"
                                selected="{_thingBinding.floorChange}"
                                change="{_thingBinding.floorChange = floorChangeCheckBox.selected;}"/>
                            <s:CheckBox id="wrappableCheckBox"
                                label="@Resource(key='wrappable', bundle='strings')"
                                selected="{_thingBinding.wrappable}"
                                change="{_thingBinding.wrappable = wrappableCheckBox.selected;}"/>
                            <s:CheckBox id="unwrappableCheckBox"
                                label="@Resource(key='unwrappable', bundle='strings')"
                                selected="{_thingBinding.unwrappable}"
                                change="{_thingBinding.unwrappable = unwrappableCheckBox.selected;}"/>
                            <s:CheckBox id="topEffectCheckBox"
                                label="@Resource(key='topEffect', bundle='strings')"
                                selected="{_thingBinding.topEffect}"
                                change="{_thingBinding.topEffect = topEffectCheckBox.selected;}"/>
                        </s:VGroup>
                    </mg:GroupBox>
                </s:Group>
            </s:Scroller>
        </s:NavigatorContent>

        <!-- Attributes Tab (only for items, requires items.xml) -->
        <s:NavigatorContent label="@Resource(key='attributes', bundle='strings')"
            width="100%" height="100%"
            enabled="{_thingData != null &amp;&amp; _thingData.category == ThingCategory.ITEM &amp;&amp; _filesInfo != null &amp;&amp; _filesInfo.otbLoaded}">
            <otlib:AttributesEditor id="attributesEditor"
                width="100%" height="100%"
                thingData="{_thingData}"
                settings="{_settings}"
                change="onAttributesEditorChange(event)"/>
        </s:NavigatorContent>
    </nail:TabNavigator>
</s:Group>
