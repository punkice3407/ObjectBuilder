                    _thingBinding.copyFrom(thingData);
                    setCurrentFrameGroup(_thingBinding.getFrameGroup(thingView.frameGroupType));
            
                    addonGroup.visible = (isOutfit && _frameGroup.patternY > 1);
                    cropSizeNumericStepper.maximum = Math.max(_frameGroup.width * SpriteExtent.DEFAULT_SIZE, _frameGroup.height * SpriteExtent.DEFAULT_SIZE);
            
                    frameGroupSlider.visible = (isOutfit && _thingBinding.groups > 1);
                    animationModeDropDownList.selectedIndex = _frameGroup.animationMode;
                    loopCountNumericStepper.value = _frameGroup.loopCount;
                    startFrameNumericStepper.value = _frameGroup.startFrame;
                    frameStrategyDropDownList.selectedIndex = _frameGroup.loopCount != -1 ? 0 : 1;
            
                    if (isOutfit || isMissile)
                        selectDirectionButton(bottomCenterButton);
                    else
                        updatePreview();
            
                    // Update AttributesEditor with current thingData (via binding)
                    if (attributesEditor)
                        attributesEditor.thingData = thingData;
