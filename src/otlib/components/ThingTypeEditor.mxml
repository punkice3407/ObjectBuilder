                var size:uint = SpriteExtent.DEFAULT_SIZE;
                var bitmapWidth:Number = Math.max(size, (patternX * width) * size);
                var bitmapHeight:Number = Math.max(size, (patternY * height) * size);
                var pixelsWidth:int = width * size;
                var pixelsHeight:int = height * size;

                if (_viewBitmap && (_viewBitmap.width != bitmapWidth || _viewBitmap.height != bitmapHeight))
                {
                    _viewBitmap.dispose();
                    _viewBitmap = null;
                }

                if (!_viewBitmap)
                {
                    _viewBitmap = new BitmapData(bitmapWidth, bitmapHeight, true, 0x00FF00FF);
                }
                else
                {
                    _viewBitmap.fillRect(_viewBitmap.rect, 0x00FF00FF);
                }

                var f:uint = animationSlider.value;
                var l:uint = layerSlider.value;
