                {
                    spriteViewContainer.scaleX = _zoom;
                    spriteViewContainer.scaleY = _zoom;
                }
            
                _thingBinding.settings = settings;
            
                if (thingData)
                {
                    var isOutfit:Boolean = (thingData.category == ThingCategory.OUTFIT);
