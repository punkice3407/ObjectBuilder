            private function get numberFormatter():NumberFormatter
            {
                if (!_numberFormatter)
                {
                    _numberFormatter = new NumberFormatter();
                    _numberFormatter.useGrouping = true;
                    _numberFormatter.groupingSeparator = ",";
                    _numberFormatter.fractionalDigits = 0;
                }
                return _numberFormatter;
            }
            
            // --------------------------------------
            // Getters / Setters
            // --------------------------------------
            
            public function get bindableThingType():BindableThingType
            {
                return _thingBinding;
            }
            
            public function get thingData():ThingData
            {
                return _thingData;
            }
            public function set thingData(value:ThingData):void
            {
                if (_thingData != value)
                {
                    _thingData = value;
                    _thingDataChanged = true;
                    _changed = false;
                    invalidateProperties();
                    dispatchEvent(new ThingEditorEvent(ThingEditorEvent.THING_CHANGE, this.thingData));
                }
            }
            
            public function get changed():Boolean
            {
                return _thingData ? _changed : false;
            }
            
            public function get filesInfo():ClientInfo
            {
                return _filesInfo;
            }
            public function set filesInfo(value:ClientInfo):void
            {
                if (_filesInfo != value)
                {
                    _filesInfo = value;
                    _filesInfoChanged = true;
                    invalidateProperties();
                }
            }
            
            public function get currentFrame():int
            {
                if (_thingData)
                    return animationSlider.value;
                return -1;
            }
            
            public function get hasTransferData():Boolean
            {
                if (_thingData && _virtualTransferArea)
                    return true;
                return false;
            }
            
            public function setCurrentFrameGroup(value:FrameGroup):void
            {
                _frameGroup = value;
                // Update pixel grid size in single invalidation pass
                if (pixelGrid && value)
                    pixelGrid.setGridSize(value.width * 8, value.height * 8);
                else if (pixelGrid)
                    pixelGrid.setGridSize(1, 1);
            }
            
            public function set spriteDimension(value:SpriteDimension):void
            {
                SpriteExtent.DEFAULT_VALUE = value.toString();
                SpriteExtent.DEFAULT_SIZE = value.size;
                SpriteExtent.DEFAULT_DATA_SIZE = value.dataSize;
            
                _rect = new Rectangle(0, 0, SpriteExtent.DEFAULT_SIZE, SpriteExtent.DEFAULT_SIZE);
            }
            
            public function get settings():ObjectBuilderSettings
            {
                return _settings;
            }
            public function set settings(value:ObjectBuilderSettings):void
            {
                if (_settings != value)
                {
                    _settings = value;
                }
            }
            
            /**
             * Refreshes attribute buttons for current server from settings.
             * Call this after changing lastAttributeServer in settings.
             */
            public function refreshAttributeServer():void
            {
                if (!_settings)
                    return;
            
                // Delegate to embedded AttributesEditor
                if (attributesEditor)
                {
                    var serverName:String = _settings.lastAttributeServer || "tfs1.4";
                    attributesEditor.loadAttributesForServer(serverName);
                }
            }
            
            // --------------------------------------------------------------------------
            // METHODS
            // --------------------------------------------------------------------------
            
            // --------------------------------------
            // Public
            // --------------------------------------
            
            public function saveChanges():Boolean
            {
                if (_thingData && _changed)
                {
                    if (_thingBinding.copyToThingData(_thingData, _thingBinding.groups))
                    {
                        // xmlAttributes are already updated by onAttributesEditorChange()
                        _changed = false;
                        _pixelsModified = false;
                        _editPixelsMode = false;
                        dispatchEvent(new ThingEditorEvent(ThingEditorEvent.THING_PROPERTY_CHANGE, this.thingData));
                        return true;
                    }
                }
                return false;
            }
            
            /**
             * Copies properties from the worker response without marking as changed.
             * Used by updateThingPropertiesCallback to sync after save.
             */
            public function applyWorkerProperties(thing:ThingType):void
            {
                _loading = true;

                if (_thingData)
                    _thingData.thing.copyPropertiesFrom(thing);

                if (_thingBinding)
                    _thingBinding.copyPropertiesFrom(thing);

                _loading = false;
                _changed = false;
                _pixelsModified = false;
                _editPixelsMode = false;
            }

            public function getThingTypeResult():ThingType
            {
                if (_thingData)
                {
                    var thing:ThingType = new ThingType();
                    if (_thingBinding.copyToThingType(thing, _thingBinding.groups))
                    {
                        return thing;
                    }
                }
                return null;
            }
            
            public function get pixelsModified():Boolean
            {
                return _pixelsModified;
            }

            protected function editPixelsKeyHandler(event:KeyboardEvent):void
            {
                if (!_editPixelsMode || !_thingData) return;

                // Ctrl+A: select all film roll frames
                if (event.keyCode == Keyboard.A && event.ctrlKey
                    && _filmRollMode && _frameGroup && _frameGroup.frames > 1)
                {
                    selectAllFilmRollFrames();
                    event.preventDefault();
                    event.stopImmediatePropagation();
                    return;
                }

                var dx:int = 0, dy:int = 0;
                switch (event.keyCode)
                {
                    case Keyboard.UP:    dy = -1; break;
                    case Keyboard.DOWN:  dy = 1;  break;
                    case Keyboard.LEFT:  dx = -1; break;
                    case Keyboard.RIGHT: dx = 1;  break;
                    default: return;
                }

                if (getMultiSelectedFrameCount() > 0)
                    shiftMultipleFrames(dx, dy);
                else
                    shiftPixels(dx, dy);

                event.preventDefault();
                event.stopImmediatePropagation();
            }

            private function getDirectionLabel(direction:Direction):String
            {
                switch(direction)
                {
                    case Direction.NORTH: return "North";
                    case Direction.EAST: return "East";
                    case Direction.SOUTH: return "South";
                    case Direction.WEST: return "West";
                    case Direction.NORTHWEST: return "Northwest";
                    case Direction.NORTHEAST: return "Northeast";
                    case Direction.SOUTHWEST: return "Southwest";
                    case Direction.SOUTHEAST: return "Southeast";
                }
                return "";
            }

            private function getDirectionMappings():Array
            {
                var isOutfit:Boolean = (_thingData && _thingData.category == ThingCategory.OUTFIT);
                return [
                    { patX: isOutfit ? 0 : 1, patY: 0 },
                    { patX: isOutfit ? 1 : 2, patY: isOutfit ? 0 : 1 },
                    { patX: isOutfit ? 2 : 1, patY: isOutfit ? 0 : 2 },
                    { patX: isOutfit ? 3 : 0, patY: isOutfit ? 0 : 1 }
                ];
            }

            private function parseFrameName(name:String):Object
            {
                if (!name || name.indexOf("filmRollFrame_") != 0) return null;
                var suffix:String = name.substr(14);
                var uidx:int = suffix.indexOf("_");
                if (uidx >= 0)
                {
                    var dIdx:uint = uint(suffix.substr(0, uidx));
                    var dirs:Array = getDirectionMappings();
                    if (dIdx >= dirs.length) return null;
                    return { frameIdx: uint(suffix.substr(uidx + 1)), dirPatX: dirs[dIdx].patX, dirPatY: dirs[dIdx].patY };
                }
                return { frameIdx: uint(suffix), dirPatX: -1, dirPatY: -1 };
            }

            private function isFrameMultiSelected(frameName:String):Boolean
            {
                return _multiSelectedFrames[frameName] == true;
            }

            private function clearMultiSelection():void
            {
                _multiSelectedFrames = new Dictionary();
            }

            private function getMultiSelectedFrameCount():uint
            {
                var count:uint = 0;
                for (var key:String in _multiSelectedFrames) count++;
                return count;
            }

            /**
             * Find the frame name that matches the current selection (animationSlider + _patternX/_patternY).
             */
            private function findCurrentFrameName(container:IVisualElementContainer):String
            {
                for (var i:int = 0; i < container.numElements; i++)
                {
                    var el:Object = container.getElementAt(i);
                    if (el is Group)
                    {
                        var grp:Group = el as Group;
                        if (grp.name && grp.name.indexOf("filmRollFrame_") == 0)
                        {
                            var info:Object = parseFrameName(grp.name);
                            if (info && info.frameIdx == animationSlider.value)
                            {
                                if (info.dirPatX < 0)
                                    return grp.name; // Simple frame — match by frame index only
                                if (info.dirPatX == _patternX && info.dirPatY == _patternY)
                                    return grp.name; // Multi-direction — match direction too
                            }
                        }
                        else
                        {
                            var found:String = findCurrentFrameName(grp);
                            if (found) return found;
                        }
                    }
                    else if (el is IVisualElementContainer)
                    {
                        var found2:String = findCurrentFrameName(el as IVisualElementContainer);
                        if (found2) return found2;
                    }
                }
                return null;
            }

            private function isContentPixel(pixel:uint):Boolean
            {
                return (pixel >>> 24) > 0 && pixel != 0xFFFF00FF;
            }

            /**
             * Check if pixel shift would be blocked by boundary for the current frame.
             * Uses animationSlider.value, _patternX, _patternY (caller sets these).
             */
            private function isShiftBlocked(dx:int, dy:int):Boolean
            {
                if (!_thingData || !_frameGroup) return true;

                var groupType:uint = frameGroupSlider.value;
                var size:uint = SpriteExtent.DEFAULT_SIZE;
                var f:uint = animationSlider.value;
                var l:uint = layerSlider.value;
                var patX:uint = _patternX % _frameGroup.patternX;
                var patY:uint = (_patternY + addonsSlider.value) % _frameGroup.patternY;
                var z:uint = mountSlider.value;
                var fgWidth:uint = _frameGroup.width;
                var fgHeight:uint = _frameGroup.height;
                var totalW:uint = fgWidth * size;
                var totalH:uint = fgHeight * size;
                var rect32:Rectangle = new Rectangle(0, 0, size, size);
                var pt:Point = new Point();
                var emptyColor:uint = 0x00FF00FF;

                var composite:BitmapData = new BitmapData(totalW, totalH, true, emptyColor);
                for (var w:uint = 0; w < fgWidth; w++)
                {
                    for (var h:uint = 0; h < fgHeight; h++)
                    {
                        var index:int = _frameGroup.getSpriteIndex(w, h, l, patX, patY, z, f);
                        var bmp:BitmapData = _thingBinding.getSpriteBitmap(groupType, index);
                        if (!bmp) continue;
                        pt.x = (fgWidth - w - 1) * size;
                        pt.y = (fgHeight - h - 1) * size;
                        composite.copyPixels(bmp, rect32, pt);
                        bmp.dispose();
                    }
                }

                var blocked:Boolean = false;
                if (dx > 0)
                { for (var ry:int = 0; ry < totalH; ry++) { if (isContentPixel(composite.getPixel32(totalW - 1, ry))) { blocked = true; break; } } }
                else if (dx < 0)
                { for (var ly:int = 0; ly < totalH; ly++) { if (isContentPixel(composite.getPixel32(0, ly))) { blocked = true; break; } } }
                if (dy > 0)
                { for (var bx:int = 0; bx < totalW; bx++) { if (isContentPixel(composite.getPixel32(bx, totalH - 1))) { blocked = true; break; } } }
                else if (dy < 0)
                { for (var tx:int = 0; tx < totalW; tx++) { if (isContentPixel(composite.getPixel32(tx, 0))) { blocked = true; break; } } }

                composite.dispose();
                return blocked;
            }

            /**
             * Core pixel shift logic: compose → boundary check → shift → split.
             * Returns true if shift succeeded, false if blocked by boundary.
             * Does NOT trigger UI refresh or events — caller handles that.
             */
            private function shiftPixelsCore(dx:int, dy:int):Boolean
            {
                if (!_thingData || !_frameGroup) return false;

                var groupType:uint = frameGroupSlider.value;
                var size:uint = SpriteExtent.DEFAULT_SIZE;
                var f:uint = animationSlider.value;
                var l:uint = layerSlider.value;
                var patX:uint = _patternX % _frameGroup.patternX;
                var patY:uint = (_patternY + addonsSlider.value) % _frameGroup.patternY;
                var z:uint = mountSlider.value;
                var w:uint;
                var h:uint;
                var fgWidth:uint = _frameGroup.width;
                var fgHeight:uint = _frameGroup.height;
                var totalW:uint = fgWidth * size;
                var totalH:uint = fgHeight * size;
                var rect32:Rectangle = new Rectangle(0, 0, size, size);
                var pt:Point = new Point();
                var index:int;
                var bmp:BitmapData;

                var emptyColor:uint = 0x00FF00FF;

                var cropSize:uint = cropSizeNumericStepper.value;
                var cropW:uint = (cropSize > 0 && cropSize < totalW) ? Math.min(totalW, cropSize) : totalW;
                var cropH:uint = (cropSize > 0 && cropSize < totalH) ? Math.min(totalH, cropSize) : totalH;
                var cropX:int = totalW - cropW;
                var cropY:int = totalH - cropH;

                // 1. Compose all sprites into one large bitmap
                var composite:BitmapData = new BitmapData(totalW, totalH, true, emptyColor);
                for (w = 0; w < fgWidth; w++)
                {
                    for (h = 0; h < fgHeight; h++)
                    {
                        index = _frameGroup.getSpriteIndex(w, h, l, patX, patY, z, f);
                        bmp = _thingBinding.getSpriteBitmap(groupType, index);
                        if (!bmp) continue;
                        pt.x = (fgWidth - w - 1) * size;
                        pt.y = (fgHeight - h - 1) * size;
                        composite.copyPixels(bmp, rect32, pt);
                        bmp.dispose();
                    }
                }

                // 2. Boundary check
                var blocked:Boolean = false;
                if (dx > 0)
                {
                    for (var ery:int = 0; ery < totalH; ery++)
                    { if (isContentPixel(composite.getPixel32(totalW - 1, ery))) { blocked = true; break; } }
                }
                else if (dx < 0)
                {
                    for (var ely:int = 0; ely < totalH; ely++)
                    { if (isContentPixel(composite.getPixel32(0, ely))) { blocked = true; break; } }
                }
                if (dy > 0)
                {
                    for (var ebx:int = 0; ebx < totalW; ebx++)
                    { if (isContentPixel(composite.getPixel32(ebx, totalH - 1))) { blocked = true; break; } }
                }
                else if (dy < 0)
                {
                    for (var etx:int = 0; etx < totalW; etx++)
                    { if (isContentPixel(composite.getPixel32(etx, 0))) { blocked = true; break; } }
                }

                if (blocked) { composite.dispose(); return false; }

                // 3. Shift the composite
                var shifted:BitmapData = new BitmapData(totalW, totalH, true, emptyColor);
                pt.x = dx; pt.y = dy;
                shifted.copyPixels(composite, composite.rect, pt);
                composite.dispose();

                // 4. Split back into individual sprites
                var region:Rectangle = new Rectangle(0, 0, size, size);
                var tile:BitmapData = new BitmapData(size, size, true, emptyColor);
                pt.x = 0; pt.y = 0;
                for (w = 0; w < fgWidth; w++)
                {
                    for (h = 0; h < fgHeight; h++)
                    {
                        index = _frameGroup.getSpriteIndex(w, h, l, patX, patY, z, f);
                        region.x = (fgWidth - w - 1) * size;
                        region.y = (fgHeight - h - 1) * size;
                        tile.fillRect(rect32, emptyColor);
                        tile.copyPixels(shifted, region, pt);
                        var tilePixels:ByteArray = tile.getPixels(rect32);

                        var sd:SpriteData = _thingBinding.sprites[groupType][index];
                        var origId:uint = _frameGroup.spriteIndex[index];
                        if (sd && origId != 0)
                        {
                            var clonedSd:SpriteData = SpriteData.createSpriteData(uint.MAX_VALUE, tilePixels);
                            _thingBinding.sprites[groupType][index] = clonedSd;
                            _frameGroup.spriteIndex[index] = uint.MAX_VALUE;
                        }
                        else
                        {
                            var newSd:SpriteData = SpriteData.createSpriteData(uint.MAX_VALUE, tilePixels);
                            if (!newSd.isEmpty())
                                _thingBinding.setSprite(groupType, index, newSd);
                        }
                    }
                }
                tile.dispose();
                shifted.dispose();
                return true;
            }

            private function shiftPixels(dx:int, dy:int):void
            {
                if (!shiftPixelsCore(dx, dy)) return;

                _pixelsModified = true;
                _changed = true;

                if (_filmRollMode && _frameGroup.frames > 1)
                    refreshFilmRollFrame();
                else
                    refreshViewBitmap();

                setFocus();
                dispatchEvent(new ThingEditorEvent(ThingEditorEvent.THING_PROPERTY_CHANGE, _thingData));
            }

            private function shiftMultipleFrames(dx:int, dy:int):void
            {
                if (!_thingData || !_frameGroup) return;

                var savedF:uint = animationSlider.value;
                var savedPatX:uint = _patternX;
                var savedPatY:uint = _patternY;

                // Pass 1: check ALL frames — if ANY is blocked, abort entirely
                for (var frameName:String in _multiSelectedFrames)
                {
                    var info:Object = parseFrameName(frameName);
                    if (!info) continue;

                    animationSlider.value = info.frameIdx;
                    if (info.dirPatX >= 0)
                    {
                        _patternX = info.dirPatX;
                        _patternY = info.dirPatY;
                    }

                    if (isShiftBlocked(dx, dy))
                    {
                        // Restore and abort — no frames shifted
                        animationSlider.value = savedF;
                        _patternX = savedPatX;
                        _patternY = savedPatY;
                        return;
                    }
                }

                // Pass 2: shift ALL frames (guaranteed none blocked)
                for (frameName in _multiSelectedFrames)
                {
                    info = parseFrameName(frameName);
                    if (!info) continue;

                    animationSlider.value = info.frameIdx;
                    if (info.dirPatX >= 0)
                    {
                        _patternX = info.dirPatX;
                        _patternY = info.dirPatY;
                    }

                    shiftPixelsCore(dx, dy);
                }

                animationSlider.value = savedF;
                _patternX = savedPatX;
                _patternY = savedPatY;

                _pixelsModified = true;
                _changed = true;

                if (_filmRollMode && _frameGroup.frames > 1)
                    updatePreview();
                else
                    refreshViewBitmap();

                setFocus();
                dispatchEvent(new ThingEditorEvent(ThingEditorEvent.THING_PROPERTY_CHANGE, _thingData));
            }

            private function selectAllFilmRollFrames():void
            {
                clearMultiSelection();
                collectFrameNamesRecursive(buttonsContainer);
                updateFilmRollSelection();
            }

            private function collectFrameNamesRecursive(container:IVisualElementContainer):void
            {
                for (var i:int = 0; i < container.numElements; i++)
                {
                    var el:Object = container.getElementAt(i);
                    if (el is Group)
                    {
                        var grp:Group = el as Group;
                        if (grp.name && grp.name.indexOf("filmRollFrame_") == 0)
                            _multiSelectedFrames[grp.name] = true;
                        else
                            collectFrameNamesRecursive(grp);
                    }
                    else if (el is IVisualElementContainer)
                    {
                        collectFrameNamesRecursive(el as IVisualElementContainer);
                    }
                }
            }

            public function updateFrameGroupNameLabel():void
            {
                if (frameGroupSlider.value == 0)
                {
                    frameGroupNameLabel.text = "Idle / Stand";
                }
                else
                {
                    frameGroupNameLabel.text = "Walking";
                }
            }
            
            public function frameGroupSliderChange():void
            {
                if (!_thingBinding || !_thingBinding.frameGroups)
                    return;
            
                var group:FrameGroup = _thingBinding.getFrameGroup(frameGroupSlider.value);
                if (group)
                    setCurrentFrameGroup(group);
            
                updateFrameGroupNameLabel();
                animationSlider.value = 0;
                mountSlider.value = 0;
                addonsSlider.value = 0;
                updateAnimationControls();
                updatePreview();
            }
            
            public function updatePreview():void
            {
                if (!_thingData)
                    return;
            
                // Build state key to detect if update is needed
                var animVal:int = animationSlider.value;
                var animMax:int = animationSlider.maximum;
                var addonVal:int = addonsSlider.value;
                var mountVal:int = mountSlider.value;
                var layerVal:int = layerSlider.value;
                var stateKey:String = animVal + "," + animMax + "," + addonVal + "," + mountVal + "," + layerVal + "," + _patternX + "," + _patternY;
            
                // Update labels only if state changed
                if (stateKey != _lastPreviewState)
                {
                    _lastPreviewState = stateKey;
                    animationCountLabel.text = (animVal + 1) + "/" + (animMax + 1);
                    addonCountLabel.text = (addonVal + 1) + "/" + (addonsSlider.maximum + 1);
                    mountCountLabel.text = (mountVal + 1) + "/" + (mountSlider.maximum + 1);
                    layerCountLabel.text = (layerVal + 1) + "/" + (layerSlider.maximum + 1);
                }
            
                thingView.patternX = _patternX;
                thingView.patternY = _patternY;
                thingView.patternZ = mountVal;
                thingView.frameGroupType = frameGroupSlider.value;
            
                var frameDuration:FrameDuration = _frameGroup.getFrameDuration(animVal);
                if (frameDuration)
                {
                    minimumNumericStepper.value = frameDuration.minimum;
                    maximumNumericStepper.value = frameDuration.maximum;
                    refreshFrameDurationsTime();
                }
            
                var isOutfitOrMissile:Boolean = (_thingData.category == ThingCategory.OUTFIT || _thingData.category == ThingCategory.MISSILE);

                if (isOutfitOrMissile)
                {
                    addonGroup.visible = (_thingData.category == ThingCategory.OUTFIT && patternYNumericStepper.value > 1);
                    frameGroupSlider.visible = (_thingData.category == ThingCategory.OUTFIT && frameGroupsNumericStepper.value > 1);
                }

                if (_filmRollMode && _frameGroup.frames > 1)
                {
                    if (isOutfitOrMissile)
                        updateMultiDirectionFilmRollView();
                    else
                        updateFilmRollView();
                }
                else if (isOutfitOrMissile)
                {
                    updateViewWithDirection();
                }
                else
                {
                    updateView();
                }

                // Return focus to editor when in edit pixels mode
                if (_editPixelsMode)
                    setFocus();
            }
            
            public function invalidateThingData():void
            {
                _invalidateThingData = true;
                invalidateProperties();
            }
            
            public function clearSprite(frame:int, index:int):void
            {
                if (!_thingData || !_frameGroup || frame < 0 || frame >= _frameGroup.frames || index < 0 || index >= _frameGroup.spriteIndex.length)
                    return;
            
                _thingBinding.setSprite(_frameGroup.type, index, new SpriteData());
                updatePreview();
            }
            
            /**
             * Recursively collect all sprite Buttons from a container (handles film roll nesting).
             */
            private function collectSpriteButtons(container:IVisualElementContainer, result:Vector.<Button>):void
            {
                for (var i:int = 0; i < container.numElements; i++)
                {
                    var el:Object = container.getElementAt(i);
                    if (el is Button)
                        result.push(el as Button);
                    else if (el is IVisualElementContainer)
                        collectSpriteButtons(el as IVisualElementContainer, result);
                }
            }

            public function copyFrame(frame:int):void
            {
                if (!_thingData || !_frameGroup || frame < 0 || frame >= _frameGroup.frames)
                    return;

                var groupType:uint = _frameGroup.type;
                if (!_thingBinding.sprites[groupType])
                    return;

                var buttons:Vector.<Button> = new Vector.<Button>();
                collectSpriteButtons(buttonsContainer, buttons);
                var length:int = buttons.length;
                _virtualTransferArea = new Vector.<SpriteData>(length, true);
                for (var i:int = 0; i < length; i++)
                {
                    var index:int = parseInt(buttons[i].label);
                    _virtualTransferArea[i] = _thingBinding.sprites[groupType][index].clone();
                }
            }

            public function pasteFrame(frame:int):void
            {
                if (!_thingData || !_frameGroup || frame < 0 || frame >= _frameGroup.frames)
                    return;

                if (!_virtualTransferArea)
                    return;

                var buttons:Vector.<Button> = new Vector.<Button>();
                collectSpriteButtons(buttonsContainer, buttons);
                if (_virtualTransferArea.length != buttons.length)
                    return;

                var groupType:uint = _frameGroup.type;
                if (!_thingBinding.sprites[groupType])
                    return;

                for (var i:int = 0; i < buttons.length; i++)
                {
                    var index:int = parseInt(buttons[i].label);
                    _thingBinding.setSprite(groupType, index, _virtualTransferArea[i]);
                }
                updatePreview();
            }

            public function clearFrame(frame:int):void
            {
                if (!_thingData || !_frameGroup || frame < 0 || frame >= _frameGroup.frames)
                    return;

                var groupType:uint = _frameGroup.type;
                if (!_thingBinding.sprites[groupType])
                    return;

                var sprite:SpriteData = new SpriteData();
                var buttons:Vector.<Button> = new Vector.<Button>();
                collectSpriteButtons(buttonsContainer, buttons);
                for (var i:int = 0; i < buttons.length; i++)
                {
                    var index:int = parseInt(buttons[i].label);
                    _thingBinding.setSprite(groupType, index, sprite);
                }
                updatePreview();
            }
