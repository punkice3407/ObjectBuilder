            private function updateViewWithDirection():void
            {
                removeButtons();

                if (!_thingData || !_frameGroup)
                    return;

                var width:uint = _frameGroup.width;
                var height:uint = _frameGroup.height;
                var size:uint = SpriteExtent.DEFAULT_SIZE;
                var bitmapWidth:Number = Math.max(size, width * size);
                var bitmapHeight:Number = Math.max(size, height * size);

                if (_viewBitmap && (_viewBitmap.width != bitmapWidth || _viewBitmap.height != bitmapHeight))
                {
                    _viewBitmap.dispose();
                    _viewBitmap = null;
                }

                if (!_viewBitmap)
                {
                    _viewBitmap = new BitmapData(bitmapWidth, bitmapHeight, true, 0x00FF00FF);
                }
                else
                {
                    _viewBitmap.fillRect(_viewBitmap.rect, 0x00FF00FF);
                }

                var f:uint = animationSlider.value;
                var l:uint = layerSlider.value;
                var x:uint = _patternX % _frameGroup.patternX;
                var y:uint = (_patternY + addonsSlider.value) % _frameGroup.patternY;
                var z:uint = mountSlider.value;

                _suppressDrawCropSize = true;
                for (var w:uint = 0; w < width; w++)
                {
                    for (var h:uint = 0; h < height; h++)
                    {
                        var index:int = _frameGroup.getSpriteIndex(w, h, l, x, y, z, f);
                        var id:uint = _frameGroup.spriteIndex[index];
                        var px:int = ((width - w - 1) * size);
                        var py:int = ((height - h - 1) * size);
                        copyPixels(_frameGroup.type, index, _viewBitmap, px, py);
                        addButton(index, id, px, py);
                    }
                }
                _suppressDrawCropSize = false;

                if (bitmapView.source && bitmapView.source != _viewBitmap)
                {
                    bitmapView.source.dispose();
                    bitmapView.source = null;
                }

                bitmapView.source = _viewBitmap;
                buttonsContainer.width = _viewBitmap.width;
                buttonsContainer.height = _viewBitmap.height;
                spriteViewContainer.scaleX = _zoom;
                spriteViewContainer.scaleY = _zoom;
                drawCropSize();
            }

            private function updateView():void
            {
